<?xml version="1.0" encoding="utf-8" ?>
<data>
	<father name="deathRole">
		<skill>
			<name>deathPro</name>
			<cnName>属性加成</cnName>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>passive</conditionType>
			<condition>allHit</condition>
			<target>me</target>
			<!--效果------------------------------------------------------------ -->
			<addType>instant</addType>
			<effectType>pro</effectType><effectFather>death</effectFather>
		</skill>
		<skill>
			<name>rollingDeath</name>
			<cnName>翻滚</cnName><ignoreImmunityB>1</ignoreImmunityB><ignoreNoSkillB>1</ignoreNoSkillB>
			<iconUrl>SkillIcon/rolling_hero</iconUrl>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>passive</conditionType>
			<condition>rollKey</condition>
			<otherConditionArr>rollingDeath</otherConditionArr>
			<target>me</target>
			<!--效果------------------------------------------------------------ -->
			<addType>state</addType>
			<effectType>rolling</effectType><effectFather>death</effectFather>
			<minTriggerT>0.56</minTriggerT>
			<mul>0</mul><!-- 限制玩家移动速度的影响 -->
			<value>180</value><!-- 移动距离 -->
			<duration>0.46</duration>
			<secMul>0.36</secMul><!-- 移动持续的时间 -->
			<stateEffectImg name="rolling_hero_state"/>
			<otherEffectImg name="sprintSmoke"/>
			<!--图像------------------------------------------------------------ -->
			<description>按下翻滚键进行翻滚，期间不受攻击、子弹碰撞，最短触发间隔[minTriggerT]秒。</description>
		</skill>
		<skill>
			<name>infiniteAnger</name>
			<cnName>无限怒气</cnName><everNoClearB>1</everNoClearB><noSkillDodgeB>1</noSkillDodgeB><ignoreImmunityB>1</ignoreImmunityB>
			<conditionType>passive</conditionType><noBeClearB>1</noBeClearB>
			<condition>add</condition>
			<target>me</target>
			<!--效果------------------------------------------------------------ -->
			<addType>state</addType>
			<effectType>addAnger</effectType>
			<value>100</value>
			<duration>999999</duration>
			<description>无限怒气。</description>
		</skill>
		<skill>
			<name>weaponRosLost</name>
			<cnName>副手硬直</cnName><everNoClearB>1</everNoClearB><noSkillDodgeB>1</noSkillDodgeB><ignoreImmunityB>1</ignoreImmunityB><ignoreNoSkillB>1</ignoreNoSkillB>
			<conditionType>passive</conditionType><noBeClearB>1</noBeClearB>
			<condition>ros</condition>
			<otherConditionArr>isWeaponHurt,targetIsHero</otherConditionArr>
			<target>target</target>
			<!--效果------------------------------------------------------------ -->
			<addType>instantAndState</addType>
			<effectType>weaponRosLost</effectType><effectFather>death</effectFather>
			<duration>0.8</duration>
			<stateEffectImg name="pullAttackHit_state"/>
			<description>副手攻击让持枪单位硬直时，使其失去射击能力[duration]秒钟。</description>
		</skill>
	</father>
	<father name="drop">
		<skill>
			<name>deathGem</name>
			<cnName>升级水晶</cnName>
			<!--效果------------------------------------------------------------ -->
			<addType>instant</addType>
			<effectType>deathGem</effectType><effectFather>death</effectFather>
			<meEffectImg name="murderous_enemy_state"/>
		</skill>
	</father>
</data>