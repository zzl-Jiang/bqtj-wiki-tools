	<father name="deathArms">
		<skill>
			<name>yearHourseDea</name><noRandomListB>1</noRandomListB>
			<cnName>处决</cnName><noSkillDodgeB>1</noSkillDodgeB><ignoreImmunityB>1</ignoreImmunityB>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>passive</conditionType><changeHurtB>1</changeHurtB>
			<condition>hit</condition>
			<otherConditionArr>targetLifePerLess</otherConditionArr>
			<conditionRange>0.25</conditionRange>
			<target>target</target>
			<!--效果------------------------------------------------------------ -->
			<addType>instant</addType>
			<effectType>changeHurtNoCondition</effectType>
			<mul>10</mul>
			<targetEffectImg con="add" partType="body">boomEffect/midCan</targetEffectImg>
			<!--图像------------------------------------------------------------ -->
			<description>对生命值低于25%的敌人造成10倍的伤害，无视技能免疫。</description>
		</skill>
	</father>
