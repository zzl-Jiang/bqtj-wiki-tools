<?xml version="1.0" encoding="utf-8" ?>
<data>
	<father  type="rocket" cnName="火炮-特殊">
		<bullet index="40" cnName="亥猪" name="yearPig" color="black" composeLv="90" chipB="1" chipNum="160" dropLevelArr="999">
			<name>yearPig</name>
			<cnName>亥猪</cnName>
			<!--随机属性------------------------------------------------------------ -->
			<!--基本-->
			<capacity>5</capacity>
			<attackGap>1.3</attackGap>
			<reloadGap>4</reloadGap>
			<shakeAngle>0</shakeAngle>
			<bulletWidth>30</bulletWidth>
			<bulletShakeWidth>0,0</bulletShakeWidth>
			<bulletNum>1</bulletNum>				
			<gunNum>1</gunNum>
			
			<!--武器属性------------------------------------------------------------ -->
			<armsArmMul>0.65</armsArmMul>
			<upValue>5</upValue>
			<shootShakeAngle>40</shootShakeAngle>
			<shootRecoil>12</shootRecoil>
			<screenShakeValue>16</screenShakeValue>
			<!--基本属性------------------------------------------------------------ -->
			<noShakeTime>0.5</noShakeTime>
			<bulletLife>2</bulletLife>
			<hitType>rect</hitType>
			<!--攻击时的属性------------------------------------------------------------ -->
			<dpsMul>1.8</dpsMul>
			<uiDpsMul>2</uiDpsMul>
			
			<!--运动属性------------------------------------------------------------ -->	
			<bulletSpeed>20</bulletSpeed>
			<!--特殊------------------------------------------------------------ -->
			<boomD  bodyB="1" floorB="1" selfB="1" radius="130"/>
			<twoShootPro>0.4</twoShootPro>
			<penetrationGap>0</penetrationGap>
			<bounceD floor="0" body="1"/>	<!-- 反弹 -->
			<critD mul="2" pro="0.3"/>
			
			
			<skillArr>Hit_blindness_ArmsSkill,Hit_Paralysis_ArmsSkill</skillArr>
			<godSkillArr>Hit_fleshSkill_godArmsSkill,yearPigSkill</godSkillArr>
			<!--图像动画属性------------------------------------------------------------ -->
			<iconUrl>specialGun/yearPigIcon</iconUrl>
			<flipX>1</flipX>
			<bulletImgUrl con="filter" raNum="30">bullet/blueFire</bulletImgUrl>
			<hitImgUrl soundUrl="sound/fireHit2"  soundVolume="0.3"  shake="3,0.4,13" con="add">boomEffect/boom2</hitImgUrl><!-- 子弹图像【必备】 -->
			<hitFloorImgUrl soundUrl="sound/fireHit1"  shake="3,0.4,9" soundVolume="0.5" con="add">boomEffect/boom1</hitFloorImgUrl><!-- 子弹图像【必备】 -->
			<fireImgType></fireImgType>
			<shootSoundUrl>sound/bigShoot</shootSoundUrl>
			<!--图像范围------------------------------------------------------------ -->
			<bodyImgRange>specialGun/yearPig</bodyImgRange>
			<bulletImgRange>specialGun/bullet</bulletImgRange>
			<description>远古宝箱、生肖碎片包(活跃值礼包)、纪念币商店、黄金商店、竞技宝箱</description>
		</bullet>
		
	</father>
	<father name="godArmsSkill" cnName="神级武器技能">
		<skill index="0" name="周五大吉"><!-- dps-被动 -->
			<name>yearPigSkill</name><noSkillDodgeB>1</noSkillDodgeB><ignoreImmunityB>1</ignoreImmunityB>
			<cnName>周五大吉</cnName><noRandomListB>1</noRandomListB>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>passive</conditionType>
			<condition>hit</condition>
			<otherConditionArr>puWe,noDemonOnlyBoss,noMainTask,noHardB,dayPan,yearArmsFalse,targetUnitType,noUnionBattle</otherConditionArr>
			<conditionRange>5</conditionRange>
			<conditionString>boss</conditionString>
			<target>target</target>
			<!--效果------------------------------------------------------------ -->
			<addType>instant</addType>
			<effectType>yearArmsKill</effectType>
			<!--图像------------------------------------------------------------ -->
			<meEffectImg></meEffectImg>
			<targetEffectImg soundUrl="sound/pointBoom_hero">boomEffect/bigCircle</targetEffectImg>
			<description>每周五可以直接瞬秒一个首领，无视技能免疫。主线任务、困难模式、修罗决斗模式、军队争霸中该技能无效。</description>
		</skill>
	</father>
</data>