					<bulletNum>10</bulletNum>
					<shootAngle>13</shootAngle>
					<bulletAngle>90</bulletAngle>
					<bulletLife>5</bulletLife>
					<bulletWidth>25</bulletWidth>
					<hitType>rect</hitType>
					<!--攻击时的属性------------------------------------------------------------ -->
					<bulletSpeed>13</bulletSpeed>
					<speedD lockRaB="1"/>
					<penetrationGap>1000</penetrationGap>
					<!--图像动画属性------------------------------------------------------------ -->
					<flipX>1</flipX>
					<bulletImgUrl name="redThorn"/>
					<hitImgUrl name="gun_hit"/>
				</bullet>

	</father>
	<father type="energy" info="鬼影战士-鬼武E">
		<bullet>
			<name>spiralCannonE</name>
