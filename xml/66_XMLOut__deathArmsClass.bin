<?xml version="1.0" encoding="utf-8" ?>
<data>
	<father cn="来自武器工厂">
		<armsEdit name="snakeCrossbow$dea" info="多发弩-僵尸突击兵武器">{'baseLabel':'snakeCrossbow','color':'white','dpsMul':1,'extraMul':1,'followD':{'shootTween':0.3},'fireImg':'SilverShipFire','godSkillArr':[],'aiShootRange':700,'attackGap':1.7,'bulletSpeed':15,'shootAngle':15,'bulletNum':5,'bulletLife':1.9}</armsEdit>
		<armsEdit name="rocketSky$dea" info="备用">{'baseLabel':'rocketSky','color':'white','dpsMul':1,'extraMul':1,'boomD':{'radius':60},'bounceD':{'body':0},'skillArr':[],'shootSoundUrl':'specialGun/rocketHummer_sound','speedD':{'max':30,'min':5,'a':20},'attackGap':1.5,'bulletLife':6,'aiShootRange':1200,'godSkillArr':[],'penetrationNum':0,'twoShootPro':0,'capacity':4,'bulletSpeed':5,'hitFloorImg':'smallSpace'}</armsEdit>
		<armsEdit name="sniperBlue$dea" info="僵尸狙击兵武器">{'baseLabel':'sniperBlue','followD':{'shootDelayLockB':true},'attackGap':2.5,'attackDelay':1.4,'bulletWidth':800,'bounceD':{'body':0},'skillArr':[],'penetrationNum':0,'dpsMul':1,'twoShootPro':0,'godSkillArr':[]}</armsEdit>
		<armsEdit name="rocketMammoth$dea">{'skillArr':[],'baseLabel':'rocketMammoth','aiShootRange':600,'color':'white','bounceD':{'body':0},'boomD':{'floorB':false,'bodyB':false},'attackGap':1.8,'noHitB':true,'twoShootPro':0,'whippB':false,'penetrationNum':0,'dpsMul':1,'godSkillArr':[]}</armsEdit>
		<armsEdit name="roamRocket$dea" info="防爆僵尸武器">{'cnName':'漫游','baseLabel':'roamRocket','attackGap':0.6,'attackDelay':0.55,'aiShootRange':850,'bulletSpeed':4,'bulletImg':'fightBackBullet_bullet','speedD':{'min':3},'boomD':{'haveBodyHitEffectB':false,'maxHurtNum':40,'selfB':false,'floorB':false},'noHitTime':0.1,'bulletLife':8,'color':'white','dpsMul':1,'godSkillArr':[]}</armsEdit>
		<armsEdit name="starTrails$dea" info="僵尸暴枪兵武器">{'cnName':'星环','baseLabel':'starTrails','dpsMul':0.02,'extraMul':1,'reloadGap':1.5,'capacity':20,'bulletWidth':60,'penetrationGap':1000,'attackGap':0.5,'bulletLife':0.5,'bulletNum':3,'shootAngle':120,'speedD':{'vra':0.42},'aiShootRange':900,'followD':{'aiStopGap':110,'shootTween':0.3}}</armsEdit>
		
	</father>
	<father type="cutter">
		<bullet>
			<name>sawEmitterE</name><dpsMul>1</dpsMul>
			<cnName>矿锯发射器E</cnName>
			<aiShootRange>700</aiShootRange><!-- ai射程 -->
			<attackType>direct</attackType>
			
			<!--基本-->
			<capacity>5</capacity>
			<attackGap>1.3</attackGap>
			<attackDelay>1</attackDelay>
			<reloadGap>2</reloadGap>
			<bulletWidth>30</bulletWidth>
			<bulletNum>1</bulletNum>
			<!--武器属性------------------------------------------------------------ -->
			<armsArmMul>0.5</armsArmMul>
			<upValue>10</upValue>
			<shootShakeAngle>20</shootShakeAngle>
			<shootRecoil>20</shootRecoil>
			<screenShakeValue>16</screenShakeValue>
			<!--基本属性------------------------------------------------------------ -->
			<bulletLife>4</bulletLife>
			<hitType>rect</hitType>
			<!--运动属性------------------------------------------------------------ -->	
			<bulletSpeed>8</bulletSpeed>
			<followD value="2" delay="0.5" maxTime="2.5"/>
			<bindingD cnName="太空空单位" lifeMul="0.1"/>
			<!--特殊------------------------------------------------------------ -->
			<skillArr></skillArr>
			<!--图像动画属性------------------------------------------------------------ -->
			<fireImgUrl con="add">boomEffect/boom2</fireImgUrl>
			<shootSoundUrl>specialGun/yearCattleSound</shootSoundUrl>
			<bulletImgUrl name="oreSawBullet"/>
			<smokeImgUrl name="oreBombState"/>
			<hitImgUrl name="oreWormHit"/>
			<hitFloorImgUrl raNum="30">bulletHitEffect/smoke_motion</hitFloorImgUrl>
			<!--图像范围------------------------------------------------------------ -->
			<bodyImgRange>specialGun/sawEmitterE</bodyImgRange>
		</bullet>
	</father>
	<father type="rocket">
		<bullet  info="僵尸炮兵总管武器">
			<name>sunDeath</name>
			<cnName>子母炮</cnName>
			<!--随机属性------------------------------------------------------------ -->
			<!--基本-->
			<capacity>5</capacity><dpsMul>0.7</dpsMul>
			<attackGap>2</attackGap>
			<attackDelay>1</attackDelay>
			<reloadGap>2</reloadGap>
			<bulletWidth>20</bulletWidth>
			<aiShootRange>700</aiShootRange>
			<bulletNum>1</bulletNum>				
			<bulletSkillArr>sunDeathSunSunDieEvent</bulletSkillArr>
			<!--武器属性------------------------------------------------------------ -->
			<armsArmMul>0.65</armsArmMul>
			<upValue>5</upValue>
			<shootShakeAngle>30</shootShakeAngle>
			<shootRecoil>12</shootRecoil>
			<screenShakeValue>16</screenShakeValue>
			<!--基本属性------------------------------------------------------------ -->
			<noShakeTime>0.5</noShakeTime>
			<bulletLife>0.8</bulletLife>
			<hitType>rect</hitType>
			<!--运动属性------------------------------------------------------------ -->	
			<bulletSpeed>15</bulletSpeed>
			<!--特殊------------------------------------------------------------ -->
			<boomD selfB="1" bodyB="1" floorB="1" radius="60"/>
			<followD shootTween="0.3"/>
			<!--图像动画属性------------------------------------------------------------ -->
			<iconUrl></iconUrl>
			<bulletImgUrl name="sunDeathBullet"/>
			<hitImgUrl name="midSpaceQuietly"/><!-- 子弹图像【必备】 -->
			<smokeImgUrl name="rocketSmokeSm"/><!-- redFire_smoke -->
			<fireImgUrl name="gunFireRocket"/>
			<shootSoundUrl>specialGun/rocketHummer_sound</shootSoundUrl>
			<!--图像范围------------------------------------------------------------ -->
			<bodyImgRange>specialGun/rocketMammoth</bodyImgRange>
			<bulletImgRange>specialGun/bullet</bulletImgRange>
		</bullet>
		
			<bullet cnName="子母炮-子弹">
				<name>sunDeathSun</name>
				<cnName>子母炮-子弹</cnName><armsType>rocket</armsType>
				<noMagneticB>1</noMagneticB>
				<!--伤害属性------------------------------------------------------------ -->
				<hurtRatio>0.4</hurtRatio>
				<!--基本属性------------------------------------------------------------ -->
				<bulletAngle>0</bulletAngle>
				<bulletLife>0.7</bulletLife>
				<bulletWidth>20</bulletWidth>
				<hitType>rect</hitType>
				<!--攻击时的属性------------------------------------------------------------ -->
				<bulletNum>16</bulletNum>
				<shootAngle>167</shootAngle>
				<!--运动属性------------------------------------------------------------ -->	
				<noHitTime>0.15</noHitTime>
				<bulletSpeed>15</bulletSpeed>
				<speedD a="-10" min="1"  />
				<!--图像动画属性------------------------------------------------------------ -->
				<flipX>1</flipX>
				<![CDATA[
				<bulletImgUrl raNum="30">bullet/gaiaSmallBullet</bulletImgUrl>
				<smokeImgUrl con="filter" raNum="30">bulletHitEffect/smoke_small</smokeImgUrl>
				<hitImgUrl soundUrl="boomSound/midBoom2" soundVolume="0.3">boomEffect/boom1</hitImgUrl>
				]]>
				<bulletImgUrl>LingShooter/bullet</bulletImgUrl>
				<hitImgUrl soundUrl="LingShooter/hit2">bulletHitEffect/yellow_motion</hitImgUrl>
				<hitFloorImgUrl name="fireFlamer_hit"/>
			</bullet>
	</father>
	<father type="pistol">
		<bullet color="white"  info="鬼目射手武器">
			<name>lingPistol</name>
