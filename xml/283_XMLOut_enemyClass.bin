			<!-- 运动 -->
			<maxJumpNum>1</maxJumpNum>
			<maxVx>10</maxVx>
			<!-- AI属性 -->
			<nextAttackTime>0</nextAttackTime>
			<!-- 技能 -->
			<skillArr>suicide_headless,boom_headless</skillArr>
			<canBossB>0</canBossB><!-- 不能成为boss -->
