<?xml version="1.0" encoding="utf-8" ?>
<data>
	<father name="materials" cnName="">
		<things cnName="终级装备守护卡">
			<name>ultiEquipEchelonCard</name>
			<cnName>终级装备守护卡</cnName>
			<iconUrl>ThingsIcon/ultiEquipEchelonCard</iconUrl><!-- 技能图标 -->
			<description>
				强化装备的保级道具，最高保级26级。
				[n][n]{b}{font color='#FFFF00'}获得方式：{/font}{/b}
				[n]高级装备守护卡合成
				[n]商店购买
				[n]优胜券兑换
				[n]功勋牌兑换
			</description>
			<smeltD addType="equipChip" price="20"  maxNum="1"/>
		</things>
		<things cnName="终级武器守护卡">
			<name>ultiArmsEchelonCard</name>
			<cnName>终级武器守护卡</cnName>
			<iconUrl>ThingsIcon/ultiArmsEchelonCard</iconUrl><!-- 技能图标 -->
			<description>
				强化武器的保级道具，最高保级26级。
				[n][n]{b}{font color='#FFFF00'}获得方式：{/font}{/b}
				[n]高级武器守护卡合成
				[n]商店购买
				[n]优胜券兑换
				[n]功勋牌兑换
			</description>
			<smeltD addType="armsChip" price="20"  maxNum="1"/>
		</things>
		
		<things cnName="终级武器守护卡">
			<name>ultiArmsEchelonCard</name>
