	<father name="props" cnName="新道具">
		<things cnName="扫荡卡">
			<name>sweepingCard</name>
			<cnName>扫荡卡</cnName>
			<zuobiNum>30000</zuobiNum>
			<iconUrl>ThingsIcon/sweepingCard</iconUrl><!-- 技能图标 -->
			<description>使用后添加1次扫荡机会，今天如果没用完，第二天次数将消失。</description>
			<effectD type="addGift" dayUseLimit="7" />
			<gift>base;daySweeping;1</gift>
			<loveD num="0"/>
		</things>
		<things cnName="电磁铁">
			<name>electromagnet</name><addDropDefineB>1</addDropDefineB>
			<cnName>电磁铁</cnName>
			<iconUrl>ThingsIcon/electromagnet</iconUrl><!-- 技能图标 -->
