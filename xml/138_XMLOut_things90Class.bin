			<iconUrl>ThingsIcon/demBall</iconUrl><!-- 技能图标 -->
			<description>
				可在锻造合成中合成指定物品。
				[n][n]{b}{font color='#FFFF00'}获得方式：{/font}{/b}
				[n]修罗模式。
			</description>
			<loveD num="0"/>
		</things>
		<things cnName="升化剂">
			<name>intensDrug</name><addDropDefineB>1</addDropDefineB>
			<cnName>升化剂</cnName>
			<iconUrl>ThingsIcon/intensDrug</iconUrl><!-- 技能图标 -->
			<description>
				用于提升尸宠99级以后的强化等级。
				[n][n]{b}{font color='#FFFF00'}获得方式：{/font}{/b}
