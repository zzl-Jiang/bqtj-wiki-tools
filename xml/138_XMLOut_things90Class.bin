			<loveD num="1"/>
			<smeltD type="pet" />
		</things>
		<things cnName="雷斯图鉴">
			<name>PetLakeBook</name>
			<cnName>雷斯图鉴</cnName><addDropDefineB>1</addDropDefineB>
			<iconUrl>ThingsIcon/PetLakeBook</iconUrl><!-- 技能图标 -->
			<description>
				进化和培养雷克进化体所需的材料。
				[n][n]{b}{font color='#FFFF00'}获得方式：{/font}{/b}
				[n][n]秘境“黑暗雷尔”
			</description>
			<loveD num="1"/>
			<smeltD type="pet" />
		</things>
		<things cnName="技能熟练卡">
			<name>profiStamp</name>
			<cnName>技能熟练卡</cnName>
			<iconUrl>ThingsIcon/profiStamp</iconUrl><!-- 技能图标 -->
			<description>
				增加技能3000点熟练度所需的材料，在技能升级界面中操作。
				[n][n]{b}{font color='#FFFF00'}获得方式：{/font}{/b}
				[n]商店购买
			</description>
			<loveD num="0"/>
		</things>
		<things>
			<name>renameCard</name>
			<cnName>改名卡</cnName>
			<iconUrl>ThingsIcon/renameCard</iconUrl><!-- 技能图标 -->
