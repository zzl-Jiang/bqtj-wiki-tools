				[n]功勋牌兑换。
			</description>
			<loveD num="0"/>
		</things>
		
		<things cnName="爆骷S图鉴">
			<name>PetBoomSkullBook</name>
			<cnName>爆骷S图鉴</cnName><addDropDefineB>1</addDropDefineB>
