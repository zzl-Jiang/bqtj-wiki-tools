			<loveD num="1"/>
			<smeltD type="pet" />
		</things>
		<things cnName="冥王图鉴">
			<name>PetIronChiefBook</name>
			<cnName>冥王图鉴</cnName><addDropDefineB>1</addDropDefineB>
