			<loveD num="10"/>
		</things>
		<things cnName="冷冻宝石">
			<name>frozenGem</name><addDropDefineB>1</addDropDefineB>
			<cnName>冷冻宝石</cnName>
			<iconUrl>ThingsIcon/frozenGem</iconUrl><!-- 技能图标 -->
