			</description>
		</things>
		<things cnName="魂卡券">
			<name>bossCardStamp</name>
			<cnName>魂卡券</cnName><addDropDefineB>1</addDropDefineB>
			<iconUrl>ThingsIcon/bossCardNum</iconUrl><!-- 技能图标 -->
			<loveD num="0"/>
			<description>
				购买魂卡券后，可直接增加1次抽魂卡次数，无需使用。
				[n][n]{b}{font color='#FFFF00'}获得方式：{/font}{/b}
				[n]商店购买
			</description>
		</things>
		<things cnName="老弹兑换券">
			<name>oldBulletStamp</name>
			<cnName>老弹兑换券</cnName>
			<iconUrl>ThingsIcon/oldBulletStamp</iconUrl><!-- 技能图标 -->
			<description>
				可在“锻造>物品合成”中合成零件“老弹体”。老弹体是领取究极武器“射手座”的必需品。
				[n][n]{b}{font color='#FFFF00'}获得方式：{/font}{/b}
				[n]纪念币商店
			</description> 
			<loveD num="1"/>
		</things>
		
		
		<things cnName="万能载具碎片">
			<name>vehicleCash</name>
			<cnName>万能载具碎片</cnName>
			<iconUrl>ThingsIcon/vehicleCash</iconUrl><!-- 技能图标 -->
			<description>
				可在“锻造>合成”界面中合成指定载具碎片。
				[n][n]{b}{font color='#FFFF00'}获得方式：{/font}{/b}
				[n]四周年庆感恩礼包。
			</description>
			<loveD num="20"/>
			<smeltD type="vehicle" grade="2" addType="box" price="20"  maxNum="1"/>
		</things>
		<things cnName="万能生肖碎片">
			<name>zodiacCash</name>
			<cnName>万能生肖碎片</cnName><addDropDefineB>1</addDropDefineB>
			<iconUrl>ThingsIcon/zodiacCash</iconUrl><!-- 技能图标 -->
			<description>
				可在“锻造>合成”界面中合成指定生肖武器碎片。
				[n][n]{b}{font color='#FFFF00'}获得方式：{/font}{/b}
