			</description>
		</things>
		<things cnName="高级装扮券">
			<name>dressStampHigh</name><addDropDefineB>1</addDropDefineB>
			<cnName>高级装扮券</cnName>
			<iconUrl>ThingsIcon/dressStampHigh</iconUrl><!-- 技能图标 -->
			<description>
