		<things cnName="生化宝石">
			<name>poisonGem</name><addDropDefineB>1</addDropDefineB>
			<cnName>生化宝石</cnName>
			<iconUrl>ThingsIcon/poisonGem</iconUrl><!-- 技能图标 -->
