			</description>
		</things>
		<things cnName="黄金装扮券">
			<name>dressStampGold</name>
			<cnName>黄金装扮券</cnName>
			<iconUrl>ThingsIcon/dressStampGold</iconUrl><!-- 技能图标 -->
