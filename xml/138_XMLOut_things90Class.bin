	<father name="materials" cnName="宝石、无双水晶" smeltType="armsEquip">
		<things>
			<name>deathSilver</name>
			<cnName>秘银块</cnName>
			<iconUrl>NewIcon/silver</iconUrl><!-- 技能图标 -->
			<loveD num="0"/>
			<description>
				可在“锻造>物品合成”中合成“跟踪器”。未来可用于合成源自肉鸽模式的特殊武器、装备等。
				[n][n]{b}{font color='#FFFF00'}获得方式：{/font}{/b}
				[n]成就>肉鸽模式
			</description>
		</things>
		<things cnName="氩晶">
			<name>yaGem</name>
			<cnName>氩晶</cnName><addDropDefineB>1</addDropDefineB>
			<iconUrl>NewIcon/yaGem</iconUrl><!-- 技能图标 -->
			<description>
				部分战神装备和氩星武器进化所需的材料。
				[n][n]{b}{font color='#FFFF00'}获得方式：{/font}{/b}
