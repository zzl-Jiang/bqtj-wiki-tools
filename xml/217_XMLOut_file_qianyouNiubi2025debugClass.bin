						<unit cnName="小樱" dpsMul="3000" lifeMul="0.5" dieGotoState="stru"
							skillArr="vacuumJie_8,uavYing_2,moreUav_2,trueshotYing_2,hurtAddYing_2,coquettish_hero_4,invisibility_hero_4,screaming_hero_4,gliding_hero_4,rolling_hero_5,heroSprint,jumpNumAdd1"
							armsRange="pistol_two,shotgun_two,sniperRifle,ak47" />
						<!-- 藏师将军 -->
