		<gather name="初登绿岛">
			<level name="GreenIs_FirstVisit" cnName="初登绿岛" descrip="爆枪小队已顺利登陆，尽快击溃沿岸巡逻的血蟒部队，我们要尽快争取时间向绿岛内部深入与文杰和小白会合。">
				<![CDATA[2025.10.29添加]]>
				<info enemyLv="99" noMoreB="1" noVehicleB="1" noTreasureB="1" noPropsB="1" mustSingleB="1" noDeviceB="1" />
				<sceneLabel>GreenIs1</sceneLabel>
				<unitG>
					<allDefault aiOrder="patrolGlobal" noSuperB="1" />

					<!-- ★ 我方：爆枪小队四人 + 三尸宠 ★ -->
					<unitOrder id="we1" camp="we">
						<!-- 小樱（主控） -->
						<unit cnName="小樱" dpsMul="2000" lifeMul="0.5" dieGotoState="stru"
							skillArr="vacuumJie_10,uavYing_4,moreUav_4,trueshotYing_4,hurtAddYing_4,coquettish_hero_4,invisibility_hero_10,screaming_hero_5,gliding_hero_5,rolling_hero_5,heroSprint,jumpNumAdd1"
							armsRange="pistol_two,shotgun_two,sniperRifle,ak47" />
						<!-- 藏师将军 -->
						<unit cnName="藏师将军" dpsMul="100" lifeMul="0.6" dieGotoState="stru"
							skillArr="jumpNumAdd1" armsRange="rocket1,sniperRifle,pistol_two,ak47,shotgun_two" aiOrder="followBodyAttack:小樱" />
						<!-- 天鹰小美 -->
						<unit cnName="天鹰小美" dpsMul="150" lifeMul="0.6" dieGotoState="stru"
							armsRange="XiaoMei_pistol,XiaoMei_rocket,christmasGun$2"
							skillArr="groupLight_hero_7,hiding_hero_3,wisdomAnger_hero_1,screaming_hero_7,invisibility_enemy,skillCopy_enemy,sweep_enemy,moreMissile_enemy,disabledHalo_enemy,paralysis_enemy,changeToZombie_enemy,jumpNumAdd1,State_AddMove50" aiOrder="followBodyAttack:藏师将军" />
						<!-- 心零 -->
						<unit cnName="心零" dpsMul="100" lifeMul="0.8" dieGotoState="stru"
							skillArr="coquettish_hero_14,tauntLing_10,strongLing_10,revengeLing_10,resonanceLing_10,nightLing_10,clawLing_10,jumpNumAdd1,State_AddMove50,WatchEagleWing"
							armsRange="shotgun1" aiOrder="followBodyAttack:天鹰小美" />
					</unitOrder>
					<unitOrder id="we2" camp="we">
						<unit cnName="处决者"  lifeMul="9999999" skillArr="State_noAiFind,State_InvincibleThrough,noAttackOrder,noMoveSpeed" />
					</unitOrder>

					<!-- ★ 尸宠：跟随各自主人 ★ -->
					<unitOrder id="pet2" camp="we">
						<unit cnName="冥王" lifeMul="1.8" dpsMul="40"
							aiOrder="followBodyAttack:心零" />
					</unitOrder>
					<unitOrder id="pet3" camp="we">
						<unit cnName="爆骷S" lifeMul="1.6" dpsMul="35"
							aiOrder="followBodyAttack:天鹰小美" />
					</unitOrder>

					<!-- ★ 敌方：血蟒沿岸巡逻小分队（规模缩小，体现迷雾下我方实力受限） ★ -->
					<unitOrder id="enemy1">
						<unit cnName="巡逻狗" num="3"/>
						<unit cnName="飞天狗" num="1"/>
						<unit cnName="血蟒雇佣兵" num="1"/>
						<unit cnName="血蟒突击兵" num="2"/>
						<unit cnName="血蟒狙击兵" num="2"/>
					</unitOrder>
					<unitOrder id="enemy2">
						<unit cnName="巡逻狗" num="3"/>
						<unit cnName="飞天狗" num="1"/>
						<unit cnName="血蟒雇佣兵" num="2"/>
						<unit cnName="血蟒突击兵" num="2"/>
						<unit cnName="血蟒狙击兵" num="1"/>
					</unitOrder>
					<unitOrder id="enemy3">
						<unit cnName="巡逻狗" num="3"/>
						<unit cnName="飞天狗" num="1"/>
						<unit cnName="血蟒雇佣兵" num="2"/>
						<unit cnName="血蟒突击兵" num="1"/>
						<unit cnName="血蟒狙击兵" num="2"/>
					</unitOrder>
					<unitOrder id="boss1">
						<unit cnName="血蟒狙击兵" unitType="boss" lifeMul="30" onlyLevelSkillB="1" skillArr="sumLandDog,slowMove_enemy"/>
						<unit cnName="血蟒突击兵" unitType="boss" dpsMul="2"  lifeMul="30" onlyLevelSkillB="1" skillArr="imploding_enemy,moreMissile_enemy" />
						<unit cnName="巡逻狗" num="3"/>
						<unit cnName="飞天狗" num="3"/>
						<unit cnName="血蟒雇佣兵" num="1"/>
						<unit cnName="血蟒突击兵" num="1"/>
						<unit cnName="血蟒狙击兵" num="1"/>
					</unitOrder>
				</unitG>
				<rectG>
					<!-- 敌人出生点 -->
					<rect id="rEnemySpace1">2600,650,100,100</rect>
					<rect id="rEnemySpace2">1700,650,100,100</rect>
					<!-- 其他特殊点 -->
					<rect id="fly1">152,600,60,60</rect>
					<rect id="r_wounded">400,500,50,50</rect>
					<rect id="r_prison">500,400,80,80</rect>
					<rect id="r_prison_guard">520,420,50,50</rect>
					<rect id="r_retreat">600,600,50,50</rect>
					<rect id="r_friend">200,200,50,50</rect>
					<rect id="r_boss">250,200,50,50</rect>
				</rectG>
				<eventG>
					<group>
						<!-- 初始设置：禁用装备、创建我方四人 -->
						<event>
							<condition />
							<order>weAllHeroNoShoot</order>
							<order>weAllHeroNoEquip</order>
							<!-- 主角限制 -->
							<order>createUnit:we2; fly1</order>
							<order>body:处决者; flipToRight</order>
							<order>createUnit:we1; r_birth</order>
							<order>parasiticWeRolePan</order>
							<order>heroEverParasitic:小樱</order>
							<order>openInput</order>
						</event>

						<!-- 延迟0.5秒创建尸宠，营造“跟随主人”的出场感 -->
						<event>
							<condition delay="0.5" />
							<order>createUnit:pet2; r2</order>
							<order>createUnit:pet3; r3</order>
						</event>

						<!-- 登陆剧情：感受迷雾压制，只能使用基础武器 -->
						<event>
							<condition delay="1" />
							<order>playMusic; music_face:piano</order>
							<order>say; startList:s1</order>
						</event>

						<!-- 对话结束，血蟒巡逻队出现 -->
						<event>
							<condition delay="0.5">say:listOver</condition>
							<order>createUnit:enemy1; hideRan</order>
						</event>
						<event>
							<condition  doNumber="3">liveEnemyNumber:less_1</condition>
							<order>createUnit:enemy2; hideRan</order>
						</event>
						<event>
							<condition  doNumber="3">liveEnemyNumber:less_1</condition>
							<order>createUnit:enemy3; hideRan</order>
						</event>

						<event>
							<condition  doNumber="1">liveEnemyNumber:less_1</condition>
							<order>createUnit:boss1; hideRan</order>
						</event>

						<!-- 敌人全灭后，决定转移 -->
						<event>
							<condition delay="0.5">enemyNumber:less_1</condition>
							<order>playMusic; music_face:piano</order>
							<order>say; startList:s2</order>
						</event>
						<event>
							<condition>say:listOver</condition>
							<order>alert:yes; 绿岛地区迷雾信号屏蔽实况报告单（内含绿岛地图）。</order>
						</event>
						<event>
							<condition delay="1"></condition>
							<order>say; startList:s3</order>
						</event>
						<event>
							<condition>say:listOver</condition>
							<order>task:now; complete</order>
							<order>level; showPointer:r_over</order>
						</event>
					</group>
				</eventG>
			</level>
		</gather>
		<gather name="密林潜行">
			<level name="GreenIs_UnderSneaking" cnName="密林潜行" descrip="众人赶在更多血蟒巡逻部队发现之前顺着地图来到了苍木道，即将发生的事情出乎众人意料。">
				<![CDATA[2025.11.1添加]]>
				<info enemyLv="99" noMoreB="1" noVehicleB="1" noTreasureB="1" noPropsB="1" mustSingleB="1" noDeviceB="1" />
				<sceneLabel>GreenIs2</sceneLabel>

				<unitG>
					<allDefault aiOrder="patrolGlobal" noSuperB="1" />

					<!-- ★ 我方：爆枪小队四人 ★ -->
					<unitOrder id="we1" camp="we">
						<!-- 小樱（主控） -->
						<unit cnName="小樱" dpsMul="4550" lifeMul="0.5" dieGotoState="stru"
							skillArr="vacuumJie_8,uavYing_4,moreUav_4,trueshotYing_4,hurtAddYing_4,coquettish_hero_4,invisibility_hero_10,screaming_hero_10,gliding_hero_10,rolling_hero_10,heroSprint,jumpNumAdd1"
							armsRange="pistol_two,shotgun_two,sniperRifle,ak47" />
						<!-- 藏师将军 -->
						<unit cnName="藏师将军" dpsMul="100" lifeMul="0.8" dieGotoState="stru"
							skillArr="jumpNumAdd1" armsRange="rocket1,sniperRifle,pistol_two,ak47,shotgun_two" aiOrder="followBodyAttack:小樱" />
						<!-- 天鹰小美 -->
						<unit cnName="天鹰小美" dpsMul="150" lifeMul="0.6" dieGotoState="stru"
							armsRange="XiaoMei_pistol,XiaoMei_rocket,christmasGun$2"
							skillArr="groupLight_hero_7,hiding_hero_3,wisdomAnger_hero_1,screaming_hero_7,invisibility_enemy,skillCopy_enemy,sweep_enemy,moreMissile_enemy,disabledHalo_enemy,paralysis_enemy,changeToZombie_enemy,jumpNumAdd1,State_AddMove50" aiOrder="followBodyAttack:藏师将军" />
						<!-- 心零 -->
						<unit cnName="心零" dpsMul="100" lifeMul="0.8" dieGotoState="stru"
							skillArr="coquettish_hero_14,tauntLing_10,strongLing_10,revengeLing_10,resonanceLing_10,nightLing_10,clawLing_10,jumpNumAdd1,State_AddMove50,WatchEagleWing"
							armsRange="shotgun1" aiOrder="followBodyAttack:天鹰小美" />
					</unitOrder>

					<!-- ★ 尸宠：跟随各自主人 ★ -->
					<unitOrder id="pet2" camp="we">
						<unit cnName="冥王" lifeMul="1.8" dpsMul="40"
							aiOrder="followBodyAttack:心零" />
					</unitOrder>
					<unitOrder id="pet3" camp="we">
						<unit cnName="爆骷S" lifeMul="1.6" dpsMul="35"
							aiOrder="followBodyAttack:天鹰小美" />
					</unitOrder>

					<!-- ★ 友方：受伤垂死的血蟒士兵（仅触发剧情）★ -->
					<unitOrder id="woundedEnemy" camp="we">
						<unit cnName="血蟒突击兵" lifeMul="1" dpsMul="5000" skillArr="State_InvincibleThrough,State_noAiFind" dieGotoState="stru" />
					</unitOrder>

					<!-- ★ 敌方：少量游荡者（可选，若希望有零星战斗可保留，若纯剧情可注释）★ 
			<unitOrder id="enemy_patrol">
				<numberType>num</numberType>
				<unit cnName="血蟒雇佣兵" num="1" lifeMul="1.5" skillArr="toFlyState" />
				<unit cnName="血蟒突击兵" num="1" lifeMul="1.5" armsRange="rifleDragon" />
			</unitOrder>
			-->
				</unitG>
				<rectG>
					<!-- 敌人出生点 -->
					<rect id="rEnemySpace1">2600,650,100,100</rect>
					<rect id="rEnemySpace2">1700,650,100,100</rect>
					<!-- 其他特殊点 -->
					<rect id="fly1">152,600,60,60</rect>
					<rect id="r_wounded">2500,1150,50,50</rect>
					<rect id="r_prison">500,400,80,80</rect>
					<rect id="r_prison_guard">520,420,50,50</rect>
					<rect id="r_retreat">600,600,50,50</rect>
					<rect id="r_friend">200,200,50,50</rect>
					<rect id="r_boss">250,200,50,50</rect>
				</rectG>
				<eventG>
					<group>
						<!-- 初始设置：创建我方四人 + 尸宠 -->
						<event>
							<condition />
							<order>weAllHeroNoShoot</order>
							<order>weAllHeroNoEquip</order>
							<order>createUnit:we1; r_birth</order>
							<order>heroEverParasitic:小樱</order>
							<order>createUnit:pet2; r2</order>
							<order>createUnit:pet3; r3</order>
							<order>createUnit:woundedEnemy; r_wounded</order>
							<order>body:血蟒突击兵; toDie</order>
							<order>openInput</order>
						</event>

						<!-- 进入苍木道密林，背景音乐切换为悬疑氛围 -->
						<event>
							<condition delay="1"></condition>
							<order>playMusic; music_face:suspense</order>
							<order>say; startList:s1</order>
						</event>

						<!-- 发现受伤士兵 -->
						<event>
							<condition>say:listOver</condition>
						</event>
						<event>
							<condition>bodyGap:less_350; 小樱:血蟒突击兵</condition>
							<order>say; startList:s2</order>
						</event>

						<!-- 士兵临终遗言 -->
						<event>
							<condition>say:listOver</condition>
							<order>say; startList:s3</order>
						</event>

						<!-- 士兵气绝，众人哀叹 -->
						<event>
							<condition delay="1">say:listOver</condition>
							<order>body:血蟒突击兵; rebirth</order>
							<order>body:血蟒突击兵;toDie:die</order>
							<order>playMusic; music_face:piano</order>
							<order>say; startList:s4</order>
						</event>

						<!-- 分析路线，想起制毒师告诫（天气铺垫） -->
						<event>
							<condition>say:listOver</condition>
							<order>say; startList:s5</order>
						</event>

						<!-- 突然！远处爆炸，地面震荡 -->
						<event>
							<condition>say:listOver</condition>
							<order>level; shake:beatMadboss</order>
							<order>playMusic; music_face:descent</order>
							<order>say; startList:s6</order>
						</event>

						<!-- 大批血蟒部队正在围拢（任务完成，紧张转移） -->
						<event>
							<condition>say:listOver</condition>
							<order>say; startList:s7</order>
						</event>
						<event>
							<condition delay="1">say:listOver</condition>
							<order>task:now; complete</order>
							<order>level; win</order>
						</event>
					</group>

					<!-- 失败条件：小樱、心零任意一人阵亡（尸宠可牺牲） -->
					<group>
						<event id="e_fail">
							<condition delay="1">bodyEvent:die; 小樱</condition>
							<order>alert:yes; 小樱阵亡，任务失败！</order>
						</event>
						<event>
							<condition delay="0.03" />
							<order>level; fail</order>
						</event>
						<event id="e_fail2">
							<condition delay="1">bodyEvent:die; 心零</condition>
							<order>alert:yes; 心零阵亡，任务失败！</order>
						</event>
						<event>
							<condition delay="0.03" />
							<order>level; fail</order>
						</event>
					</group>
				</eventG>
			</level>
		</gather>
