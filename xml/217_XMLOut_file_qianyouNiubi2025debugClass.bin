							skillArr="imploding_enemy" aiOrder="followBodyAttack:小樱" />
						<unit cnName="血蟒突击兵" num="1" lifeMul="0.6" dpsMul="0.4" dieGotoState="stru" aiOrder="patrolRandom" />
						<unit cnName="血蟒狙击兵" num="1" lifeMul="0.6" dpsMul="0.4" dieGotoState="stru" aiOrder="patrolRandom" />
					</unitOrder>

					<!-- 敌方：感染病毒的血蟒僵尸部队（多波次） -->
					<unitOrder id="zombie_wave1">
						<numberType>num</numberType>
						<unit cnName="血蟒感染者" num="4" lifeMul="150" armsRange="rifleDragon" skillArr="through_enemy" />
						<unit cnName="血蟒感染者" num="3" lifeMul="150" armsRange="lightCone" skillArr="through_enemy" />
