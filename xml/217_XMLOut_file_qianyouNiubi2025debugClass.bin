				<eventG>
					<group>
						<!-- ========== 初始设置 ========== -->
						<event>
							<condition />
							<order>weAllHeroNoShoot</order>
							<order>weAllHeroNoEquip</order>
							<order>createUnit:we1; r_birth</order>
							<order>parasiticWeRolePan</order>
							<order>heroEverParasitic:小樱</order>
							<order>createUnit:pet2; r2</order>
							<order>createUnit:pet3; r3</order>
							<order>openInput</order>
						</event>

						<!-- ========== 开场：被包围的紧迫感 ========== -->
						<event>
							<condition delay="0.5" />
							<order>playMusic; music_face:descent</order>
							<order>say; startList:s1</order>
						</event>

						<!-- ========== 波次战斗：共10波，每波全灭后给地雷并触发下一波 ========== -->
						<!-- 波次1 -->
						<event>
							<condition>say:listOver</condition>
							<order>createUnit:wave1; rEnemySpace2</order>
							<order>say; startList:s2_1</order>
						</event>
						<event>
							<condition doNumber="1">enemyNumber:less_1</condition>
							<order>body:sumByP1; addTempDevice:hurtMine_6,2</order>
							<!-- 缴获2颗地雷 -->
							<order>createUnit:wave2; rEnemySpace2</order>
							<order>say; startList:s2_2</order>
						</event>
						<event>
							<condition doNumber="1">enemyNumber:less_1</condition>
							<order>body:sumByP1; addTempDevice:hurtMine_6,2</order>
							<order>createUnit:wave3; rEnemySpace2</order>
							<order>say; startList:s2_3</order>
						</event>
						<!-- 波次4-6 -->
						<event>
							<condition doNumber="1">enemyNumber:less_1</condition>
							<order>body:sumByP1; addTempDevice:hurtMine_6,3</order>
							<order>createUnit:wave4; rEnemySpace2</order>
							<order>say; startList:s2_4</order>
						</event>
						<event>
							<condition doNumber="1">enemyNumber:less_1</condition>
							<order>body:sumByP1; addTempDevice:hurtMine_6,3</order>
							<order>createUnit:wave5; rEnemySpace2</order>
							<order>say; startList:s2_5</order>
						</event>
						<event>
							<condition doNumber="1">enemyNumber:less_1</condition>
							<order>body:sumByP1; addTempDevice:hurtMine_6,3</order>
							<order>createUnit:wave6; rEnemySpace2</order>
							<order>say; startList:s2_6</order>
						</event>
						<!-- 波次7-9 -->
						<event>
							<condition doNumber="1">enemyNumber:less_1</condition>
							<order>body:sumByP1; addTempDevice:hurtMine_6,4</order>
							<order>createUnit:wave7; rEnemySpace2</order>
							<order>say; startList:s2_7</order>
						</event>
						<event>
							<condition doNumber="1">enemyNumber:less_1</condition>
							<order>body:sumByP1; addTempDevice:hurtMine_6,4</order>
							<order>createUnit:wave8; rEnemySpace2</order>
							<order>say; startList:s2_8</order>
						</event>
						<event>
							<condition doNumber="1">enemyNumber:less_1</condition>
							<order>body:sumByP1; addTempDevice:hurtMine_6,4</order>
							<order>createUnit:wave9; rEnemySpace2</order>
							<order>say; startList:s2_9</order>
						</event>
						<!-- 波次10：最终波 -->
						<event>
							<condition doNumber="1">enemyNumber:less_1</condition>
							<order>body:sumByP1; addTempDevice:hurtMine_6,5</order>
							<order>createUnit:wave10; rEnemySpace2</order>
							<order>playMusic; music_face:Madboss</order>
							<order>say; startList:s2_10</order>
						</event>

						<!-- ========== 全部敌人消灭，战斗胜利 ========== -->
						<event>
							<condition delay="0.5">enemyNumber:less_1</condition>
							<order>playMusic; music_face:piano</order>
							<order>say; startList:s3</order>
						</event>

						<!-- ========== 分兵决策 ========== -->
						<event>
							<condition>say:listOver</condition>
							<order>say; startList:s4</order>
						</event>

						<!-- 小樱移交地图给藏师将军 -->
						<event>
							<condition>say:listOver</condition>
							<order>body:小樱; transferItem:绿岛地图; 藏师将军</order>
							<!-- 假设存在该指令，若无则用剧情表现 -->
							<order>say; startList:s5</order>
						</event>

						<!-- ========== 任务完成，为第四关铺垫 ========== -->
						<event>
							<condition>say:listOver</condition>
							<order>task:now; complete</order>
							<order>level; showPointer:r_over</order>
						</event>
					</group>

					<!-- ========== 失败条件：小樱或心零阵亡 ========== -->
					<group>
						<event id="e_fail1">
							<condition delay="1">bodyEvent:die; 小樱</condition>
