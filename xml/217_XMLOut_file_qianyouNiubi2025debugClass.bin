						</event>
					</group>
				</eventG>
			</level>
		</gather>
		<gather name="殊途同归">
			<level name="GreenIs_DoubleinPairs" cnName="殊途同归" descrip="情况越来越严峻，大批血蟒支援部队向苍木道方向赶来，坚持五分钟击溃血蟒部队，为藏师一队提前突围断后，倒计时结束未击溃全部血蟒部队视为任务失败。">
				<![CDATA[2025.11.9添加]]>
				<info enemyLv="99" noMoreB="1" noVehicleB="1" noTreasureB="1" noPropsB="1" mustSingleB="1" noDeviceB="1" />
				<sceneLabel>GreenIs2</sceneLabel>

				<unitG>
					<allDefault aiOrder="patrolGlobal" noSuperB="1" />

					<!-- ★ 我方：爆枪小队四人 ★ -->
					<unitOrder id="we1" camp="we">
