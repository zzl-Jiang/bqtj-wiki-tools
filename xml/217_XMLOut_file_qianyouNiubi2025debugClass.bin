					<allDefault aiOrder="patrolGlobal" noSuperB="1" />

					<!-- 我方：小樱、天鹰小美、心零 -->
					<unitOrder id="we1" camp="we">
						<unit cnName="小樱" dpsMul="500" lifeMul="0.3" dieGotoState="stru"
							skillArr="uavYing_7,moreUav_7,trueshotYing_14,hurtAddYing_14,coquettish_hero_14,invisibility_hero_10,screaming_hero_10,gliding_hero_10,rolling_hero_10,heroSprint,jumpNumAdd1"
							armsRange="consVirgo" aiOrder="followBodyAttack:心零" />
						<unit cnName="天鹰小美" dpsMul="500" lifeMul="0.3" dieGotoState="stru"
							armsRange="lightCone,yearChicken,beadCrossbow,christmasGun$2"
							skillArr="groupLight_hero_7,hiding_hero_3,wisdomAnger_hero_1,screaming_hero_7,invisibility_enemy,skillCopy_enemy,sweep_enemy,moreMissile_enemy,disabledHalo_enemy,paralysis_enemy,changeToZombie_enemy,jumpNumAdd1,State_AddMove50"
							aiOrder="followBodyAttack:小樱" />
						<unit cnName="心零" dpsMul="500" lifeMul="0.1" dieGotoState="stru"
							skillArr="groupLight_hero_7,crazy_hero_13,coquettish_hero_14,tauntLing_10,strongLing_10,revengeLing_10,resonanceLing_10,nightLing_10,clawLing_10,jumpNumAdd1,State_AddMove50,WatchEagleWing"
							armsRange="consLeo,lightCone,rifleHornetYa,shotgunSkunkYa" />
