<?xml version="1.0" encoding="utf-8"?>

<data id="qianyouNiubi2026" cnName="支线续章：绿岛篇" author="倩友小萌新">
	<!-- id是唯一识别码，必须防止和其他关卡集合重复，不设置的话默认为文件名。 -->
	<info>
		绿岛支线时间线与绿岛主线并行，爆枪小队全员将在绿岛面对未知的挑战而前进。
		该系列支线剧情已实现与主线剧情的全接轨，第二章期待您的沉浸式剧情游玩体验！爆枪小队集结南下，迷雾雷区尸变鏖战，会师仙草奔赴苍木道！
		后续还有更多精彩章节敬请期待！        B站 倩友小萌新(下滑页面查看推荐提示)
		推荐：关闭P1的AI功能，默认小白档游玩，其余角色P1档可能会出现bug
	</info>

	<father name="normal" cn="关卡">
		<gather name="千里驰援">
			<level name="GreenIs_RapidRescue" cnName="千里驰援" descrip="有一台载具闯入战斧高地防空警戒区，这位不速之客究竟是谁？">
				<![CDATA[2025.9.13添加]]>
				<info enemyLv="99" noMoreB="1" noVehicleB="1" noTreasureB="1" noPropsB="1" mustSingleB="1" noDeviceB="1" />
				<sceneLabel>MainUpland</sceneLabel>
				<unitG>
					<allDefault aiOrder="patrolGlobal" noSuperB="1"></allDefault>
					<!-- 人类 -->
					<unitOrder id="we1" camp="we">
						<unit cnName="制毒师" dpsMul="150" lifeMul="1" dieGotoState="stru" armsRange="consVirgo" skillArr="crazy_enemy,through_hero_5,groupLight_hero_7,jumpNumAdd1"/>
					</unitOrder>
					<unitOrder id="we2"  camp="we">
						<unit cnName="处决者"/>
					</unitOrder>
					<unitOrder id="we3"  camp="we">
						<unit cnName="小樱" dpsMul="100" lifeMul="0.3" skillArr="uavYing_14,moreUav_14,trueshotYing_14,hurtAddYing_14,coquettish_hero_14,invisibility_hero_10,screaming_hero_10,gliding_hero_10,rolling_hero_10,heroSprint,jumpNumAdd1" armsRange="consVirgo"/>
						<unit cnName="藏师将军" dpsMul="100" lifeMul="0.3" skillArr="jumpNumAdd1" armsRange="sniperCicadaYa" aiOrder="followBodyAttack:小樱"/>
						<unit cnName="天鹰小美" dpsMul="150" lifeMul="0.5" armsRange="lightCone,yearChicken,beadCrossbow,christmasGun$2" skillArr="groupLight_hero_7,hiding_hero_3,wisdomAnger_hero_1,screaming_hero_7,invisibility_enemy,skillCopy_enemy,sweep_enemy,moreMissile_enemy,disabledHalo_enemy,paralysis_enemy,changeToZombie_enemy,jumpNumAdd1,State_AddMove50"  aiOrder="followBodyAttack:藏师将军"/>
					</unitOrder>
					<unitOrder id="we4"  camp="we">
						<unit cnName="摩卡" dpsMul="30000" lifeMul="1" armsRange="lightCone" dieGotoState="stru" skillArr="crazy_enemy,groupLight_hero_7,hiding_hero_3,jumpNumAdd1,State_AddMove50,toFlyState" aiOrder="followBodyAttack:藏师将军"/>
						<unit cnName="玉晴"  aiOrder="followBodyAttack:制毒师"/>
					</unitOrder>
					<unitOrder id="we5"  camp="we">
						<unit cnName="心零" dpsMul="100" lifeMul="0.3" skillArr="jumpNumAdd1,WatchEagleWing" armsRange="consLeo" aiOrder="followBodyAttack:小樱"/>
					</unitOrder>
					<unitOrder id="we6"  camp="we">
						<unit cnName="雇佣兵" dpsMul="200" lifeMul="1" dieGotoState="stru" armsRange="lightCone,yearDragon,consLibra,shotgunBlade" skillArr="crazy_enemy,groupLight_hero_7,hiding_hero_3,feedback_hero_5,pioneer_hero_5,moreMissile_hero_10,silence_hero_5,through_hero_5,moreMissile_enemy,pointBoom_enemy,changeToSecDiggers,jumpNumAdd1,State_AddMove,toFlyState"  aiOrder="followBodyAttack:摩卡"/>
					</unitOrder>
					<unitOrder id="we7"  camp="we">
						<unit cnName="丛林特种兵" num="1" dpsMul="1000" lifeMul="1" dieGotoState="stru"  aiOrder="followBodyAttack:小樱"/>
						<unit cnName="沙漠特种兵" num="1" dpsMul="1000" lifeMul="1" dieGotoState="stru"  aiOrder="followBodyAttack:小樱"/>
						<unit cnName="处决者"  lifeMul="0.3" dpsMul="1100" skillArr="crazy_vehicle_8,groupLightMadFly"  aiOrder="followBody:小樱"/>
						<unit cnName="鲲" lifeMul="2" aiOrder="followBody:处决者"/>
						<unit cnName="潜影者" lifeMul="2" aiOrder="followBody:处决者"/>
						<unit cnName="大鹏" lifeMul="2" skillArr="slowMove_enemy,groupSpeedUp_enemy"  aiOrder="followBody:处决者"/>
					</unitOrder>
				</unitG>
				<eventG>
					<group>
						<event>
							<condition></condition>
							<order>weAllHeroNoShoot</order>
							<order>weAllHeroNoEquip</order>
							<order>createUnit:we1; r1</order>
							<order>heroNoExistXY:1100,600</order>
						</event>
						<event>
							<condition delay="0.5"></condition>
							<order>playMusic; music_face:descent</order>
							<order>say; startList:s1</order>
							<order>body:制毒师;followPoint:1100,600</order>
							<order>body:制毒师; setShootXY:100,512</order>
						</event>
						<event>
							<condition delay="1">say:listOver</condition>
							<order>createUnit:we2; r2</order>
							<order>body:处决者; flipToLeft</order>
							<order>body:处决者;followPoint:1400,600</order>
							<order>playMusic; music_face:suspense</order>
							<order>say; startList:s2</order>
						</event>
						<event>
							<condition delay="1">say:listOver</condition>
							<order>body:处决者; rangeLimit:close</order>
							<order>body:处决者; followPoint:-1000,-2000</order>
						</event>
						<![CDATA[飞机飞走]]>
						<event>
							<condition delay="5"></condition>
							<order>createUnit:we3; r1</order>
							<order>heroEverParasitic:小樱</order>
							<order>body:处决者; toDel</order>
							<order>say; startList:s3</order>
						</event>
						<event>
							<condition delay="2">say:listOver</condition>
							<order>createUnit:we4; r1</order>
							<order>playMusic; music_face:love</order>
							<order>say; startList:s4</order>
						</event>
						<event>
							<condition delay="2">say:listOver</condition>
							<order>createUnit:we5; r1</order>
							<order>playMusic; music_face:piano</order>
							<order>say; startList:s5</order>
						</event>
						<event>
							<condition delay="2">say:listOver</condition>
							<order>playMusic; music_face:piano</order>
							<order>createUnit:we6; r1</order>
							<order>say; startList:s6</order>
						</event>
						<event>
							<condition delay="1">say:listOver</condition>
							<order>alert:yes; 获得物品：绿岛地区迷雾信号屏蔽实况报告单（内含绿岛地图）。</order>
							<order>say; startList:s7</order>
						</event>
						<event>
							<condition delay="2">say:listOver</condition>
							<order>createUnit:we7; r2</order>
							<order>say; startList:s8</order>
						</event>
						<event>
							<condition delay="2">say:listOver</condition>
							<order>task:now; complete</order>
							<order>level; showPointer:r_over</order>
						</event>
					</group>
				</eventG>
			</level>
		</gather>
		<gather name="空中封锁">
