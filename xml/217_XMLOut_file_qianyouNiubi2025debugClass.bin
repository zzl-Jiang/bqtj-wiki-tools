							skillArr="jumpNumAdd1" armsRange="rocket1,sniperRifle,pistol_two,ak47,shotgun_two"/>
						<!-- 天鹰小美 -->
						<unit cnName="天鹰小美" dpsMul="450" lifeMul="0.5" dieGotoState="stru"
							armsRange="XiaoMei_pistol,XiaoMei_rocket,christmasGun$2"
							skillArr="groupLight_hero_7,hiding_hero_3,wisdomAnger_hero_1,screaming_hero_2,invisibility_enemy,skillCopy_enemy,sweep_enemy,moreMissile_enemy,disabledHalo_enemy,paralysis_enemy,changeToZombie_enemy,jumpNumAdd1,State_AddMove50" aiOrder="followBodyAttack:小樱" />
						<!-- 心零 -->
						<unit cnName="心零" dpsMul="450" lifeMul="0.5" dieGotoState="stru"
							skillArr="coquettish_hero_14,tauntLing_10,strongLing_10,revengeLing_10,resonanceLing_10,nightLing_10,clawLing_10,jumpNumAdd1,State_AddMove50,WatchEagleWing"
							armsRange="shotgun1" aiOrder="followBodyAttack:天鹰小美" />
					</unitOrder>

					<!-- ★ 尸宠：跟随各自主人 ★ -->
					<unitOrder id="pet2" camp="we">
						<unit cnName="冥王" lifeMul="1.8" dpsMul="40"
							aiOrder="followBodyAttack:藏师将军" />
					</unitOrder>
					<unitOrder id="pet3" camp="we">
						<unit cnName="爆骷S" lifeMul="1.6" dpsMul="35"
							aiOrder="followBodyAttack:藏师将军" />
					</unitOrder>

					<unitOrder id="enemy1">
						<unit cnName="血蟒雇佣兵" num="4" dpsMul="1.5" lifeMul="2" />
						<unit cnName="血蟒突击兵" num="4" dpsMul="1.5" lifeMul="2"/>
					</unitOrder>
					<unitOrder id="enemy2">
						<unit cnName="血蟒雇佣兵" num="4" dpsMul="1.5" lifeMul="2"/>
						<unit cnName="血蟒突击兵" num="4" dpsMul="1.5" lifeMul="2"/>
						<unit cnName="血蟒狙击兵" num="2" dpsMul="1.5" lifeMul="2"/>
					</unitOrder>
					<unitOrder id="enemy3">
						<unit cnName="血蟒雇佣兵" num="4" dpsMul="1.5" lifeMul="2"/>
						<unit cnName="血蟒突击兵" num="4" dpsMul="1.5" lifeMul="2"/>
						<unit cnName="血蟒狙击兵" num="4" dpsMul="1.5" lifeMul="2"/>
					</unitOrder>
					<unitOrder id="boss1">
						<unit cnName="血蟒雇佣兵" dpsMul="3" lifeMul="0.5" unitType="boss" onlyLevelSkillB="1" skillArr="imploding_enemy"/>
						<unit cnName="大地掠袭者" dpsMul="1" lifeMul="12" unitType="boss" warningRange="4000" onlyLevelSkillB="1" skillArr="defence100,floorTankSkill_8,sumAirDog"/>
					</unitOrder>
				</unitG>

				<rectG>
					<!-- 敌人出生点 -->
					<rect id="rEnemySpace1">2600,650,100,100</rect>
					<rect id="rEnemySpace2">1700,650,100,100</rect>
					<!-- 其他特殊点 -->
					<rect id="fly1">152,600,60,60</rect>
					<rect id="r_wounded">2500,1150,50,50</rect>
					<rect id="r_prison">500,400,80,80</rect>
					<rect id="r_prison_guard">520,420,50,50</rect>
					<rect id="r_retreat">600,600,50,50</rect>
					<rect id="r_friend">200,200,50,50</rect>
					<rect id="r_boss">250,200,50,50</rect>
				</rectG>
				<eventG>
					<group>
						<!-- 初始设置：创建全员 -->
						<event>
							<condition />
							<order>weAllHeroNoShoot</order>
							<order>weAllHeroNoEquip</order>
							<order>level;taskTimingB:false</order>
							<order>createUnit:we1; r_birth</order>
							<order>heroEverParasitic:小樱</order>
							<order>createUnit:pet2; r2</order>
							<order>createUnit:pet3; r3</order>
							<order>body:sumByP1; addTempDevice:hurtMine_6,70</order>
							<order>alert:yes; 重要提示：当前开发者模式下该关卡无5分钟倒计时限制</order>
							<order>openInput</order>
						</event>

						<!-- 播放分兵嘱托对话 -->
						<event>
							<condition delay="1" />
							<order>playMusic; music_face:piano</order>
							<order>say; startList:s1</order>
						</event>

						<!-- 对话结束，藏师及尸宠离场（向右移动至3000码外后删除） -->


						<event>
							<condition delay="0.5">say:listOver</condition>
							<order>body:藏师将军; rangeLimit:close</order>
							<order>body:藏师将军; lockShootXY:4090,1200</order>
							<order>body:冥王; rangeLimit:close</order>
							<order>body:冥王; lockShootXY:4090,1200</order>
							<order>body:爆骷S; rangeLimit:close</order>
							<order>body:爆骷S; lockShootXY:4090,1200</order>
						</event>
						<event>
							<condition delay="0.5"></condition>
							<order>body:藏师将军;followPoint:4090,1200</order>
							<order>body:冥王;followPoint:4090,1200</order>
							<order>body:爆骷S;followPoint:4090,1200</order>
						</event>
						<event>
							<condition delay="13"></condition>
							<order>body:藏师将军; addEffectPosition:oreBombShowFlower</order>
							<order>body:藏师将军; toDel</order>
							<order>body:冥王; addEffectPosition:oreBombShowFlower</order>
							<order>body:冥王; toDel</order>
							<order>body:爆骷S; addEffectPosition:oreBombShowFlower</order>
							<order>body:爆骷S; toDel</order>
							<order>say; startList:s2</order>
							<!-- 简短提醒断后开始 -->
						</event>

						<!-- 断后开始：出现第一波敌人 -->
						<event>
							<condition>say:listOver</condition>
							<order>level;taskTimingB:true</order>
							<order>createUnit:enemy1; hideRan</order>
						</event>

						<!-- 连续波次：每波全灭后刷下一波 -->
						<event>
							<condition doNumber="4">liveEnemyNumber:less_1</condition>
							<order>body:sumByP1; addTempDevice:hurtMine_6,5</order>
							<order>createUnit:enemy2; hideRan</order>
						</event>
						<event>
							<condition doNumber="4">liveEnemyNumber:less_1</condition>
							<order>body:sumByP1; addTempDevice:hurtMine_6,5</order>
							<order>createUnit:enemy3; hideRan</order>
						</event>
						<event>
							<condition doNumber="1">liveEnemyNumber:less_1</condition>
							<order>body:sumByP1; addTempDevice:hurtMine_6,5</order>
							<order>createUnit:boss1; hideRan</order>
						</event>

						<!-- 所有敌人消灭，任务完成 -->
						<event>
							<condition delay="0.5">enemyNumber:less_1</condition>
							<order>level;taskTimingB:false</order>
							<order>playMusic; music_face:descent</order>
							<order>say; startList:s3</order>
						</event>
						<event>
							<condition>say:listOver</condition>
							<order>task:now; complete</order>
							<order>level; showPointer:r_over</order>
						</event>
					</group>

					<!-- 失败条件：小樱、心零、小美任意一人阵亡 -->
					<group>
						<event id="e_fail1">
							<condition delay="1">bodyEvent:die; 小樱</condition>
							<order>alert:yes; 小樱阵亡，任务失败！</order>
						</event>
						<event>
							<condition delay="0.03" />
							<order>level; fail</order>
						</event>
						<event id="e_fail2">
							<condition delay="1">bodyEvent:die; 心零</condition>
							<order>alert:yes; 心零阵亡，任务失败！</order>
						</event>
						<event>
							<condition delay="0.03" />
							<order>level; fail</order>
						</event>
						<event id="e_fail3">
							<condition delay="1">bodyEvent:die; 天鹰小美</condition>
							<order>alert:yes; 天鹰小美阵亡，任务失败！</order>
						</event>
						<event>
							<condition delay="0.03" />
							<order>level; fail</order>
						</event>
					</group>
				</eventG>
