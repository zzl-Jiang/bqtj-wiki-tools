		<gather name="雾里寻踪">
			<level name="GreenIs_TracingMist" cnName="雾里寻踪" descrip="话分两头，藏师带领随行尸宠沿着稍远的郁葱坪方向出发，这一路上相对安全，只要克服眼前携带迷雾发射装置的小股血蟒巡逻队即可。战斗完毕后迷雾会削弱，才能战斧高地取得联系。">
				<![CDATA[2025.11.21添加]]>
				<info enemyLv="99" noMoreB="1" noVehicleB="1" noTreasureB="1" noPropsB="1" mustSingleB="1" noDeviceB="1" />
				<sceneLabel>GreenIs4</sceneLabel>

				<unitG>
					<allDefault aiOrder="patrolGlobal" noSuperB="1" />
					<!-- 我方：藏师 + 三尸宠 -->
					<unitOrder id="we1" camp="we">
						<unit cnName="藏师将军" dpsMul="6500" lifeMul="0.5" dieGotoState="stru"
							skillArr="vacuumJie_6,groupLight_hero_7,crazy_hero_2,through_hero_2,murderous_hero_2,pointBoom_hero_2,hiding_hero_2,jumpNumAdd1,rolling_hero_5,State_AddMove50" armsRange="rocket1,sniperRifle,pistol_two,ak47,shotgun_two"/>
					</unitOrder>
					<unitOrder id="pet2" camp="we">
						<unit cnName="冥王" lifeMul="1.8" dpsMul="40"
							aiOrder="followBodyAttack:藏师将军" />
					</unitOrder>
					<unitOrder id="pet3" camp="we">
						<unit cnName="爆骷S" lifeMul="1.6" dpsMul="35"
							aiOrder="followBodyAttack:藏师将军" />
					</unitOrder>

					<!-- 敌方：携带迷雾发射装置的血蟒巡逻队 -->
					<unitOrder id="enemy1">
						<numberType>num</numberType>
						<unit cnName="血蟒雇佣兵" num="1" lifeMul="2.5" skillArr="slowMove_enemy" />
						<unit cnName="血蟒突击兵" num="1" lifeMul="2.5" armsRange="rifleDragon" skillArr="toFlyState"/>
						<unit cnName="血蟒狙击兵" num="1" lifeMul="3" skillArr="imploding_enemy" />
						<unit cnName="巡逻狗" num="1"/>
						<unit cnName="飞天狗" num="1"/>
						<unit cnName="血蟒重甲兵" num="2"/>
					</unitOrder>
					<unitOrder id="enemy2">
						<numberType>num</numberType>
						<unit cnName="血蟒雇佣兵" num="2" lifeMul="2.5" skillArr="slowMove_enemy" />
						<unit cnName="血蟒突击兵" num="2" lifeMul="2.5" armsRange="rifleDragon" skillArr="toFlyState,imploding_enemy"/>
						<unit cnName="血蟒狙击兵" num="2" lifeMul="2.5" armsRange="sniperSmilodon" skillArr="feedback_enemy"/>
						<unit cnName="巡逻狗" num="2"/>
						<unit cnName="飞天狗" num="2"/>
						<unit cnName="血蟒重甲兵" num="2"/>
					</unitOrder>
				</unitG>
				<rectG>
					<!-- 敌人出生点 -->
					<rect id="rEnemySpace1">2600,650,100,100</rect>
					<rect id="rEnemySpace2">1700,650,100,100</rect>
					<!-- 其他特殊点 -->
					<rect id="fly1">152,600,60,60</rect>
					<rect id="r_wounded">2500,1150,50,50</rect>
					<rect id="r_prison">500,400,80,80</rect>
					<rect id="r_prison_guard">520,420,50,50</rect>
					<rect id="r_retreat">600,600,50,50</rect>
					<rect id="r_friend">200,200,50,50</rect>
					<rect id="r_boss">250,200,50,50</rect>
				</rectG>
				<eventG>
					<group>
						<event>
							<condition />
							<order>weAllHeroNoShoot</order>
							<order>weAllHeroNoEquip</order>
							<order>addWeather:rain; 3:10000</order>
							<order>createUnit:we1; r_birth</order>
							<order>heroEverParasitic:藏师将军</order>
							<order>createUnit:pet2; r2</order>
							<order>createUnit:pet3; r3</order>
							<order>openInput</order>
						</event>
						<event>
							<condition delay="1" />
							<order>playMusic; music_face:suspense</order>
							<order>body:sumByP1; addTempDevice:hammerMine_6,10</order>
							<order>say; startList:s1</order>
						</event>
						<!-- 遭遇迷雾巡逻队 -->
						<event>
							<condition>say:listOver</condition>
							<order>say; startList:s2</order>
						</event>
						<!-- 全灭第一波 -->
						<event>
							<condition>say:listOver</condition>
							<order>createUnit:enemy2; rEnemySpace1</order>
							<order>body:sumByP1; addTempDevice:hammerMine_6,2</order>
						</event>
						<event>
							<condition doNumber="3">enemyNumber:less_1</condition>
							<order>createUnit:enemy1; rEnemySpace2</order>
							<order>body:sumByP1; addTempDevice:hammerMine_6,2</order>
						</event>
						<event>
							<condition delay="0.5">enemyNumber:less_1</condition>
							<order>say; startList:s3</order>
						</event>
						<event>
							<condition delay="0.5">say:listOver</condition>
							<order>createUnit:enemy2; rEnemySpace1</order>
							<order>body:sumByP1; addTempDevice:hammerMine_6,2</order>
						</event>
						<!-- 全灭敌人，迷雾削弱 -->
						<event>
							<condition delay="0.5">enemyNumber:less_1</condition>
							<order>playMusic; music_face:piano</order>
							<order>say; startList:s4</order>
						</event>
						<!-- 恢复与高地通讯 -->
						<event>
							<condition>say:listOver</condition>
							<order>say; startList:s5</order>
						</event>
						<event>
							<condition>say:listOver</condition>
							<order>task:now; complete</order>
							<order>level; showPointer:r_over</order>
						</event>
					</group>
					<group>
						<event id="e_fail">
							<condition delay="1">bodyEvent:die; 藏师将军</condition>
							<order>alert:yes; 藏师阵亡，任务失败！</order>
						</event>
						<event>
							<condition delay="0.03" />
							<order>level; fail</order>
						</event>
					</group>
				</eventG>
			</level>
		</gather>
		<gather name="雷区险地">
			<level name="GreenIs_MineFields" cnName="雷区险地" descrip="话分另一头，小樱一行人沿着郁葱甸方向发现了掩埋在道路间的大量地雷，利用随身缴获的特殊地雷去连环引爆，开辟一条安全前进道路，但在排雷后有一队血蟒士兵匆匆撤退至此，他们似乎并不是来围剿你们的，这是什么情况？（开发者模式下无强制排雷数量任务目标要求）">
				<![CDATA[2025.12.28添加]]>
				<info diy="greenIsTask" enemyLv="99" preBulletArr="hurtMineBullet,hammerMineBullet" noAIB="1" noMoreB="1" noVehicleB="1" noTreasureB="1" noPropsB="1" mustSingleB="1" noDeviceB="1" firstLostB="1" />
				<drop noChargerBasinB="1"/>
				<sceneLabel>GreenIs3</sceneLabel>
				<unitG>
					<allDefault aiOrder="patrolGlobal" noSuperB="1" />
					<!-- 我方：天鹰小美、小樱、心零（无尸宠） -->
					<unitOrder id="we1" camp="we">
						<!-- 天鹰小美（玩家控制） -->
						<unit cnName="天鹰小美" dpsMul="350" lifeMul="0.5" dieGotoState="stru"
							armsRange="rocket1"
							skillArr="groupLight_hero_7,hiding_hero_3,wisdomAnger_hero_1,screaming_hero_2,invisibility_enemy,skillCopy_enemy,sweep_enemy,moreMissile_enemy,disabledHalo_enemy,paralysis_enemy,changeToZombie_enemy,jumpNumAdd1,gliding_hero_7" />
					</unitOrder>
					<unitOrder id="we2" camp="we">
						<!-- 小樱（初始静止） -->
						<unit cnName="小樱" dpsMul="3000" lifeMul="50" dieGotoState="stru"
							skillArr="vacuumJie_7,trueshotYing_2,hurtAddYing_2,coquettish_hero_4,invisibility_hero_4,screaming_hero_4,gliding_hero_4,rolling_hero_5,heroSprint,jumpNumAdd1,WatchEagleWing"
							armsRange="pistol_two,shotgun_two,sniperRifle,ak47" aiOrder="followBodyAttack:心零" />
					</unitOrder>
					<unitOrder id="we3" camp="we">
						<!-- 心零（初始静止） -->
						<unit cnName="心零" dpsMul="350" lifeMul="50" dieGotoState="stru"
							skillArr="coquettish_hero_14,tauntLing_10,strongLing_10,revengeLing_10,resonanceLing_10,nightLing_10,clawLing_10,jumpNumAdd1,State_AddMove50,WatchEagleWing"
							armsRange="shotgun1" aiOrder="followBodyAttack:天鹰小美" />
					</unitOrder>
					<!-- 撤退的血蟒士兵（友军，不攻击） -->
					<unitOrder id="we4" camp="we">
						<unit cnName="血蟒突击兵" lifeMul="50" dpsMul="10" dieGotoState="stru" />
						<unit cnName="血蟒狙击兵" lifeMul="0.5" dpsMul="10" dieGotoState="stru" />
					</unitOrder>
				</unitG>

				<rectG>
					<!-- 敌人出生点（未使用但保留） -->
					<rect id="rEnemySpace1">2600,650,100,100</rect>
					<rect id="rEnemySpace2">1700,650,100,100</rect>
					<!-- 血蟒士兵出现点 -->
					<rect id="r_wounded">3300,1200,100,100</rect>
					<!-- 其他备用矩形 -->
					<rect id="fly1">152,600,60,60</rect>
					<rect id="fly2">150,950,100,100</rect>
					<rect id="fly3">100,850,50,50</rect>
					<rect id="r_prison">500,400,80,80</rect>
					<rect id="r_prison_guard">520,420,50,50</rect>
					<rect id="r_retreat">600,600,50,50</rect>
					<rect id="r_friend">200,200,50,50</rect>
					<rect id="r_boss">250,200,50,50</rect>
				</rectG>

				<eventG>
					<group>
						<!-- 初始设置：创建单位、赋予地雷、调用地雷初始化 -->
						<event>
							<condition />
							<order>weAllHeroNoShoot</order>
							<order>weAllHeroNoEquip</order>
							<order>addWeather:heat; 3:10000</order>
							<order>createUnit:we1; r_birth</order>
							<order>createUnit:we2; fly2</order>
							<order>createUnit:we3; fly3</order>
							<order>heroEverParasitic:天鹰小美</order>
							<order>body:sumByP1; addTempDevice:hammerMine_6,40</order>
							<order>body:sumByP1; allArmsCapacity:15</order>
							<order>body:sumByP1; allArmsChargerMul:0</order>
							<order>GreenIs1_mine</order>
							<!-- 停止小樱和心零的AI，使其静止 -->
							<order>body:小樱; ai:no</order>
							<order>body:心零; ai:no</order>
							<order>openInput</order>
						</event>

						<!-- 开场对话 -->
						<event>
							<condition delay="1" />
							<order>playMusic; music_face:suspense</order>
							<order>say; startList:s1</order>
						</event>

						<!-- 发现雷区 -->
						<event>
							<condition delay="2">say:listOver</condition>
							<order>say; startList:s2</order>
						</event>

						<!-- 玩家确认引爆 -->
						<event>
							<condition>say:listOver</condition>
							<order>playMusic; music_face:descent</order>
							<order>alert:yes; 尝试在有限的火炮弹药前提下用缴获的眩晕地雷连环引爆前方雷区。</order>
						</event>

						<!-- 选择“是”后播放对话 -->
						<event>
							<condition>enemyMineNumer:less_1</condition>
							<order>say; startList:s3</order>
						</event>

						<!-- 等待地雷排除任务完成（由地雷系统自动触发） -->
						<event>
							<condition delay="0.5">say:listOver</condition>
							<!-- 恢复小樱和心零的AI -->
							<order>body:小樱; ai:followBodyAttack:天鹰小美</order>
							<order>body:心零; ai:followBodyAttack:天鹰小美</order>
							<order>createUnit:we4; r_wounded</order>
							<order>playMusic; music_face:suspense</order>
							<order>say; startList:s4</order>
						</event>

						<!-- 任务完成，显示出口 -->
						<event>
							<condition delay="0.1">say:listOver</condition>
							<order>body:血蟒突击兵; rangeLimit:close</order>
							<order>body:血蟒突击兵; lockShootXY:4000,1200</order>
							<order>body:血蟒狙击兵; rangeLimit:close</order>
							<order>body:血蟒狙击兵; lockShootXY:4000,1200</order>
						</event>
						<event>
							<condition delay="0.5"></condition>
							<order>body:血蟒突击兵;followPoint:4000,1200</order>
							<order>body:血蟒狙击兵;followPoint:4000,1200</order>
						</event>
						<event>
							<condition delay="3"></condition>
							<order>body:血蟒突击兵; addEffectPosition:oreBombShowFlower</order>
							<order>body:血蟒突击兵; toDel</order>
							<order>body:血蟒狙击兵; addEffectPosition:oreBombShowFlower</order>
							<order>body:血蟒狙击兵; toDel</order>
							<order>say; startList:s5</order>
							<!-- 简短提醒断后开始 -->
						</event>
						<event>
							<condition delay="1">say:listOver</condition>
							<order>playMusic; music_face:suspense</order>
							<order>level; shake:beatMadboss</order>
							<order>say; startList:s6</order>
						</event>
						<event>
							<condition delay="1">say:listOver</condition>
							<order>task:now; complete</order>
							<order>level; win</order>
						</event>
					</group>
					<!-- 失败条件：天鹰小美阵亡 -->
					<group>
						<event id="e_fail1">
							<condition delay="1">bodyEvent:die; 天鹰小美</condition>
							<order>alert:yes; 小美阵亡，任务失败！</order>
						</event>
						<event>
							<condition delay="0.03" />
							<order>level; fail</order>
						</event>
						<event id="e_fail2">
							<condition delay="1">bodyEvent:die; 心零</condition>
							<order>alert:yes; 心零阵亡，任务失败！</order>
						</event>
						<event>
							<condition delay="0.03" />
							<order>level; fail</order>
						</event>
						<event id="e_fail3">
							<condition delay="1">bodyEvent:die; 小樱</condition>
							<order>alert:yes; 小樱阵亡，任务失败！</order>
						</event>
						<event>
							<condition delay="0.03" />
							<order>level; fail</order>
						</event>
					</group>
				</eventG>
			</level>
		</gather>
		<gather name="尸变危机">
			<level name="GreenIs_MorgueCrisis" cnName="尸变危机" descrip="情况突变，先前追捕爆枪小队的血蟒部队反而被僵尸部队追杀撤退至此，联起手来共同击退即将靠近的大批已感染血蟒持枪僵尸部队，记得充分运用血蟒士兵递给你的时停沙漏道具，此战结束后，小樱一行人将得到更多小白和文杰的行踪信息。">
				<!-- 关卡数据：预置时停沙漏技能，禁用载具/道具/装备等 -->
				<![CDATA[2026.1.21添加]]>
				<info diy="greenIsTask" enemyLv="99" preSkillArr="timeCapsuleT" noMoreB="1" noVehicleB="1" noTreasureB="1" noPropsB="1" mustSingleB="1" noDeviceB="1" firstLostB="1" />
				<drop noChargerBasinB="1" />
				<sceneLabel>GreenIs3</sceneLabel>

