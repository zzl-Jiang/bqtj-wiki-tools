<?xml version="1.0" encoding="utf-8" ?>
<data>
	<father name="we">
		<body name="大圣分身" shell="normal">
			
			<name>GreatSageShadow</name>
			<cnName>大圣分身</cnName>
			<raceType>human</raceType>
			<showLevel>9999</showLevel>
			<swfUrl>swf/enemy/GreatSageShadow329.swf</swfUrl>
