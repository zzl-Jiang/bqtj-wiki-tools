					<attackType>holy</attackType>
					<hitImgUrl name="yellowStickHit"/>
				</hurt>
			</hurtArr>
		</body>
		
		
			<skill>
				<name>greatSageFly</name>
				<cnName>筋斗云</cnName><ignoreNoSkillB>1</ignoreNoSkillB><ignoreImmunityB>1</ignoreImmunityB><noSkillDodgeB>1</noSkillDodgeB><noBeClearB>1</noBeClearB><everNoClearB>1</everNoClearB>
				<!--触发条件与目标------------------------------------------------------------ -->
				<conditionType>passive</conditionType>
				<condition>add</condition>
				<target>me</target>
				<!--效果------------------------------------------------------------ -->
