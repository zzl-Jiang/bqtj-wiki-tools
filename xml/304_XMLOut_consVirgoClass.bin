<?xml version="1.0" encoding="utf-8" ?>
<data>
	<father type="blink">
		
		<bullet color="purgold" kind="particle" evoMaxLv="2" evoMustFirstLv="13" composeLv="99" chipNum="300">
			<name>consVirgo</name><extraMul>1.2</extraMul>
			<cnName>处女座</cnName><iconUrl>newGun/consVirgoIcon</iconUrl>
			<aiShootRange>1700</aiShootRange><!-- ai射程 -->
			<attackType>holy</attackType>
			<dpsMul>8</dpsMul>
			<uiDpsMul>2.27</uiDpsMul>
			<!--基本-->
			<capacity>15</capacity>
			<attackGap>0.5</attackGap>
			<reloadGap>1</reloadGap>
			<bulletWidth>180</bulletWidth>
			<bulletNum>1</bulletNum>				
			<!--武器属性------------------------------------------------------------ -->
			<armsArmMul>0.8</armsArmMul>
			<upValue>0</upValue>
			<shootShakeAngle>45</shootShakeAngle>
			<shootRecoil>5</shootRecoil>
			<screenShakeValue>9</screenShakeValue>
			<!--基本属性------------------------------------------------------------ -->
			<bulletLife>0.001</bulletLife>
			<hitType>rect</hitType>
			<!--运动属性------------------------------------------------------------ -->	
			<bulletSpeed>0.1</bulletSpeed>
			<!--特殊------------------------------------------------------------ -->
			<twoShootPro>0.3</twoShootPro>
			<penetrationGap>1000</penetrationGap>
			<penetrationNum>999</penetrationNum>
			<bounceD floor="0" body="0"/>	<!-- 反弹 -->
			<critD mul="2" pro="0.3"/>
			<skillArr>Hit_AddLifeMul_ArmsSkill,Kill_Spurting_ArmsSkill</skillArr>
			<godSkillArr>Hit_atry_godArmsSkill,consVirgoSkill</godSkillArr>
			<!--图像动画属性------------------------------------------------------------ -->
			<shootSoundUrl>newGun/consVirgoS4</shootSoundUrl>
			<imgClearDelay>0.3</imgClearDelay>
			<bulletVra>-0.00091</bulletVra>
			<bulletImgUrl name="consVirgoBullet"/><![CDATA[子弹类特效，注意len是否有值，len只有激光类才能用，否则将无法显示]]>
			<hitImgUrl name="consVirgoHit"/>
			<fireImgUrl name="purpleGunFire"/>
			<!--图像范围------------------------------------------------------------ -->
			<bodyImgRange>newGun/consVirgo</bodyImgRange>
			<bulletImgRange>specialGun/bullet</bulletImgRange>
			<description>消灭首领狂战神(99级)</description>
		</bullet>
	</father>
	<father name="godArmsSkill" cnName="神级武器技能">
		<skill>
			<name>consVirgoSkill</name>
			<cnName>星速子弹</cnName><noRandomListB>1</noRandomListB><ignoreNoSkillB>1</ignoreNoSkillB>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>passive</conditionType>
			<condition>beforeAttack</condition>
			<target>me</target>
			<!--效果------------------------------------------------------------ -->
			<addType>instant</addType>
			<effectType>consVirgoSkill</effectType>
			<otherEffectImg name="consVirgoLine"/>
			<description>发射时，把子弹瞬移到鼠标点位置，中间不受任何障碍物的阻挡，且无视刚体。</description>
		</skill>
	</father>
</data>