		<body name="神圣盖亚" fixed="BlackTitans" shell="compound">
			<name>GoldGaia</name>
			<cnName>神圣盖亚</cnName>
			<swfUrl>swf/vehicle/GoldGaia.swf</swfUrl>
			<bmpUrl>BodyImg/GoldGaia</bmpUrl>
			<lifeBarExtraHeight>-50</lifeBarExtraHeight>
			<motionD F_G="0.6" jumpDelayT="0.2" F_I="1" F_F="0.9" moveWhenVB="1" />
