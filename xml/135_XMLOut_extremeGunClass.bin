<?xml version="1.0" encoding="utf-8" ?>
<data>
	<father type="lightning">
		
		<bullet color="darkgold" evoMaxLv="5" evoMustFirstLv="9" composeLv="99" chipNum="200">
			<name>extremeGun</name>
			<cnName>极源</cnName><extraMul>1.3</extraMul>
			<aiShootRange>900</aiShootRange><!-- ai射程 -->
			<attackType>holy</attackType>
			<dpsMul>0.5</dpsMul>
			<uiDpsMul>1.49</uiDpsMul>
			<iconUrl>specialGun/extremeGunIcon</iconUrl>
			<!--基本-->
			<capacity>13</capacity>
			<attackGap>0.8</attackGap>
			<reloadGap>2</reloadGap>
			<bulletWidth>25</bulletWidth>
			<bulletNum>1</bulletNum>				
			<shootAngle>1</shootAngle>
			<!--武器属性------------------------------------------------------------ -->
			<armsArmMul>0.5</armsArmMul>
			<upValue>10</upValue>
			<shootShakeAngle>30</shootShakeAngle>
			<shootRecoil>5</shootRecoil>
			<screenShakeValue>9</screenShakeValue>
			<!--基本属性------------------------------------------------------------ -->
			<noHitB>1</noHitB>
			<bulletLife>1</bulletLife>
			<hitType>rect</hitType>
			<!--运动属性------------------------------------------------------------ -->	
			<bulletSpeed>50</bulletSpeed>
			<bulletSkillArr>extremeGun</bulletSkillArr>
			<!--特殊------------------------------------------------------------ -->
			<penetrationNum>999</penetrationNum>
			<twoShootPro>0.3</twoShootPro>
			<bounceD floor="0" body="0"/>	<!-- 反弹 -->
			<boomD selfB="1"/>
			<critD mul="0" pro="0"/>
			<skillArr>Hit_Paralysis_ArmsSkill,Hit_silence_ArmsSkill</skillArr>
			<godSkillArr>extremeGunSkill</godSkillArr>
			<!--图像动画属性------------------------------------------------------------ -->
			<shootSoundUrl>sound/lightningShoot</shootSoundUrl>
			<bulletImgUrl name="extremeGunBullet"/>
			<![CDATA[<hitImgUrl soundUrl="sound/paralysis_enemy_hit"  shake="2,0.2,10" con="filter">generalEffect/frozenBallHide</hitImgUrl>]]>
			<selfBoomImgUrl con="add">generalEffect/frozenBallHide</selfBoomImgUrl>
			<hitFloorImgUrl con="add">generalEffect/frozenBallHide</hitFloorImgUrl>
			<!--图像范围------------------------------------------------------------ -->
			<bodyImgRange>specialGun/extremeGun</bodyImgRange>
			<bulletImgRange>specialGun/bullet</bulletImgRange>
			<description>消灭首领利爪僵尸(99级)</description>
		</bullet>
	</father>
	<father name="godArmsSkill" cnName="神级武器技能">
		<skill>
			<name>extremeGunSkill</name><noRandomListB>1</noRandomListB>
			<cnName>电磁黏连</cnName>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>passive</conditionType>
			<condition>hit</condition>
			<target>me</target>
			<!--效果------------------------------------------------------------ -->
			<addType>instant</addType>
			<effectType>no</effectType>
			<description>经过敌人时将产生电磁黏连，使电球移动速度变慢2.5倍（对僵尸精英怪或僵尸首领将变慢4倍），从而有更多的时间攻击敌人。</description>
		</skill>
		<skill>
			<name>extremeGunSkill2</name><noRandomListB>1</noRandomListB>
			<cnName>紊乱电流</cnName><ignoreImmunityB>1</ignoreImmunityB><noSkillDodgeB>1</noSkillDodgeB>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>passive</conditionType>
			<condition>hit</condition>
			<target>target</target>
			<!--效果------------------------------------------------------------ -->
			<addType>state</addType>
			<effectType>noReplyB</effectType>
			<stateEffectImg name="headElectric"/>
			<duration>3</duration>
			<description>击中敌人后紊乱其回复机制，使其无法回复生命值，持续[duration]秒。无视技能免疫。</description>
		</skill>
	</father>
</data>