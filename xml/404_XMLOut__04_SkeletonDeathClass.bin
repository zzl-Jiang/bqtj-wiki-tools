<?xml version="1.0" encoding="utf-8" ?>
<data>
	<father name="death" cn="单位">	
		<body index="0" name="末日暴君">
			
			<name>SkeletonDeath</name>
			<cnName>末日暴君</cnName>
			<raceType>zombies</raceType><headIconUrl>IconGather/Skeleton</headIconUrl>
			<swfUrl>swf/enemy/Skeleton358.swf</swfUrl>
			<swfName>Skeleton</swfName>
			<!-- 基本系数 -->
			<lifeRatio>1</lifeRatio>
			<showLevel>9999</showLevel>
			<!-- 图像 -->
			<imgType>normal</imgType>
			<imgArr>
				stand,move,run
				,normalAttack2,comboAttack2,bulletAttack2,machineAttack2,plugAttack2
				,hurt1,hurt2,die1
				,__jumpUp,jumpUp,jumpUp__jumpDown,jumpDown,jumpDown__
				,__fill1_Up,fill1_Up,fill1_Up__fill1_Down,fill1_Down,fill1_Down__die1
			</imgArr>
			<lifeBarExtraHeight>-60</lifeBarExtraHeight>
			<handAddRa>90</handAddRa>
			<!-- 碰撞体积 -->
			<hitRect>-18,-96,36,96</hitRect>
			<!-- 运动 -->
			<maxJumpNum>1</maxJumpNum>
			<maxVx>8</maxVx>
			<runStartVx>11</runStartVx>
			<!-- AI属性 -->
			<nextAttackTime>0</nextAttackTime>
			<!-- 技能 -->
			<bulletLauncherClass>VehicleBulletLauncher</bulletLauncherClass>
			<skillArr></skillArr>
			<bossSkillArr>knife_skeletonDeath</bossSkillArr>
			<extraAIClassLabel>Skeleton_AIExtra</extraAIClassLabel>
			<preBulletArr>knife_skeleton</preBulletArr>
			<!-- 攻击数据 -->
			<hurtArr>
				<!-- 普通攻击1 -->
				<hurt>
					<imgLabel>normalAttack2</imgLabel><cn>竖切</cn>
					<grapMaxLen>140</grapMaxLen><grapMinLen>0</grapMinLen>
					<hurtRatio>1</hurtRatio>
					<attackType>direct</attackType>
					<shakeValue>10</shakeValue>
					<hitImgUrl name="cutHit"/>
				</hurt>
				<!-- 瞬移连击 -->
				<hurt cd="4">
					<imgLabel>comboAttack2</imgLabel><cn>连击</cn>
					<grapMaxLen>1000</grapMaxLen>
					<hurtRatio>1</hurtRatio>
					<attackType>direct</attackType>
					<shakeValue>7</shakeValue>
					<hitImgUrl name="cutHit"/>
				</hurt>
				<hurt cd="7.5">
					<imgLabel>bulletAttack2</imgLabel><cn>导弹</cn><mustGrapRectB>1</mustGrapRectB>
					<grapMaxLen>800</grapMaxLen><grapRect>-800,-800,1600,1600</grapRect>
					<bulletLabel>Skeleton_bullet2</bulletLabel>
					<hurtRatio>0.6</hurtRatio>
					<attackType>direct</attackType>
				</hurt>
				<!-- 机关枪 -->
				<hurt  cd="6">
					<imgLabel>machineAttack2</imgLabel><cn>机关枪</cn><mustGrapRectB>1</mustGrapRectB>
					<grapMaxLen>900</grapMaxLen><grapRect>-800,-800,1600,1600</grapRect>
					<bulletLabel>Skeleton_machine2</bulletLabel>
					<hurtRatio>0.15</hurtRatio>
					<attackType>direct</attackType>
				</hurt>
				<!-- 插入地面 （ai不选择）-->
				<hurt info="不加入ai选择">
					<imgLabel>plugAttack2</imgLabel><noAiChooseB>1</noAiChooseB>
					<grapRect>-400,-111,300,105</grapRect>
					<hurtRatio>3</hurtRatio>
					<attackType>direct</attackType>
					<shakeValue>7</shakeValue>
					<hitImgUrl name="oreWormHit"/>
				</hurt>
			</hurtArr>
		</body>	
		<skill index="0" name="骷髅-地狱之刃">
			<name>knife_skeletonDeath</name>
			<cnName>地狱之刃</cnName><iconUrl36>SkillIcon/knife_skeleton_36</iconUrl36>
			<showInLifeBarB>1</showInLifeBarB><wantDescripB>1</wantDescripB>
			<cd>8</cd>
			
			<ignoreSilenceB>1</ignoreSilenceB>
			<conditionType>active</conditionType>
			<condition>avtiveSkillCdOver</condition>
			<otherConditionArr>lifePerLess</otherConditionArr>
			<conditionRange>0.4</conditionRange>
			<target>me</target>
			
			<addType>state</addType>
			<effectType>no</effectType>
			<value>1</value>
			<mul>1</mul>
			<duration>1</duration>
			<meActionLabel>plugAttack2</meActionLabel>
			<stateEffectImg partType="hand_left" con="filter">skillEffect/smallFire</stateEffectImg>
			<description>暴君用力将它的地狱剑插入地面，在地壳之下形成无数的剑刃并转向刺出地面，被刺中的敌人将受到巨大的伤害。</description>
		</skill>
		
		
		<bullet cnName="骷髅-跟踪导弹">
			<name>Skeleton_bullet2</name>
			<cnName>骷髅-跟踪导弹</cnName>
			<hurtRatio>1</hurtRatio>
			<!--基本属性------------------------------------------------------------ -->
			<shakeAngle>5</shakeAngle>
			<bulletLife>3</bulletLife>
			<bulletWidth>30</bulletWidth>
			<hitType>rect</hitType>
			<!--攻击时的属性------------------------------------------------------------ -->
			<attackGap>1</attackGap>
			<attackDelay>0.8</attackDelay>
			<bulletAngle>175</bulletAngle>
			<bulletAngleRange>50</bulletAngleRange>
			<bulletNum>3</bulletNum>				
			<shootNum>1</shootNum>					
			<shootAngle>5</shootAngle>					
			<!--特殊属性------------------------------------------------------------ -->	
			
			<!--运动属性------------------------------------------------------------ -->	
			<shootPoint>-97,-84</shootPoint>
			<bulletSpeed>24</bulletSpeed>
			
			<penetrationGap>1000</penetrationGap>
			<![CDATA[v35.9取消导弹跟踪
			<speedD max="35" min="3" a="-15" />
			<followD value="2" delay="0.8" maxTime="2" />
			<bulletSkillArr>pointerMissileNoDieLAST</bulletSkillArr>
			]]>
			<noHitTime>0.1</noHitTime>
			<!--图像动画属性------------------------------------------------------------ -->
			<flipX>1</flipX>
			<bulletImgUrl name="fightBackBullet_bullet"/>
			<hitImgUrl soundUrl="boomSound/midBoom2"  shake="3,0.4,13">boomEffect/boom2</hitImgUrl><!-- 子弹图像【必备】 -->
			<hitFloorImgUrl soundUrl="boomSound/smallBoom"  shake="3,0.4,9" soundVolume="0.5">boomEffect/boom1</hitFloorImgUrl><!-- 子弹图像【必备】 -->
			<smokeImgUrl name="smallMissleSmokeSm"/><!-- 子弹尾烟效果（默认为空） -->
		</bullet>
		<bullet index="0" name="骷髅-散弹枪">
			<name>Skeleton_machine2</name>
			<cnName>骷髅-散弹枪</cnName>
			<!--武器属性------------------------------------------------------------ -->
			<hurtRatio>0.06</hurtRatio>
			<!--基本属性------------------------------------------------------------ -->
			<bulletLife>5</bulletLife>
			<hitType>rect</hitType>
			<bulletWidth>15</bulletWidth>
			<extendGap>50</extendGap>
			<!--攻击时的属性------------------------------------------------------------ -->
			<shootPoint>-97,-84</shootPoint>
			<bulletAngle>175</bulletAngle>
			<attackGap>1.6</attackGap>
			<attackDelay>1.1</attackDelay>
			<bulletNum>50</bulletNum>
			<shootNum>4</shootNum>					
			<shootGap>0.07</shootGap>					
			<!--运动属性------------------------------------------------------------ -->	
			<shootAngle>175</shootAngle>				
			<bulletSpeed>15</bulletSpeed>
			<bulletImgUrl>LingShooter/bullet</bulletImgUrl>
			<hitImgUrl name="gun_hit"/>
		</bullet>
	</father>
</data>