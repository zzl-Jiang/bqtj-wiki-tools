<?xml version="1.0" encoding="utf-8" ?>

<!-- id是唯一识别码，必须防止和其他关卡集合重复，不设置的话默认为文件名。 -->
<data id="fileLevelExampleBody" cnName="创建新单位" author="沃龙先生">
	<!-- 关卡集介绍。 -->
	<info>演示了如何添加新单位。</info>
	<father name="normal" cn="关卡">
		<gather>
			<level name="fileLevelExampleBody1" cnName="新角色：噬原" descrip="">
				<!-- info参数【更多参数参考“开发文档_关卡.xls的info参数”】-->
				<info enemyLv="99" noMoreB="1" noVehicleB="1" noTreasureB="1" noPropsB="1" mustSingleB="1" noDeviceB="1" noAIB="1" />
				<!-- 场景 -->
				<sceneLabel>WoTu</sceneLabel>
				<!-- 发兵集************************************************ -->
				<unitG>
					<!-- 设置全部单位id命令为patrolGlobal（巡逻全图） -->
					<allDefault aiOrder="patrolGlobal"></allDefault>
					<unitOrder id="we1" camp="we">
						<unit id="weBoss" cnName="噬原" lifeMul="0.1" dpsMul="3000" skillArr="" />
					</unitOrder>
					<!-- 创建id为enemy1的发兵集。 camp="enemy"代表阵营设为敌方，要设为我方请用"we"，不设置的话默认为敌方。-->
					<unitOrder id="enemy1" camp="enemy">
						<!-- number（按照num数量发兵），pro就是按照（按照num数量进行概率发兵） -->
						<numberType>number</numberType>
						<unit cnName="肥胖僵尸" num="2" />
						<unit cnName="战斗僵尸" num="3" />
					</unitOrder>
					<unitOrder id="enemy2">
						<numberType>pro</numberType>
						<unit cnName="肥胖僵尸" num="3" />
						<unit cnName="战斗僵尸" num="4" />
					</unitOrder>
					<unitOrder id="enemy3">
						<numberType>pro</numberType>
						<unit cnName="肥胖僵尸" num="8" />
						<unit cnName="战斗僵尸" num="8" />
						<unit cnName="携弹僵尸" num="1" />
					</unitOrder>
					<unitOrder id="enemy4">
						<!-- unitType：单位类型，boss（首领），super（精英怪），normal（小怪，默认值） -->
						<!-- lifeMul：生命倍数，dpsMul：伤害倍数 -->
						<!-- skillArr：设置额外技能 ，格式="技能1英文名,技能2英文名..." -->
						<!-- 【更多参数参考“开发文档_关卡.xls的unit参数”】 -->
						<unit cnName="携弹僵尸" num="1" unitType="boss" lifeMul="2" dpsMul="3" skillArr="groupCrazy_enemy,groupLight_enemy" />
					</unitOrder>
				</unitG>
				
				<!-- 事件集，每个事件集内的event按照顺序运行，上个event执行结束后才会进行下一个。而事件集1和事件集2则同时运行。 -->
				<eventG>
					<group id="group1" cnName="事件集1">
						<event>
							<!-- 恢复视野为标准值，避免受到远视镜的影响 -->
							<order>sceneScale:1</order>
							<!-- 限制p1功能 -->
							<order>weAllHeroNoEquip</order>
							<order>weAllHeroNoShoot</order><order>weAllHeroNoEquip</order>
							<!-- 添加战神发兵集到r_birth（出生地） -->
							<order>createUnit:we1; r_birth</order>
							<!-- p1永久附身于噬原 -->
							<order>heroEverParasitic:weBoss</order>
						</event>
						<event>
							<order>say; startList:s1</order>
						</event>
						<!-- 对话结束后继续，其他condition参数【参考“开发文档_关卡.xls的condtion条件”】 -->
						<event><condition>say:listOver</condition></event>
						<!-- 当敌人数量少于1时，发兵enemy1在区域r123（r1、r2、r3中随机），循环执行5次 （doNumber="5"）-->
						<event>
							<condition>enemyNumber:less_1</condition>
							<order>createUnit:enemy1; r123</order>
						</event>
						<!-- 当敌人数量少于1时继续-->
						<event><condition>enemyNumber:less_1</condition></event>
						<!-- 倒计时1秒后开启对话s2-->
						<event>
							<condition delay="1"></condition>
							<order>say; startList:s2</order>
						</event>
						<!-- 对话完毕后显示通关箭头在区域r_over -->
						<event>
							<condition>say:listOver</condition>
							<order>level; showPointer:r_over</order>
						</event>
					</group>
					<!-- 判断失败的事件集。 -->
					<group id="group2"  cnName="事件集2">
						<event><condition delay="0.01">bodyEvent:die; weBoss</condition></event>
						<event><condition delay="0.05"></condition><order>alert:yes; 关卡失败！</order></event>
						<event><condition delay="0.05"></condition><order>level; fail</order></event>
					</group>
				</eventG>
			</level>
		</gather>
	</father>	
	<father name="normal" cn="对话">
		<level name="levelExample1"><!-- name要和level 的name同名 -->
			<sayList name="s1">
				<say target="p1"><content>我是谁？</content></say>
				<say target="沃龙"><content>你是我创建的新角色：噬原。</content></say>
			</sayList>
			<sayList name="s2">
				<say target="沃龙"><content>感觉怎么样？</content></say>
				<say target="p1"><content>我的噬原刃呢？</content></say>
				<say target="沃龙"><content>你只是个演示品而已。</content></say>
			</sayList>
		</level>
	</father>
	
	<father name="developer" cn="单位">
		<body shell="normal">
			<name>ShiHun</name>
			<cnName>噬原</cnName>
			<raceType>human</raceType>
			<movieLink>Striker</movieLink>
			<swfName>phage</swfName>
			<!-- 基本系数 -->
			<!-- 图像 ，【已经链接到了movieLink】-->
			<headIconUrl>phage/head_icon</headIconUrl>
			<!-- 碰撞体积 -->
			<hitRect>-12, -90, 24, 90</hitRect><!-- 站立碰撞体积-->
			<squatHitRect>-12,-50,24,50</squatHitRect><!-- 下蹲碰撞体积-->
			<hurtRectArr>-12,-35,24,35</hurtRectArr> <!-- 要害受伤体积-->
			<hurtRectArr>-12, -70, 24, 70</hurtRectArr> <!-- 站立受伤体积-->
			<hurtRectArr>-12, -40, 24, 40</hurtRectArr> <!-- 下蹲受伤体积-->
			<!-- 运动 -->
			<maxVx>13</maxVx>
			<squatMaxVx>5</squatMaxVx>
			<!-- AI属性 -->
			<armsNumber>5</armsNumber><!-- 武器个数 -->
			<randomArmsRange>sniperRifle,rocket1,pistol1,ak47,shotgun1</randomArmsRange><!-- 随机枪范围，里面是armsRange的标签 -->	
			<oneAiLabel>sniper</oneAiLabel>
			<extraAIClassLabel>Hero_AIExtra</extraAIClassLabel>
			<!-- 技能 -->
			<skillArr>crazy_hero_5,through_hero_5,murderous_hero_5</skillArr>
		</body>
	</father>
	
	
</data>