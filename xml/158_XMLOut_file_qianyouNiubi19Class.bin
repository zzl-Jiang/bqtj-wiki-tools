<?xml version="1.0" encoding="utf-8" ?>


<data id="qianyouNiubi2025debug" cnName="支线续章：救援篇" author="倩友小萌新"><!-- id是唯一识别码，必须防止和其他关卡集合重复，不设置的话默认为文件名。 -->
	<info>
		救援篇时间线取自主线“狂战神”(星谷之巅对战狂战神)至“威慑”（氩星舰队降临战斧高地）这一个月的主线时间线内，并适当补充绿岛支线剧情。
		该系列支线剧情已实现与主线剧情的全接轨，第一章期待您的沉浸式剧情游玩体验！精英共赴寒光，营救亚瑟奇皇！
		还有续篇三大章更多剧情关卡敬请期待！        B站 倩友小萌新
		推荐：关闭P1的AI功能，默认小白档游玩，其余角色P1档可能会出现bug
	</info>

	

	
	<father name="normal" cn="关卡">
		<gather>
			<level name="OperationMidnight" cnName="夤夜行动" descrip="移步战斧高地，制毒师他们终于下定决心要下山做一项大胆的行动，他们的行动是什么呢？">
			<![CDATA[2025.8.21添加]]>
				<!--  发兵集************************************************  -->
				<info enemyLv="99" noMoreB="1" noVehicleB="1" noTreasureB="1" noPropsB="1" mustSingleB="1" noDeviceB="1"/>
				<sceneLabel>MainUpland</sceneLabel>
				<!--  发兵集************************************************  -->
				<unitG>
					<allDefault aiOrder="patrolGlobal" noSuperB="1"></allDefault>
					<!-- 人类 -->
					<unitOrder id="we1"  camp="we">
						<unit cnName="天鹰小美" dpsMul="1000" lifeMul="0.3" armsRange="lightCone,yearChicken,beadCrossbow,christmasGun$2" skillArr="groupLight_hero_7,hiding_hero_3,wisdomAnger_hero_1,screaming_hero_7,invisibility_enemy,skillCopy_enemy,changeToZombie_enemy,jumpNumAdd1,State_AddMove50" />
						<unit cnName="制毒师" aiOrder="followBodyAttack:天鹰小美"/>
					</unitOrder>
					<unitOrder id="we2"  camp="we">
						<unit cnName="雇佣兵" aiOrder="followBodyAttack:制毒师"/>
						<unit cnName="摩卡" aiOrder="followBodyAttack:雇佣兵"/>
					</unitOrder>
					<unitOrder id="we3"  camp="we">
						<unit cnName="丛林特种兵" num="5" aiOrder="followBodyAttack:摩卡"/>
						<unit cnName="沙漠特种兵" num="5" aiOrder="followBodyAttack:摩卡"/>
					</unitOrder>
				</unitG>
				<eventG>
					<group>
						<event>
							<condition></condition>
							<order>weAllHeroNoShoot</order>
							<order>weAllHeroNoEquip</order>
							<order>createUnit:we1; r_birth</order>
							<order>heroEverParasitic:天鹰小美</order>
						</event>
						<event>
							<condition delay="0.5"></condition>
							<order>playMusic; music_face:funny</order>
							<order>say; startList:s1</order>
						</event>
						<event>
							<condition delay="1">say:listOver</condition>
						</event>
						<event>
							<condition delay="1"></condition>
							<order>playMusic; music_face:piano</order>
							<order>say; startList:s2</order>
						</event>
						<event>
							<condition delay="1">say:listOver</condition>
						</event>
						<event>
							<condition delay="1"></condition>
							<order>createUnit:we2; r_birth</order>
							<order>playMusic; music_face:wind</order>
							<order>say; startList:s3</order>
						</event>
						<event>
							<condition delay="1">say:listOver</condition>
						</event>
						<event>
							<condition delay="1"></condition>
							<order>createUnit:we3; r_birth</order>
							<order>playMusic; music_face:wind</order>
							<order>say; startList:s4</order>
						</event>
						<event>
							<condition delay="2">say:listOver</condition>
							<order>task:now; complete</order>
							<order>level; showPointer:r_over</order>
						</event>
					</group>
				</eventG>
			</level>
			<level name="rescueArthur" cnName="秘密营救" descrip="跟随小美的指引，制毒师与阿天带领一支精英小队终于秘密潜入实验室地下，尝试营救困在生化罐的亚瑟等人。">
			<![CDATA[2025.2.3添加]]>
