			<level name="findwayOut" cnName="蹊径突围" descrip="亚瑟等顺利被营救，全体营救小队齐聚实验室地下，鬼影军团围困在急，众人该如何逃出生天？">
			<![CDATA[2025.2.7添加]]>
				<!--  发兵集************************************************  -->
				<info enemyLv="99" noMoreB="1" noVehicleB="1" noTreasureB="1" noPropsB="1" mustSingleB="1" noDeviceB="1"/>
				<sceneLabel>HospitalUnder</sceneLabel>
				<!--  发兵集************************************************  -->
				<unitG>
					<allDefault aiOrder="patrolGlobal" noSuperB="1"></allDefault>
					<!-- 人类 -->
					<unitOrder id="we1"  camp="we">
						<unit cnName="天鹰小美" dpsMul="1000" lifeMul="0.3" armsRange="lightCone,yearChicken,beadCrossbow,christmasGun$2" skillArr="groupLight_hero_7,hiding_hero_3,wisdomAnger_hero_1,screaming_hero_7,invisibility_enemy,skillCopy_enemy,changeToZombie_enemy,jumpNumAdd1,State_AddMove50" />
						<unit cnName="雇佣兵" aiOrder="followBodyAttack:我"/>
						<unit cnName="制毒师"/>
						<unit cnName="亚瑟" aiOrder="followBodyAttack:我"/>
						<unit cnName="奇皇博士" aiOrder="followBodyAttack:我"/>
						<unit cnName="鬼爵"/>
						<unit cnName="丛林特种兵" num="3" aiOrder="followBodyAttack:雇佣兵"/>
						<unit cnName="沙漠特种兵" num="3" aiOrder="followBodyAttack:我"/>
					</unitOrder>
				</unitG>
				<eventG>
					<group>
						<event>
							<condition></condition>
							
							<order>sceneMc:floor; hide:Arthur</order><!-- 隐藏地图中的亚瑟 -->
							<order>sceneMc:floor; hide:QiHuang</order><!-- 隐藏地图中的奇皇 -->
							<order>weAllHeroNoShoot</order>
