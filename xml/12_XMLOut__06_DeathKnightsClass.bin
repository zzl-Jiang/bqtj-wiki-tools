<?xml version="1.0" encoding="utf-8" ?>
<data>
	<father name="death" cn="单位">	
		<body index="0" name="死亡骑士" shell="compound">
			
			<name>DeathKnights</name>
			<cnName>死亡骑士</cnName><headIconUrl>IconGather/BlackKnights</headIconUrl>
			<raceType>robot</raceType>
			<swfUrl>swf/enemy/BlackKnights.swf</swfUrl>
			<swfName>BlackKnights</swfName>
			<!-- 基本系数 -->
			<rosRatio>99</rosRatio>
			<lifeRatio>1.8</lifeRatio>
			<rateRatio>0.05</rateRatio>
			<headHurtMul>0.3</headHurtMul>
			<showLevel>9999</showLevel>
			<!-- 图像 -->
			<dieJumpMul>0</dieJumpMul>
			<imgType>normal</imgType>
			<imgArr>
				stand,move
				,normalAttack,shootAttack
				,twoAttack,laserAttack,walkAttack
				,__jumpUp,jumpUp,jumpDown,jumpDown__
				,die1
			</imgArr>
			<lifeBarExtraHeight>-280</lifeBarExtraHeight>
			<handAddRa>90</handAddRa>
			<!-- 碰撞体积 -->
			<hitRect>-18,-96,36,96</hitRect>
			<!-- 运动 -->
			<maxJumpNum>1</maxJumpNum>
			<maxVx>7</maxVx>
			<motionD jumpDelayT="0.19" headRectScale="0.5" />
			<!-- AI属性 -->
			<nextAttackTime>0</nextAttackTime>
			<preBulletArr>DeathKnights_2</preBulletArr>
			<!-- 技能 -->
			<bulletLauncherClass>VehicleBulletLauncher</bulletLauncherClass>
			<skillArr>throughBK</skillArr>
			<bossSkillArr>underBlackKnights,BlackKnightsBuff,underHitBK,twoAttackBK,laserAttackBK,walkAttackBK</bossSkillArr>
			
			<extraAIClassLabel>BlackKnights_AIExtra</extraAIClassLabel>
			<!-- 掉落 -->
			<extraDropArmsB>1</extraDropArmsB>
			<!-- 攻击数据 -->
			<hurtArr>
				<!-- 普通攻击1 -->
				<hurt>
					<imgLabel>normalAttack</imgLabel><cn>重锤</cn>
					<mustGrapRectB>1</mustGrapRectB>
					<hurtRatio>2</hurtRatio>
					<attackType>direct</attackType>
					<shakeValue>10</shakeValue>
					<hitImgUrl name="yellowHit"/>
				</hurt>
				<hurt>
					<imgLabel>shootAttack</imgLabel><cn>拳炮</cn>
					<bulletLabel>DeathKnights_1</bulletLabel>
					<grapRect>-500,-100,250,150</grapRect>
					<hurtRatio>1</hurtRatio>
					<attackType>direct</attackType>
				</hurt>
				<![CDATA[以下为大招]]>
				<hurt>
					<imgLabel>twoAttack</imgLabel><cn>无双拳</cn><noAiChooseB>1</noAiChooseB>
					<grapRect>-500,-100,250,150</grapRect>
					<hurtRatio>2</hurtRatio>
					<attackType>direct</attackType>
				</hurt>
				<hurt>
					<imgLabel>laserAttack</imgLabel><cn>无疆激光</cn><noAiChooseB>1</noAiChooseB>
					<hurtRatio>1.4</hurtRatio>
					<attackType>direct</attackType>
					<shakeValue>10</shakeValue>
					<hitImgUrl name="silverScreenBulletHit"/>
				</hurt>
				<hurt>
					<imgLabel>walkAttack</imgLabel><cn>践踏</cn><noAiChooseB>1</noAiChooseB>
					<hurtRatio>2</hurtRatio><ingfollowB>1</ingfollowB>
					<attackType>direct</attackType>
					<shakeValue>10</shakeValue>
					<hitImgUrl name="yellowHit"/>
				</hurt>
			</hurtArr>
		</body>	
		<![CDATA[结束无双拳状态时，不受到无双拳子弹的伤害]]>
		<![CDATA[缩小头部碰撞区域]]>
		
		
		<bullet>
			<name>DeathKnights_1</name>
			<cnName>黑暗骑士-拳炮</cnName>
			<!--基本属性------------------------------------------------------------ -->
			<shakeAngle>5</shakeAngle>
			<bulletLife>2</bulletLife>
			<bulletWidth>30</bulletWidth>
			<hitType>rect</hitType>
			<!--攻击时的属性------------------------------------------------------------ -->
			<attackGap>1.35</attackGap>
			<attackDelay>0.27</attackDelay>
			<bulletAngle>157</bulletAngle>
			<bulletAngleRange>20</bulletAngleRange>
			<bulletNum>1</bulletNum>				
			<shootNum>2</shootNum>					
			<shootAngle>20</shootAngle>
			<shootGap>0.39</shootGap>					
			<!--特殊属性------------------------------------------------------------ -->	
			<penetrationGap>1000</penetrationGap>
			<!--运动属性------------------------------------------------------------ -->	
			<shootPoint>-106,-199</shootPoint>
			<bulletSpeed>15</bulletSpeed>
			<followD value="1.5" maxTime="0.35" />	<!-- 跟踪 -->
			<!--图像动画属性------------------------------------------------------------ -->
			<flipX>1</flipX>
			<bulletImgUrl name="BlackKnightsBullet"/>
			<hitImgUrl soundUrl="boomSound/midBoom2"  shake="3,0.4,13">boomEffect/boom2</hitImgUrl><!-- 子弹图像【必备】 -->
			<hitFloorImgUrl soundUrl="boomSound/smallBoom"  shake="3,0.4,9" soundVolume="0.5">boomEffect/boom1</hitFloorImgUrl><!-- 子弹图像【必备】 -->
			<smokeImgUrl con="filter" raNum="30">bulletHitEffect/smoke_small</smokeImgUrl><!-- 子弹尾烟效果（默认为空） -->
		</bullet>
		
		<bullet>
			<name>DeathKnights_2</name>
			<cnName>黑暗骑士-双拳炮</cnName><noMagneticB>1</noMagneticB>
			<!--基本属性------------------------------------------------------------ -->
			<shakeAngle>5</shakeAngle>
			<bulletLife>20</bulletLife>
			<bulletWidth>30</bulletWidth>
			<hitType>rect</hitType>
			<bulletAngle>-140</bulletAngle>	
			
			<bulletNum>1</bulletNum>								
			<shootAngle>30</shootAngle>	
			<!--特殊属性------------------------------------------------------------ -->	
			<penetrationGap>1000</penetrationGap>
			<boomD selfB="1" hurtMul="0" noExcludeBodyB="1" haveBodyHitEffectB="1"/>
			<bindingD cnName="空单位" lifeMul="0.01" skillArr="underBKBullet" />
			<!--运动属性------------------------------------------------------------ -->	
			<shootPoint>-153,-394</shootPoint>
			<bulletSpeed>15</bulletSpeed>
			<speedD a="-5" min="12" max="15" random="0.1" />
			<followD value="0.5" delay="0.3" maxTime="6" />	<!-- 跟踪 -->
			<skillArr></skillArr>
			<!--图像动画属性------------------------------------------------------------ -->
			<flipX>1</flipX>
			<bulletImgUrl name="BlackKnightsBulletTwo"/>
			<hitImgUrl soundUrl="boomSound/midBoom2"  shake="3,0.4,13">boomEffect/boom2</hitImgUrl><!-- 子弹图像【必备】 -->
			<hitFloorImgUrl soundUrl="boomSound/smallBoom"  shake="3,0.4,9" soundVolume="0.5">boomEffect/boom1</hitFloorImgUrl><!-- 子弹图像【必备】 -->
			<smokeImgUrl name="oreBombState"/>
		</bullet>
		
		
		<skill><!-- dps-主动 -->
			<name>throughBK</name>
			<cnName>敌人金刚钻</cnName>
			<conditionType>passive</conditionType>
			<condition>no</condition>
			<otherConditionArr>targetIsHero</otherConditionArr>
			<target>me</target>
			
			<addType>state</addType>
			<effectType>penetrationGap</effectType>
			<value>10000</value>
			<duration>0.5</duration>
			
			<stateEffectImg partType="shootPoint" con="add" raNum="30" followPartRaB="1">skillEffect/through_hero</stateEffectImg>
			<description>处于激光状态时，给敌人添加金刚钻效果。</description>
		</skill>
	</father>
</data>