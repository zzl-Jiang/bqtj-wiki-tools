<?xml version="1.0" encoding="utf-8" ?>

<!-- id是唯一识别码，必须防止和其他关卡集合重复，不设置的话默认为文件名。 -->
<data id="levelExamplePa" cnName="附身玩法" author="沃龙先生">
	<!-- 关卡集介绍。 -->
	<info>里面包含了几种玩法的关卡示例，作为参考。你还可以在底下“获取源码：关卡”中，获取其他关卡的源码进行参考。</info>
	<father name="normal" cn="关卡1-附身玩法">
		<gather>
			<level name="levelExamplePa1" cnName="我乃战神" descrip="展示附身玩法，你可以将“战神”修改成任何一个单位。">
				<!-- info参数【更多参数参考“开发文档_关卡.xls的info参数”】-->
				<info enemyLv="99" noMoreB="1" noVehicleB="1" noTreasureB="1" noPropsB="1" mustSingleB="1" noDeviceB="1" noAIB="1" />
				<!-- 场景 -->
				<sceneLabel>NanTang</sceneLabel>
				<!-- 发兵集************************************************ -->
				<unitG>
					<!-- 设置全部单位id命令为patrolGlobal（巡逻全图） -->
					<allDefault aiOrder="patrolGlobal"></allDefault>
					<!-- 创建战神的发兵集， -->
					<unitOrder id="we1" camp="we">
						<unit id="weBoss" cnName="战神" lifeMul="0.1" dpsMul="3000" skillArr="crazy_hero_14,through_hero_13,armsSpeed_jie_14" />
					</unitOrder>
					<unitOrder id="enemy1">
						<numberType>pro</numberType>
						<unit cnName="肥胖僵尸" num="6" skillArr="State_AddMove,State_AddMove50" />
						<unit cnName="战斗僵尸" num="10" skillArr="State_AddMove,State_AddMove50" />
					</unitOrder>
					<unitOrder id="enemy2">
						<unit cnName="矿工僵尸" unitType="boss" />
					</unitOrder>
					<unitOrder id="enemy3">
						<unit cnName="僵尸治疗兵" unitType="boss" />
					</unitOrder>
					<unitOrder id="enemy4">
						<unit cnName="利爪僵尸" unitType="boss" />
					</unitOrder>
					<unitOrder id="enemy5">
						<unit cnName="双头僵尸" unitType="boss" />
					</unitOrder>
					<unitOrder id="enemy6">
						<unit cnName="狂战神" unitType="boss" />
					</unitOrder>
				</unitG>
				<!-- 事件集，每个事件集内的event按照顺序运行，上个event执行结束后才会进行下一个。而事件集1和事件集2则同时运行。 -->
				<eventG>
					<group id="group1" cnName="事件集1">
						<event>
							<!-- 恢复视野为标准值，避免受到远视镜的影响 -->
							<order>sceneScale:1</order>
							<!-- 限制p1功能 -->
							<order>weAllHeroNoEquip</order>
							<order>weAllHeroNoShoot</order><order>weAllHeroNoEquip</order>
							<!-- 添加战神发兵集到r_birth（出生地） -->
							<order>createUnit:we1; r_birth</order>
							<!-- p1永久附身于战神 -->
							<order>heroEverParasitic:weBoss</order>
						</event>
						<!-- 倒计时2秒后开启对话s1，其他order命令【参考“开发文档_关卡.xls的order参数”】-->
						<event><condition delay="2"></condition><order>say; startList:s1</order></event>
						<!-- 对话结束后继续，其他condition参数【参考“开发文档_关卡.xls的condtion条件”】 -->
						<event><condition delay="0.2">say:listOver</condition></event>
						<!-- 当敌人数量少于1时，发兵enemy1在区域r123（r1、r2、r3中随机），循环执行5次 （doNumber="5"）-->
						<event>
							<condition doNumber="3">enemyNumber:less_1</condition>
							<order>createUnit:enemy1; r123</order>
						</event>
						<event><condition>enemyNumber:less_1</condition><order>createUnit:enemy2; r123</order></event>
						<event><condition>enemyNumber:less_1</condition><order>createUnit:enemy3; r123</order></event>
						<event><condition>enemyNumber:less_1</condition><order>createUnit:enemy4; r123</order></event>
						<event><condition>enemyNumber:less_1</condition><order>createUnit:enemy5; r123</order></event>
						<event><condition>enemyNumber:less_1</condition><order>createUnit:enemy6; r123</order></event>
						<!-- 倒计时1秒后开启对话s2-->
						<event>
							<condition delay="1"></condition>
							<order>say; startList:s2</order>
						</event>
						<!-- 对话完毕后显示通关箭头在区域r_over -->
						<event>
							<condition>say:listOver</condition>
							<order>level; showPointer:r_over</order>
						</event>
					</group>
					
					<!-- 判断失败的事件集。 -->
					<group id="group2"  cnName="事件集2">
						<event><condition delay="0.01">bodyEvent:die; weBoss</condition></event>
						<event><condition delay="0.05"></condition><order>alert:yes; 关卡失败！</order></event>
						<event><condition delay="0.05"></condition><order>level; fail</order></event>
					</group>
				</eventG>
			</level>
		</gather>
		<level name="levelExampleParasitic" cn="对话"><!-- name要和level 的name同名 -->
			<sayList name="s1">
				<say target="weBoss"><content>我乃氩星二太子，</content></say>
				<say target="weBoss"><content>能降妖来会作诗。</content></say>
				<say target="weBoss"><content>今日到此除奸恶，</content></say>
				<say target="weBoss"><content>尔等妖孽快受死。</content></say>
			</sayList>
			<sayList name="s2">
				<say target="weBoss"><content>真是一群菜鸟。</content></say>
			</sayList>
		</level>
	</father>	
</data>