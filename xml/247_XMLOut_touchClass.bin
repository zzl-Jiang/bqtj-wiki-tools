<?xml version="1.0" encoding="utf-8" ?>
<data>
	<father>
		<touch cnName="传送门" name="portal" ctrlCn="传送" imgType="oneEffect" imgUrl="generalEffect/portal" lockImg="glassBoomSilence" rect="-64,-120,130,120" />
		<![CDATA[<touch name="portalExit" cnName="出口" ctrlCn="离开" imgType="oneEffect" imgUrl="generalEffect/portalExit" rect="-64,-142,130,142" />]]>
		<touch cnName="已锁传送门" name="portalLock" ctrlCn="解锁" imgType="oneEffect" imgUrl="generalEffect/portalLock" rect="-64,-142,130,142" 
			keyDelay="0.2" delayShake="6"
			keyImg="misslePointer" dieImg="glassBoom" 
			/>
		
		
		<touch cnName="宝箱" name="deathBox" ctrlCn="打爆" floorB="1" imgType="oneEffect" imgUrl="NewIcon/deathBox" rect="-43,-73,80,74"
			 keyDelay="0.4" delayShake="4"
			 keyImg="misslePointer" dieImg="boxBoom"
			/>
		<touch cnName="已锁宝箱" name="deathBoxLock" ctrlCn="打爆" floorB="1"  imgType="oneEffect" imgUrl="NewIcon/deathBoxLock" rect="-43,-73,80,74" 
			 keyDelay="0.4" delayShake="4"
			 keyImg="misslePointer" dieImg="boxBoom"
			/>
		<!-- 通关速度宝箱 -->
		<touch cnName="2分钟宝箱" name="deathBoxTime2" ctrlCn="打爆" floorB="1"  imgType="oneEffect" imgUrl="NewIcon/deathBoxTime" rect="-43,-73,80,74" 
			 keyDelay="0.4" delayShake="4"
			 keyImg="misslePointer" dieImg="boxBoom"
			/>	
		<touch cnName="1分钟宝箱" name="deathBoxTime1" ctrlCn="打爆" floorB="1"  imgType="oneEffect" imgUrl="NewIcon/deathBoxTime" rect="-43,-73,80,74" 
			 keyDelay="0.4" delayShake="4"
			 keyImg="misslePointer" dieImg="boxBoom"
			/>
			
		<touch cnName="精英怪生化罐" name="superCon"  keyDelay="0.6" delayShake="4" ctrlCn="打爆" floorB="1"  imgType="oneEffect" imgUrl="NewIcon/superCon" keyImg="misslePointer" dieImg="glassBoom" dieImg2="stoneBoom" rect="-64,-142,130,142"/>
		<touch cnName="人类生化罐" name="humanCon"  keyDelay="0.6" delayShake="6" ctrlCn="打爆" floorB="1"  imgType="oneEffect" imgUrl="NewIcon/humanCon" keyImg="misslePointer" dieImg="glassBoom" dieImg2="stoneBoom" rect="-64,-142,130,142"/>
		<touch cnName="人类空生化罐" name="humanConZero" ctrlCn="重生" floorB="1"  imgType="oneEffect" imgUrl="NewIcon/humanConZero" dieImg="blackHoleDevicer_me" rect="-64,-142,130,142"/>
		<touch cnName="角色生化罐" name="humanConRole" ctrlCn="切换"  imgType="oneEffect" imgUrl="NewIcon/humanConBroken" rect="-64,-142,130,142"/>
		
		<touch cnName="发光体" name="lightKey" imgType="oneEffect" imgUrl="NewIcon/lightKey" hitSoundUrl="uiSound/moveLottery" rect="-50,-110,100,160"/>
		<touch cnName="模拟器" name="deathSim" ctrlCn="开启" imgType="oneEffect" imgUrl="NewIcon/deathSim" hitSoundUrl="uiSound/moveLottery" rect="-50,-110,100,110"/>
		<touch cnName="研究室出口" name="labExit" ctrlCn="前往并存档" imgType="oneEffect" imgUrl="NewIcon/labExit" hitSoundUrl="uiSound/mapChange" rect="-50,-130,100,130"/>
	</father>
</data>