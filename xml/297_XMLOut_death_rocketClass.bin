<?xml version="1.0" encoding="utf-8" ?>
<data>
	<father type="rocket" cnName="火炮-紫色">
		<bullet cnName="丑牛"  kind="poison" color="purple">
			<name>yearCattleDea</name>
			<cnName>滞毒·丑牛</cnName><dpsMul>0.58</dpsMul>
			<!--随机属性------------------------------------------------------------ -->
			<!--基本-->
			<capacity>166</capacity><skillArr>stopPosionDea</skillArr>
			<attackGap>0.6</attackGap><iconUrl>specialGun/yearCattleIcon</iconUrl>
			<reloadGap>1.5</reloadGap>
			<shakeAngle>0</shakeAngle>
			<bulletWidth>30</bulletWidth>
			<bulletNum>1</bulletNum>				
			<!--武器属性------------------------------------------------------------ -->
			<armsArmMul>0.65</armsArmMul>
			<upValue>5</upValue>
			<shootShakeAngle>30</shootShakeAngle>
			<shootRecoil>10</shootRecoil>
			<screenShakeValue>10</screenShakeValue>
			<!--基本属性------------------------------------------------------------ -->
			<noShakeTime>0.5</noShakeTime>
			<bulletLife>2</bulletLife>
			<hitType>rect</hitType>
			<!--运动属性------------------------------------------------------------ -->	
			<bulletSpeed>35</bulletSpeed>
			<!--图像动画属性------------------------------------------------------------ -->
			<bulletImgUrl con="add" raNum="1">specialGun/yearCattleBullet</bulletImgUrl>
			<hitImgUrl con="add" soundUrl="HugePoison/shoot_hit">boomEffect/posion1</hitImgUrl><!-- 子弹图像【必备】 -->
