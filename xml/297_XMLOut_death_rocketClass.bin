	<father name="deathArms">
		<skill name="越障麻痹">
			<name>throughWallParalysis</name><noRandomListB>1</noRandomListB>
			<cnName>越障麻痹</cnName>
			<haveEffectBuletHitNum>1</haveEffectBuletHitNum><ignoreImmunityB>1</ignoreImmunityB>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>passive</conditionType>
			<condition>hit</condition>
			<otherConditionArr>throughWall</otherConditionArr>
			<target>target</target>
			<!--效果------------------------------------------------------------ -->
			<addType>state</addType>
			<effectType>moveSpeed</effectType>
			<mul>0</mul>
			<duration>3</duration>
			<!--图像------------------------------------------------------------ --> 
			<targetEffectImg soundUrl="sound/paralysis_enemy_hit"></targetEffectImg>
			<stateEffectImg con="add" >skillEffect/paralysis_enemy</stateEffectImg>
			<description>击中目标时，如果射击者和目标隔着地形，则目标将被麻痹[duration]秒。</description>
		</skill>
		<skill name="越障增伤">
			<name>throughWallHurt</name><noRandomListB>1</noRandomListB>
			<cnName>越障增伤</cnName>
			<haveEffectBuletHitNum>1</haveEffectBuletHitNum><ignoreImmunityB>1</ignoreImmunityB>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>passive</conditionType>
			<condition>hit</condition>
			<otherConditionArr>throughWall</otherConditionArr>
			<target>target</target>
			<!--效果------------------------------------------------------------ -->
			<addType>instant</addType>
			<effectType>changeHurtAddPointEffect</effectType><changeHurtB>1</changeHurtB>
			<mul>1.8</mul>
			<!--图像------------------------------------------------------------ --> 
			<pointEffectImg name="rainBulletBoom" />
			<description>击中目标时，如果射击者和目标隔着地形，则伤害将提高[mul-1]。</description>
		</skill>
		
		
		<skill><!-- dps-被动 -->
			<name>yearRabbitDea</name><noSkillDodgeB>1</noSkillDodgeB>
			<cnName>泡泡</cnName><noRandomListB>1</noRandomListB>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>passive</conditionType>
			<condition>hit</condition>
			<target>target</target>
			<!--效果------------------------------------------------------------ -->
			<addType>state</addType>
			<effectType>yearRabbitDea</effectType><effectFather>arms</effectFather>
			<duration>3</duration>
			<!--图像------------------------------------------------------------ -->
			<stateEffectImg partType="body" con="add">specialGun/yearRabbitBuff</stateEffectImg>
			<description>用泡泡将敌人包裹住，使其飘到空中，持续[duration]秒。敌人为精英怪和首领时，持续时间减半。</description>
		</skill>
		<skill name="滞毒"><!-- dps -->
			<name>stopPosionDea</name>
			<cnName>滞毒</cnName>
