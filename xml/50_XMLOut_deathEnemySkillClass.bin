						<bulletImgUrl con="add">skillEffect/paralysis_enemy_bullet</bulletImgUrl>
						<hitImgUrl  soundUrl="sound/paralysis_enemy_hit"></hitImgUrl><!-- 子弹图像【必备】 -->
						<selfBoomImgUrl name="yearDragon_hit"/>
					</bullet>
					<skill>
						<name>paralysisDeathBullet</name>
