			<meEffectImg soundUrl="sound/paralysis_enemy_shoot"></meEffectImg>
			<pointEffectImg name="lightningVertical"/>
			<otherEffectImg name="bluePointerLine"/>
			<description>在敌人附近放置一个麻痹电球，碰撞敌人后将使其无法移动5秒（翻滚也将失效）。</description>
		</skill>
					<bullet>
						<name>paralysisDeathBullet</name>
						<cnName>麻痹电球</cnName>
						<!--伤害属性------------------------------------------------------------ -->
