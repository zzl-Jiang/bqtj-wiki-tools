<?xml version="1.0" encoding="utf-8" ?>
<data>
	<father name="enemy">
		<skill>
			<name>superFirstLost</name>
			<cnName>苏醒</cnName><everNoClearB>1</everNoClearB><noSkillDodgeB>1</noSkillDodgeB><ignoreImmunityB>1</ignoreImmunityB><ignoreNoSkillB>1</ignoreNoSkillB>
			<conditionType>passive</conditionType><noBeClearB>1</noBeClearB>
			<condition>add</condition>
			<target>me</target>
			<!--效果------------------------------------------------------------ -->
			<addType>instantAndState</addType>
			<effectType>lostCtrl</effectType>
			<duration>1</duration>
			<description>出场时需要[duration]的苏醒时间。</description>
		</skill>
		<skill>
			<name>teleportExcapeDeath</name>
			<cnName>躲藏</cnName>
			<conditionType>passive</conditionType>
			<condition>heroShootOver</condition>
			<target>me</target>
			
			<addType>instant</addType>
			<effectType>teleport</effectType>
			<valueString>farTargetMust</valueString>
			<value>400</value>
			<range>600</range>
			<meEffectImg name="teleportNew"/>
			<otherEffectImg name="teleportLine"/>
			<description>瞬间移动到视野中的任何位置。</description>
		</skill>
		
		
		
		<skill>
			<name>selfBurnDeath</name><showInLifeBarB>1</showInLifeBarB>
			<cnName>自燃</cnName><iconUrl36>SkillIcon/selfBurn_hero_36</iconUrl36>
			<conditionType>passive</conditionType>
			<condition>interval</condition>
			<target>me,range,enemy</target>
			
			<addType>instant</addType>
			<effectType>normal_hurt</effectType>
			<extraValueType>producterDpsFactor</extraValueType>
			<mul>0.15</mul>
			<duration>0.3</duration>
			<range>100</range>
			
			<addSkillEffectImg name="selfBurn_task_add"/>
			<targetEffectImg name="Nian_change_link_target"/>
			<description>释放技能后，单位全身燃起熊熊烈火，对附近[range]范围内的敌人造成伤害。</description>
		</skill>
		
		<skill>
			<name>teleportDeath</name><showInLifeBarB>1</showInLifeBarB>
			<cnName>瞬移</cnName><iconUrl36>SkillIcon/flash_pet_36</iconUrl36>
			<cd>5</cd>
			<conditionType>active</conditionType>
			<condition>avtiveSkillCdOver</condition>
			<otherConditionArr>awayAttackTarget</otherConditionArr>
			<conditionRange>200</conditionRange>
			<target>me</target>
			
			<addType>instant</addType>
			<effectType>teleport</effectType>
			<value>150</value><!-- 瞬移到目标面前100的距离 -->
			<valueString>attackTarget</valueString>
			<meEffectImg name="teleportNew"/>
			<otherEffectImg name="teleportLine"/>
			<description>瞬间移动到目标的前方。</description>
		</skill>
		
		<skill>
			<name>fastForwardDeath</name>
			<cnName>快进</cnName><showInLifeBarB>1</showInLifeBarB><wantDescripB>1</wantDescripB>
			<!--英雄技能属性------------------------------------------------------------ -->
			<cd>3</cd><iconUrl36>SkillIcon/flash_pet_36</iconUrl36>
			<conditionType>active</conditionType>
			<condition>avtiveSkillCdOver</condition>
			<otherConditionArr>followingTarget</otherConditionArr>
			<target>me</target>
			<addType>instant</addType>
			<effectType>fastForward</effectType>
			<meEffectImg name="dinosaurEgg_me"/>
			<otherEffectImg name="teleportLine"/>
			<description>减少移动路程。</description>
		</skill>
		<skill>
			<name>pointerMissile</name><showInLifeBarB>1</showInLifeBarB>
			<cnName>指向导弹</cnName><iconUrl36>SkillIcon/moreMissile_hero_36</iconUrl36>
			<!--英雄技能属性------------------------------------------------------------ -->
			<cd>5</cd>
			<conditionType>active</conditionType>
			<condition>avtiveSkillCdOver</condition>
			<otherConditionArr>nearAttackTarget</otherConditionArr>
			<conditionRange>1400</conditionRange>
			<target>me</target>
			<addType>instant</addType>
			<effectType>bullet</effectType>
			<extraValueType>targetDpsFactor</extraValueType><!-- 附加值类型为当前武器dps比例 -->
			<!-- 子弹所需 -->
			<obj>"name":"pointerMissileBullet","site":"lifeBar","flipB":true</obj>
			<![CDATA[sound/moreMissile_hero]]>
			<meEffectImg name="misslePointerSound"/>
			<pointEffectImg name="misslePointer"/>
			<description>。</description>
		</skill>
					<bullet>
						<name>pointerMissileBullet</name><hurtRatio>2.4</hurtRatio> 
						<bulletNum>1</bulletNum>
						<shakeAngle>15</shakeAngle><bulletAngle>-90</bulletAngle>
						<bulletLife>4</bulletLife><bulletWidth>30</bulletWidth>
						<hitType>rect</hitType>
						<shootPoint>0,0</shootPoint>
						<penetrationGap>1000</penetrationGap>
						<bulletSkillArr>pointerMissileLAST</bulletSkillArr>
						<followD value="2" delay="0.8" />
						<boomD selfB="1" bodyB="1" radius="120" />
						<noHitTime>1</noHitTime>
						<!--运动属性------------------------------------------------------------ -->	
						<bulletSpeed>10</bulletSpeed>
						<speedD max="40" min="1" a="-5"/>
						
						<bulletImgUrl name="fightBackBullet_bullet"/>
						<hitImgUrl name="midSpaceQuietly"/><!-- 子弹图像【必备】 -->
						<smokeImgUrl name="rocketSmokeSm"/><!-- 子弹尾烟效果（默认为空） -->
					</bullet>	
					
		<skill>
			<name>rotatingLightning</name><showInLifeBarB>1</showInLifeBarB>
			<cnName>旋转闪电</cnName><iconUrl36>SkillIcon/laser_PetFightWolf_36</iconUrl36>
			<cd>9999999</cd>
			<firstCd>9999999</firstCd>
			<conditionType>active</conditionType>
			<condition>avtiveSkillCdOver</condition>
			<otherConditionArr>nearAttackTarget</otherConditionArr>
			<conditionRange>1000</conditionRange>
			
			<target>me</target>
			<addType>instant</addType>
			<effectType>bullet</effectType>
			<extraValueType>targetDpsFactor</extraValueType>
			<!-- 子弹所需 -->
			<obj>"name":"rotatingLightningBullet"</obj>
			<description>。</description>
		</skill>	
				<bullet>
					<name>rotatingLightningBullet</name>
