					<hurtRatio>0.25</hurtRatio>
					<bulletSkillArr>rotatingLightningLEN</bulletSkillArr>
					<bulletAngle>0</bulletAngle><bulletLife>9999999</bulletLife><bulletWidth>530</bulletWidth><hitType>longLine</hitType>	
