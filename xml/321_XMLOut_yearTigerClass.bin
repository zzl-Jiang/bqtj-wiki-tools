<?xml version="1.0" encoding="utf-8" ?>
<data>
	<![CDATA[七周年已添加]]>
	<father type="cutter" cnName="切割枪">
		<bullet name="yearTiger" color="darkgold" composeLv="99" dropLevelArr="999" evoMaxLv="2">
			<name>yearTiger</name>
			<cnName>寅虎</cnName><extraMul>1.6</extraMul>
			<whippB>0</whippB><noBeClearB>1</noBeClearB>
			<dpsMul>1.9</dpsMul>
			<uiDpsMul>2.3</uiDpsMul>
			<!--基本-->
			<capacity>8</capacity>
			<attackGap>0.8</attackGap>
			<reloadGap>2</reloadGap>
			<shakeAngle>1</shakeAngle>
			<bulletWidth>30</bulletWidth>
			<bulletShakeWidth>0,0</bulletShakeWidth>
			<bulletNum>1</bulletNum>				
			<!--特殊------------------------------------------------------------ -->
			<twoShootPro>0.3</twoShootPro>
			<penetrationNum>4</penetrationNum>
			<penetrationGap>1000</penetrationGap>
			<bounceD floor="0" body="0"/>	<!-- 反弹 -->
			<critD mul="0" pro="0"/>
			<followD value="4" delay="999" hitIsTargetB="1" />
			
			<skillArr>Hit_Spurting_ArmsSkill,Hit_AddLifeMul_ArmsSkill</skillArr>
			<godSkillArr>yearTigerSkill,yearTigerHurtSuper</godSkillArr>
			<!--武器属性------------------------------------------------------------ -->
			<bulletSpeed>25</bulletSpeed>
			<hurtRatio>4</hurtRatio>
			<gunNum>1</gunNum>
			<armsArmMul>0.5</armsArmMul>
			<armsWeight>5</armsWeight>
			<upValue>15</upValue>
			
			<shootShakeAngle>40</shootShakeAngle>
			<shootRecoil>10</shootRecoil>
			<screenShakeValue>15</screenShakeValue>
			<!--基本属性------------------------------------------------------------ -->
			<noShakeTime>0.5</noShakeTime>
			<bulletLife>7</bulletLife>
			<hitType>rect</hitType>
			<!--图像动画属性------------------------------------------------------------ -->
			<iconUrl>specialGun/yearTigerIcon</iconUrl>
			<shootSoundUrl>specialGun/yearTigerSound</shootSoundUrl>
			<flipX>1</flipX>
			<bulletImgUrl con="add" raNum="30">specialGun/yearTigerBullet</bulletImgUrl>
			<hitImgUrl con="add">bulletHitEffect/fitHit</hitImgUrl>
			<fireImgType></fireImgType>
			<!--图像范围------------------------------------------------------------ -->
			<bodyImgRange>specialGun/yearTiger</bodyImgRange>
			<bulletImgRange>specialGun/bullet</bulletImgRange>
			<description></description>
		</bullet>
	</father>
	<father name="godArmsSkill" cnName="神级武器技能">
		
		<skill>
			<name>yearTigerSkill</name><noRandomListB>1</noRandomListB>
			<cnName>虎刃</cnName>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>passive</conditionType>
			<condition>hit</condition>
			<target>me</target>
			<!--效果------------------------------------------------------------ -->
			<addType>state</addType>
			<effectType>attackGapMul</effectType>
			<mul>1.4</mul>
			<duration>5</duration>
			<description>发射出的利刃将不断切割敌人，最多切割4下，无视刚体。击中敌人后将提高[mul-1]的武器射速。</description>
		</skill>
		<skill>
			<name>yearTigerPurgold</name><noRandomListB>1</noRandomListB>
			<cnName>穿甲虎刃</cnName>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>passive</conditionType>
			<condition>hit</condition>
			<target>me</target>
			<!--效果------------------------------------------------------------ -->
			<addType>state</addType>
			<effectType>attackGapMul</effectType>
			<mul>1.4</mul>
			<duration>5</duration>
			<description>发射出的利刃将不断切割敌人，最多切割12下，无视刚体、防弹外壳、防弹钢甲。击中敌人后将提高[mul-1]的武器射速。</description>
		</skill>
		
		
		
		
		
		<skill index="0" name="精英之殇"><!-- dps-被动 -->
			<name>yearTigerHurtSuper</name><noRandomListB>1</noRandomListB>
			<cnName>精英之殇</cnName><ignoreImmunityB>1</ignoreImmunityB><noSkillDodgeB>1</noSkillDodgeB>
			<changeHurtB>1</changeHurtB>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>passive</conditionType>
			<condition>hit</condition>
			<target>target</target>
			<!--效果------------------------------------------------------------ -->
			<addType>instant</addType>
			<effectType>yearTigerHurtSuper</effectType>
			<mul>3</mul>
			<secMul>1.6</secMul>
			<!--图像------------------------------------------------------------ -->
			<description>对精英怪物造成的伤害提高[mul-1]，对首领的伤害提高[secMul-1]。</description>
		</skill>
	</father>
	
</data>