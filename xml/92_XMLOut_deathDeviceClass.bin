<?xml version="1.0" encoding="utf-8" ?>
<data>
	<father name="deathDevice" cnName="装置">
		<equip rareB="1" name="timeCapsuleS" cnName="悬停沙漏S" skill="timeCapsuleS" iconLabel="ThingsIcon/timeCapsule" />
		<equip rareB="1" name="shuttleDevicerS" cnName="镭射穿梭器S" skill="shuttleDevicerS" iconLabel="ThingsIcon/shuttleDevicer" />
		<equip rareB="1" name="earthquakeS" cnName="地震发生器S" skill="earthquakeS" iconLabel="ThingsIcon/earthquakeGenerator"/>
		<equip rareB="1" name="lightningTowerS" cnName="闪电塔S" skill="lightningTowerS" iconLabel="ThingsIcon/lightningTower"/>
		
		<equip rareB="1" name="energyShieldS" cnName="能量外壳S" skill="energyShieldS"  iconLabel="ThingsIcon/energyShield"/>
		<equip rareB="1" name="electricDevicerS" cnName="全域电击器S" skill="electricDevicerS" iconLabel="ThingsIcon/electricDevicer"/>
		<equip rareB="1" name="blackHoleDevicerS" cnName="黑洞发生器S" skill="blackHoleDevicerS" iconLabel="ThingsIcon/blackHoleDevicer"/>
		<equip rareB="1" name="dinosaurEggS" cnName="异龙蛋S" skill="dinosaurEggS" iconLabel="ThingsIcon/dinosaurEgg"/>
		<equip rareB="1" name="skeletonWandS" cnName="骷髅权杖S" skill="skeletonWandS" iconLabel="ThingsIcon/skeletonWand"/>
		<equip rareB="1" name="hurtMineS" cnName="致命地雷S" skill="hurtMineS" iconLabel="dropEffect/hurtMine" />
		<![CDATA[
		<equip rareB="1" name="hammerMineS" cnName="眩晕地雷S" skill="hammerMineS" iconLabel="dropEffect/hammerMine" />
		]]>
	</father>
	
	<father name="deviceSkill" cnName="装置技能">
		<skill name="悬停沙漏">
			<name>timeCapsuleS</name>
			<cnName>悬停沙漏</cnName>
			<!--英雄技能属性------------------------------------------------------------ -->
			<cd>41</cd>
			<changeText>持续时间：[duration]秒</changeText>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>active</conditionType>
			<condition>no</condition>
			<target>me</target>
			<!--效果------------------------------------------------------------ -->
			<addType>state</addType><stateType>time</stateType>
			<effectType>timeCapsule</effectType>
			<mul>1</mul>
			<duration>4</duration>
			<!--图像------------------------------------------------------------ -->
			<meEffectImg name="timeCapsule"/>
			<stateEffectImg name="timeCapsuleState"/>
			<description>让周围的时间停止下来，持续[duration]秒。期间再次按下装置键，可结束时间停止。</description>
			<!-- 技能各等级 ------------------------------------------------------------ -->
			<growth>
				<skill><duration>4.7</duration></skill>
				<skill><duration>5.8</duration></skill>
				<skill><duration>7</duration></skill>
			</growth>
		</skill>
		
		<skill cnName="镭射穿梭器S">
			<name>shuttleDevicerS</name>
			<cnName>穿梭</cnName>
			<!--英雄技能属性------------------------------------------------------------ -->
			<cd>9</cd>
			<changeText>技能冷却时间：[cd]秒</changeText>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>active</conditionType>
			<condition>avtiveSkillCdOver</condition>
			<target>me</target>
			<!--效果------------------------------------------------------------ -->
			<addType>state</addType>
			<effectType>shuttleDevicerS</effectType>
			<valueString>mousePoint</valueString>
			<duration>1</duration>
			<!--图像------------------------------------------------------------ -->
			<meEffectImg name="teleportNew"/>
			<otherEffectImg name="teleportLine"/>
			<stateEffectImg con="add">skillEffect/energyShield</stateEffectImg>
			<description>通过镭射器，穿梭到鼠标所在的位置并且无敌[duration]秒。</description>
			<!-- 技能各等级 ------------------------------------------------------------ -->
			<growth>
				<skill><cd>9</cd></skill>
				<skill><cd>7</cd></skill>
				<skill><cd>5</cd></skill>
			</growth>
		</skill>
		
		<skill name="地震发生器S">
			<name>earthquakeS</name>
			<cnName>地震</cnName>
			<!--英雄技能属性------------------------------------------------------------ -->
			<cd>50</cd>
			<changeText>持续时间：[duration]秒</changeText>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>active</conditionType>
			<condition>avtiveSkillCdOver</condition>
			<otherConditionArr>nearAttackTarget</otherConditionArr>
			<conditionRange>400</conditionRange>
			<target>me,range,enemy</target>
			<!--效果------------------------------------------------------------ -->
			<addType>instantAndState</addType>
			<effectType>dizziness</effectType>
			<duration>1</duration>
			<range>99999</range>
			<!--图像------------------------------------------------------------ -->
			<meEffectImg name="earthquake_me"/>
			<stateEffectImg partType="mouth" con="add">skillEffect/dizziness</stateEffectImg>
			<description>释放一次强烈地震，使周围所有敌人进入眩晕状态，持续[duration]秒。</description>
			<!-- 技能各等级 ------------------------------------------------------------ -->
			<growth>
				<skill><duration>4</duration></skill>
				<skill><duration>5</duration></skill>
				<skill><duration>6</duration></skill>
			</growth>
		</skill>
		
		<skill cnName="闪电塔S">
			<name>lightningTowerS</name>
			<cnName>召唤闪电塔</cnName>
			<!--英雄技能属性------------------------------------------------------------ -->
			<cd>47</cd>
			<changeText>技能冷却时间：[duration]秒</changeText>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>active</conditionType>
			<condition>avtiveSkillCdOver</condition>
			<otherConditionArr>nearAttackTarget</otherConditionArr>
			<conditionRange>200</conditionRange>
			<target>me</target>
			<!--效果------------------------------------------------------------ -->
			<addType>instant</addType>
			<effectType>summonedUnits</effectType>
			<extraValueType>dpsFactorAll</extraValueType>
			<!-- 子弹所需 -->
			<obj>"cnName":"闪电塔","num":1,"lifeMul":1,"dpsMul":0.5,"maxNum":1,"cx":0,"cy":-30,"mulByFatherB":true,"existB":false</obj>
			<duration>15</duration>
			<!--图像------------------------------------------------------------ -->
			<meEffectImg soundUrl="sound/changeToZombie_enemy" con="add">boomEffect/showLight</meEffectImg>
			<description>召唤出一座闪电塔，每隔1秒自动攻击周围的敌人，伤害值与角色伤害相关。闪电塔[duration]秒后消失。</description>
			
			<growth>
				<skill><cd>47</cd></skill>
				<skill><cd>38</cd></skill>
				<skill><cd>31</cd></skill>
			</growth>
		</skill>
		
		
		<skill cnName="能量外壳S">
			<name>energyShieldS</name>
			<cnName>能量外壳</cnName>
			<!--英雄技能属性------------------------------------------------------------ -->
			<cd>40</cd>
			<changeText>持续时间：[duration]秒</changeText>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>active</conditionType>
			<condition>avtiveSkillCdOver</condition>
			<otherConditionArr>weLifePerLess,attackTargetNoSameInvi</otherConditionArr>
			<conditionRange>0.3</conditionRange>
			<target>me,range,we</target>
			<!--效果------------------------------------------------------------ -->
			<addType>state</addType>
			<effectType>energyShield</effectType>
			<duration>4</duration>
			<range>500</range>
			<!--图像------------------------------------------------------------ -->
			<meEffectImg soundUrl="sound/energyShield"></meEffectImg>
			<stateEffectImg con="add">skillEffect/energyShield</stateEffectImg>
			<description>使周围[range]码内的友方单位获得能量外壳，能量外壳能抵挡任何伤害。持续[duration]秒。</description>
			<!-- 技能各等级 ------------------------------------------------------------ -->
			<growth>
				<skill><duration>4</duration></skill>
				<skill><duration>5</duration></skill>
				<skill><duration>6</duration></skill>
			</growth>
		</skill>
		<skill cnName="全域电击器S">
			<name>electricDevicerS</name>
			<cnName>全域电击</cnName>
			<noBeClearB>1</noBeClearB>
			<!--英雄技能属性------------------------------------------------------------ -->
			<cd>25</cd>
			<changeText>持续时间：[duration]秒</changeText>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>active</conditionType>
			<condition>avtiveSkillCdOver</condition>
			<target>me,range,enemy</target>
			<!--效果------------------------------------------------------------ -->
			<addType>state</addType>
			<effectType>electricDevicerS</effectType>
			<duration>4</duration>
			<value>0</value>
			<mul>0</mul>
			<secMul>0.75</secMul>
			<range>99999</range>
			<!--图像------------------------------------------------------------ -->
			<meEffectImg soundUrl="sound/paralysis_enemy_shoot"></meEffectImg>
			<targetEffectImg con="add">skillEffect/electricDevicer</targetEffectImg>
			<stateEffectImg con="add" soundUrl="sound/paralysis_enemy_hit">skillEffect/paralysis_enemy</stateEffectImg>
			<description>向大地释放强大的电流，使地图上的所有敌人无法移动，并降低[1-secMul]的防御力，持续[duration]秒。此效果不会被净化技能净化。</description>
			<!-- 技能各等级 ------------------------------------------------------------ -->
			<growth>
				<skill><duration>4</duration></skill>
				<skill><duration>5</duration></skill>
				<skill><duration>6</duration></skill>
			</growth>
		</skill>
		<skill cnName="黑洞发生器S">
			<name>blackHoleDevicerS</name>
			<cnName>黑洞</cnName>
			<!--英雄技能属性------------------------------------------------------------ -->
			<cd>9</cd>
			<changeText>技能冷却时间：[cd]秒</changeText>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>active</conditionType>
			<condition>avtiveSkillCdOver</condition>
			<doCondition>haveEnemyClearBulletRange</doCondition>
			<target>me</target>
			<!--效果------------------------------------------------------------ -->
			<addType>instant</addType>
			<effectType>blackHoleDevicerS</effectType>
			<value>1</value>
			<range>2000</range>
			<!--图像------------------------------------------------------------ -->
			<meEffectImg soundUrl="sound/invisibility_hero" partType="body">generalEffect/blackHoleHide</meEffectImg>
			<pointEffectImg name="empNoSound"/>
			<description>清空全地图所有敌人子弹（除非是不可清除的子弹）。</description>
			<!-- 技能各等级 ------------------------------------------------------------ -->
			<growth>
				<skill><cd>9</cd></skill>
				<skill><cd>7</cd></skill>
				<skill><cd>5</cd></skill>
			</growth>
		</skill>
		<skill cnName="异龙蛋S"><!-- dps -->
			<name>dinosaurEggS</name>
			<cnName>异龙蛋</cnName>
			<summonedUnits>1</summonedUnits>
			<!--英雄技能属性------------------------------------------------------------ -->
			<cd>35</cd>
			<changeText>技能冷却时间：[cd]秒</changeText>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>active</conditionType>
			<condition>avtiveSkillCdOver</condition>
			<otherConditionArr>nearAttackTarget</otherConditionArr>
			<conditionRange>700</conditionRange>
			<target>me</target>
			<!--效果------------------------------------------------------------ -->
			<addType>instant</addType>
			<effectType>summonedUnits</effectType>
			<mul>1</mul>
			<obj>"cnName":"无敌异龙蛋","num":1,"lifeMul":1000,"cx":-50,"cy":-50,"maxNum":10,"noUnderHurtB":1,"noAiFindB":1,"skillArr":["trueshot_eeg"]</obj>
			<duration>10</duration>
			<!--图像------------------------------------------------------------ -->
			<meEffectImg soundUrl="sound/teleport_enemy" con="add"></meEffectImg>
			<description>产生一个无敌的异龙蛋抵挡敌人的伤害，持续[duration]秒。在异龙蛋附近400码内可获得10%的攻击力加成。</description>
			<!-- 技能各等级 ------------------------------------------------------------ -->
			<growth>
				<skill><cd>42</cd></skill>
				<skill><cd>35</cd></skill>
				<skill><cd>27</cd></skill>
			</growth>
		</skill>
		<skill cnName="骷髅权杖S"><!-- 限制 -->
			<name>skeletonWandS</name>
			<cnName>骷髅权杖</cnName>
			<!--英雄技能属性------------------------------------------------------------ -->
			<cd>38</cd>
			<changeText>技能冷却时间：[cd]</changeText>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>active</conditionType>
			<condition>avtiveSkillCdOver</condition>
			<otherConditionArr>nearAttackTarget</otherConditionArr>
			<conditionRange>600</conditionRange>
			<target>me</target>
			<!--效果------------------------------------------------------------ -->
			<addType>instant</addType>
			<effectType>bullet</effectType>
			<!-- 子弹所需 -->
			<obj>"name":"skeletonWandBullet","site":"me","flipB":true</obj>
			<!--图像------------------------------------------------------------ -->
			<meEffectImg soundUrl="sound/lifeReplace_enemy"></meEffectImg>
			<description>发出亡命之光，对目标造成其当前生命值10%的伤害，无视技能免疫；如果击中小怪，则直接秒杀。</description>
			<growth>
				<skill><cd>38</cd></skill>
				<skill><cd>30</cd></skill>
				<skill><cd>25</cd></skill>
			</growth>
		</skill>
		<skill cnName="致命地雷S">
			<name>hurtMineS</name>
			<cnName>致命地雷</cnName>
			<!--英雄技能属性------------------------------------------------------------ -->
			<cd>37</cd>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>active</conditionType>
			<condition>avtiveSkillCdOver</condition>
			<doCondition>nearNoMine</doCondition>
			<target>me</target>
			<!--效果------------------------------------------------------------ -->
			<addType>instant</addType>
			<effectType>bullet</effectType>
			<extraValueType>dpsFactorAll</extraValueType>
			<mul>5</mul>
			<obj>"name":"hurtMineBullet","site":"meMid","minYB":true</obj>
			<!--图像------------------------------------------------------------ -->
			<meEffectImg name="putMineEffect"/>
			<description>埋下可敌人造成重大伤害的致命地雷。</description>
			<!-- 技能各等级 ------------------------------------------------------------ -->
			<growth>
				<skill><cd>37</cd></skill>
				<skill><cd>30</cd></skill>
				<skill><cd>25</cd></skill>
			</growth>
		</skill>
		
		<skill cnName="眩晕地雷S">
			<name>hammerMineS</name>
			<cnName>眩晕地雷</cnName>
			<!--英雄技能属性------------------------------------------------------------ -->
			<cd>37</cd>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>active</conditionType>
			<condition>avtiveSkillCdOver</condition>
			<doCondition>nearNoMine</doCondition>
			<target>me</target>
			<!--效果------------------------------------------------------------ -->
			<addType>instant</addType>
			<effectType>bullet</effectType>
			<extraValueType>dpsFactorAll</extraValueType>
			<obj>"name":"hammerMineBullet","site":"meMid","minYB":true</obj>
			<!--图像------------------------------------------------------------ -->
			<meEffectImg name="putMineEffect"/>
			<description>埋下可眩晕敌人5秒的眩晕地雷。</description>
			<!-- 技能各等级 ------------------------------------------------------------ -->
			<growth>
				<skill><cd>37</cd></skill>
				<skill><cd>30</cd></skill>
				<skill><cd>25</cd></skill>
			</growth>
		</skill>
	</father>
</data>