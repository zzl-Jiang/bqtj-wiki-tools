<?xml version="1.0" encoding="utf-8" ?>
<data>
	<father name="pet" cnName="尸宠">
		<body name="勇者兔"  shell="metal">
			
			<name>DollRabbit</name>
			<cnName>勇者兔</cnName>
			<raceType>robot</raceType>
			<swfUrl>swf/pet/DollRabbit.swf</swfUrl>
			<!-- 基本系数 -->
			<lifeRatio>1</lifeRatio>
			<!-- 图像 -->
			<headIconUrl>BodyImg/DollRabbit_icon</headIconUrl>
			<imgType>bmp</imgType>
			<imgArr>
				stand,move,run
				,shootAttack,shellingAttack
				,hurt1,die1
				,__jumpUp,jumpUp,jumpUp__jumpDown,jumpDown,jumpDown__
				,__fill1_Up,fill1_Up,fill1_Up__fill1_Down,fill1_Down,fill1_Down__die1
			</imgArr>
			<!-- 碰撞体积 -->
			<hitRect>-14,-76,28,76</hitRect>
			<!-- 运动 -->
			<maxJumpNum>1</maxJumpNum>
			<runStartVx>8</runStartVx>
			<maxVx>8</maxVx>
			<!-- AI属性 -->
			<nextAttackTime>0</nextAttackTime>
			<extraAIClassLabel></extraAIClassLabel>
			<!-- 攻击数据 -->
			<hurtArr>
				<hurt><cn>炮击</cn>
					<imgLabel>shootAttack</imgLabel>
					<hurtRatio>2</hurtRatio>
					<bulletLabel>DollRabbit_1</bulletLabel>
					<grapRect>-631,-166,476,318</grapRect>
				</hurt>
				<hurt info="不加入ai选择-炮轰">
					<imgLabel>shellingAttack</imgLabel><noAiChooseB>1</noAiChooseB>
					<bulletLabel>DollRabbitShelling</bulletLabel>
					<grapRect>-400,-111,100,105</grapRect>
					<hurtRatio>2</hurtRatio>
				</hurt>
			</hurtArr>
		</body>	
	</father>
	<father type="pet" cnName="勇者兔">
		<bullet>
			<name>DollRabbit_1</name>
			<cnName>勇者兔-射击</cnName><noMagneticB>1</noMagneticB>
			<!--基本属性------------------------------------------------------------ -->
			<bulletLife>3</bulletLife>
			<bulletWidth>40</bulletWidth>
			<hitType>rect</hitType>
			<!--攻击时的属性------------------------------------------------------------ -->
			<attackGap>0.6</attackGap>
			<attackDelay>0.3</attackDelay>
			<bulletAngle>180</bulletAngle>
			<bulletAngleRange>30</bulletAngleRange>
			<bulletNum>1</bulletNum>				
			<!--特殊属性------------------------------------------------------------ -->	
			<penetrationGap>1000</penetrationGap>
			<!--运动属性------------------------------------------------------------ -->	
			<shootPoint>-38,-25</shootPoint>
			<bulletSpeed>25</bulletSpeed>
			<followD value="0.5" noLM="1" />	<!-- 跟踪 -->
			<!--图像动画属性------------------------------------------------------------ -->
			<flipX>1</flipX>
			<bulletImgUrl name="DollRabbit_1"/>
			<hitImgUrl name="DollRabbitHit"/><!-- 子弹图像【必备】 -->
		</bullet>
		<bullet cnName="勇者兔-炮轰">
			<name>DollRabbitShelling</name>
			<cnName>勇者兔-炮轰</cnName><noMagneticB>1</noMagneticB>
			<!--基本属性------------------------------------------------------------ -->
			<bulletLife>3</bulletLife>
			<bulletWidth>40</bulletWidth>
			<hitType>rect</hitType>
			<!--攻击时的属性------------------------------------------------------------ -->
			<attackGap>0.9</attackGap>
			<attackDelay>0.5</attackDelay>
			<bulletAngle>120</bulletAngle>
			<bulletAngleRange>10</bulletAngleRange>
			
			<shootAngle>10</shootAngle>
			<bulletNum>2</bulletNum>				
			<shootNum>3</shootNum>	
			<shootGap>0.166</shootGap>
			<!--特殊属性------------------------------------------------------------ -->	
			<penetrationGap>1000</penetrationGap>
			<!--运动属性------------------------------------------------------------ -->	
			<shootPoint>0,-175</shootPoint>
			<bulletSpeed>25</bulletSpeed>
			<followD value="1" noLM="1" />	<!-- 跟踪 -->
			<!--图像动画属性------------------------------------------------------------ -->
			<flipX>1</flipX>
			<bulletImgUrl name="DollRabbit_1"/>
			<hitImgUrl name="DollRabbitHit"/><!-- 子弹图像【必备】 -->
		</bullet>
	</father>	
	<father name="petBodySkill">
		<skill>
			<name>DollRabbitShelling</name>
			<cnName>炮轰</cnName>
			<showInLifeBarB>1</showInLifeBarB><everNoClearB>1</everNoClearB>
			<changeText>技能冷却时间：[cd]秒</changeText>
			<cd>40</cd>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>active</conditionType>
			<condition>avtiveSkillCdOver</condition>
			<otherConditionArr>nearAttackTarget</otherConditionArr>
			<conditionRange>1000</conditionRange>
			<target>me</target>
			<!--效果------------------------------------------------------------ -->
			<addType>state</addType>
			<effectType>invincibleAndThrough</effectType>
			<duration>1.3</duration>
			<!--图像------------------------------------------------------------ --> 
			<meActionLabel>shellingAttack</meActionLabel>
			<description>腾空而起，对目标发起多次火炮攻击，造成巨大伤害。</description>
			<growth>
				<skill><cd>40</cd></skill>
				<skill><cd>36</cd></skill>
				<skill><cd>32</cd></skill>
				<skill><cd>28</cd></skill>
				<skill><cd>24</cd></skill>
				<skill><cd>20</cd></skill>
				<skill><cd>16</cd></skill>
				<skill><cd>13</cd></skill>
				<skill><cd>10</cd></skill>
			</growth>
		</skill>
		
		<skill>
			<name>dpsConnect</name>
			<cnName>战力链接</cnName><noCopyB>1</noCopyB>
			<showInLifeBarB>1</showInLifeBarB>
			<changeText>伤害倍数系数：[value]</changeText>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>passive</conditionType>
			<condition>hit</condition>
			<otherConditionArr>isMeHurt</otherConditionArr>
			
			<target>me</target>
			<!--效果------------------------------------------------------------ -->
			<addType>instant</addType>
			<effectType>dpsConnect</effectType>
			<value>0.2</value>
			<description>自身普攻或炮轰时，都会获得主人的战力增伤，增伤倍数=[value]x主人最高武器面板战斗力÷5亿。</description>
			<growth>
				<skill><value>0.2</value></skill>
				<skill><value>0.4</value></skill>
				<skill><value>0.6</value></skill>
				<skill><value>0.8</value></skill>
				<skill><value>1</value></skill>
				<skill><value>1.2</value></skill>
				<skill><value>1.4</value></skill>
				<skill><value>1.7</value></skill>
				<skill><value>2</value></skill>
			</growth>
		</skill>
		
		<skill name="合金外壳">
			<name>alloyShellP</name>
			<cnName>合金外壳</cnName>
			<iconUrl>SkillIcon/alloyShell</iconUrl>
			<!--英雄技能属性------------------------------------------------------------ -->
			<changeText>减少[1-mul]百分比伤害</changeText>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>passive</conditionType>
			<condition>underHit</condition>
			<target>me</target>
			<addType>instant</addType>
			<effectType>changeHurtMul</effectType>
			<mul>0.91</mul>
			<description>减少[1-mul]受到的百分比伤害。</description>
			<!-- 技能各等级 ------------------------------------------------------------ -->
			<growth>
				<skill><mul>0.91</mul></skill>
				<skill><mul>0.82</mul></skill>
				<skill><mul>0.73</mul></skill>
				<skill><mul>0.64</mul></skill>
				<skill><mul>0.55</mul></skill>
				<skill><mul>0.46</mul></skill>
				<skill><mul>0.37</mul></skill>
				<skill><mul>0.28</mul></skill>
				<skill><mul>0.10</mul></skill>
			</growth>
		</skill>
	</father>
</data>