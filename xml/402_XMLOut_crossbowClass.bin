<?xml version="1.0" encoding="utf-8" ?>
<data>
	<father type="crossbow" cnName="弩">
		<bullet index="23" name="银蛇" color="red" rareDropLevel="76">
			<name>snakeCrossbow</name><cnName>银蛇</cnName>
			<dpsMul>3.2</dpsMul>
			<!--基本-->
			<capacity>14,17</capacity>
			<attackGap>1.5</attackGap>
			<reloadGap>2,2.5</reloadGap>
			<shakeAngle>0,0</shakeAngle>
			<bulletWidth>20</bulletWidth>
			<bulletShakeWidth>0,0</bulletShakeWidth>
			<bulletNum>1</bulletNum>				
			<shootAngle>3,5</shootAngle>
			<!--武器属性------------------------------------------------------------ -->
			<armsArmMul>0.5</armsArmMul><upValue>10</upValue><shootShakeAngle>30</shootShakeAngle><shootRecoil>7</shootRecoil><screenShakeValue>10</screenShakeValue>
			<!--基本属性------------------------------------------------------------ -->
			<noShakeTime>0.5</noShakeTime><bulletLife>2.5</bulletLife>
			<hitType>rect</hitType>
			<!--运动属性------------------------------------------------------------ -->	
			<bulletSpeed>40</bulletSpeed>
			<!--特殊------------------------------------------------------------ -->	
			<attackDelay>1.5</attackDelay>
			<crossbowD focoB="1" minDelayMul="0.2"/>
			<godSkillArr>Hit_crazy_godArmsSkill,combo_ArmsSkill</godSkillArr>
			<!--图像动画属性------------------------------------------------------------ -->
			<shootSoundUrl>specialGun/arrowAttack</shootSoundUrl>
			<bulletImgUrl name="snakeCrossbow_bullet"/>
			<hitImgUrl soundUrl="specialGun/arrowImpact">bulletHitEffect/yellow_motion</hitImgUrl><!-- 子弹图像【必备】 -->
			<hitFloorImgUrl>bulletHitEffect/yellow_motion</hitFloorImgUrl><!-- 子弹图像【必备】 -->
			<smokeImgUrl raNum="30" con="filter">bulletHitEffect/smoke_small2</smokeImgUrl><!-- 子弹尾烟效果（默认为空） -->
			<fireImgType>no</fireImgType>
			<!--图像范围------------------------------------------------------------ -->
			<bodyImgRange>specialGun/snakeCrossbow</bodyImgRange><bulletImgRange>specialGun/bullet</bulletImgRange>
			<description>76级以上关卡和每周任务(武器-处决)</description>
		</bullet>
