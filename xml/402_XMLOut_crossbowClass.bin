		<bullet index="0" name="烟花弩" kind="boom" color="black" dropLevelArr="999"  evoB="0" composeLv="86" chipNum="180">
			<name>beadCrossbow</name><cnName>烟花弩</cnName>
			<dpsMul>3.2</dpsMul>
