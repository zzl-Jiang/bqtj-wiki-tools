<?xml version="1.0" encoding="utf-8" ?>
<data>
	<father type="howitzer">
		<bullet color="purgold">
			<name>extremeLightning</name><![CDATA[ 该武器英文名不可修改]]>
			<cnName>闪电极源</cnName><noMagneticB>1</noMagneticB><noBeClearB>1</noBeClearB>
			<aiShootRange>800</aiShootRange><!-- ai射程 -->
			<attackType>holy</attackType>
			<dpsMul>1</dpsMul>
			<!--基本-->
			<capacity>30</capacity>
			<attackGap>1.4</attackGap>
			<reloadGap>0.5</reloadGap>
			<shakeAngle>1</shakeAngle>
			<bulletWidth>80</bulletWidth>	
			<beatBack>2</beatBack>
			<targetShakeValue>10</targetShakeValue>
			<!--武器属性------------------------------------------------------------ -->
			<armsArmMul>0.6</armsArmMul>
			<armsWeight>5</armsWeight>
			<upValue>8</upValue>
			<shootShakeAngle>70</shootShakeAngle>
			<shootRecoil>10</shootRecoil>
			<screenShakeValue>15</screenShakeValue>
			<!--基本属性------------------------------------------------------------ -->
			<bulletLife>6</bulletLife>
			<hitType>rect</hitType>
			<!--特殊------------------------------------------------------------ -->
			<followD value="0.5" delay="1" />
			<bulletSpeed>20</bulletSpeed>
			<speedD max="20" min="8" a="-20"/>
			<penetrationGap>1000</penetrationGap>
			<boomD selfB="1" hurtMul="0"/>
			<skillArr>enemyEmp,offAllSkill</skillArr>
			<!--图像动画属性------------------------------------------------------------ -->
			<iconUrl>specialGun/dragonUltra</iconUrl>
			<shootSoundUrl>sound/lightningShoot</shootSoundUrl>
			<flipX>1</flipX>
			<bulletImgUrl con="add">generalEffect/frozenBallBig</bulletImgUrl>
			<hitImgUrl soundUrl="sound/paralysis_enemy_hit"  shake="2,0.2,10" con="filter">generalEffect/frozenBallHide</hitImgUrl>
			<selfBoomImgUrl con="add">generalEffect/frozenBallHide</selfBoomImgUrl>
			<fireImgUrl con="add">boomEffect/boom2</fireImgUrl>
			<!--图像范围------------------------------------------------------------ -->
			<bodyImgRange>specialGun/extremeLightning</bodyImgRange>
			<description></description>
		</bullet>
	</father>
	<![CDATA[
	<father type="lightning">
		<bullet color="purgold">
			<name>extremeLightning</name>
			<cnName>闪电极源</cnName><noMagneticB>1</noMagneticB><noBeClearB>1</noBeClearB>
			<aiShootRange>700</aiShootRange><!-- ai射程 -->
			<attackType>holy</attackType>
			<!--基本-->
			<capacity>30</capacity>
			<attackGap>1</attackGap>
			<reloadGap>0.5</reloadGap>
			<shakeAngle>1</shakeAngle>
			<bulletWidth>500</bulletWidth>
			<bulletShakeWidth>100</bulletShakeWidth>
			<bulletNum>5</bulletNum>				
			<shootAngle>15</shootAngle>				
			<beatBack>2</beatBack>
			<targetShakeValue>10</targetShakeValue>
			<!--武器属性------------------------------------------------------------ -->
			<hurtRatio>4</hurtRatio>
			<gunNum>1</gunNum>
			<armsArmMul>0.6</armsArmMul>
			<armsWeight>5</armsWeight>
			<upValue>8</upValue>
			<shootShakeAngle>70</shootShakeAngle>
			<shootRecoil>10</shootRecoil>
			<screenShakeValue>15</screenShakeValue>
			<!--基本属性------------------------------------------------------------ -->
			<noShakeTime>0.5</noShakeTime>
			<bulletLife>0.001</bulletLife>
			<hitType>longLine</hitType>
			<!--特殊------------------------------------------------------------ -->
			<!--图像动画属性------------------------------------------------------------ -->
			<iconUrl>specialGun/dragonUltra</iconUrl>
			<shootSoundUrl>sound/lightningShoot</shootSoundUrl>
			<flipX>1</flipX>
			<bulletImgUrl raNum="30" con="filter" len="35" time="0.03" waveAn="60" everFleshB="1" imgDieType="stop">bullet/laser2</bulletImgUrl>
			<hitImgUrl con="add">bulletHitEffect/fitHit</hitImgUrl>
			<fireImgUrl con="add">boomEffect/boom2</fireImgUrl>
			<!--图像范围------------------------------------------------------------ -->
			<bodyImgRange>specialGun/extremeLightning</bodyImgRange>
			<description></description>
		</bullet>
	</father>
	]]>
	
	<father name="enemyArmsSkill" cnName="">
		<![CDATA[
		<skill>
			<name>extremeLightningHit</name>
			<cnName>致残</cnName><ignoreImmunityB>1</ignoreImmunityB><ignoreNoSkillB>1</ignoreNoSkillB><noSkillDodgeB>1</noSkillDodgeB><noBeClearB>1</noBeClearB>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>passive</conditionType>
			<condition>hit</condition>
			<target>target</target>
			<!--效果------------------------------------------------------------ -->
			<addType>state</addType>
			<effectType>allHurtMul</effectType>
			<mul>0.2</mul>
			<duration>8</duration>
			<stateEffectImg partType="2hand,shootPoint">skillEffect/disabledBig</stateEffectImg>
			<description>使目标伤害降低[1-mul]。</description>
		</skill>
		]]>
	</father>
</data>