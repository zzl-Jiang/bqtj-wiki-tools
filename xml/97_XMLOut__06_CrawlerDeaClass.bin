<?xml version="1.0" encoding="utf-8" ?>
<data>
	
	
	
	<father name="death">
		<body index="0" name="爬行尸">
			<name>CrawlerDea</name>
			<cnName>爬行尸</cnName>
			<raceType>zombies</raceType><headIconUrl>IconGather/Crawler</headIconUrl>
			<swfUrl>swf/enemy/Crawler360.swf</swfUrl>
			<!-- 基本系数 -->
			<lifeRatio>1</lifeRatio>
			<showLevel>9999</showLevel>
			<headHurtMul>1.3</headHurtMul>
			<!-- 图像 -->
			<imgArr>
				stand,move,run
				,normalAttack2,hurt1,die1
				,__jumpUp,jumpUp,jumpUp__jumpDown,jumpDown,jumpDown__
				,__fill1_Up,fill1_Up,fill1_Up__fill1_Down,fill1_Down,fill1_Down__die1
			</imgArr>
			
			<!-- 碰撞体积 -->
			<hitRect>-14,-30,28,30</hitRect>
			<!-- 运动 -->
			<maxJumpNum>2</maxJumpNum>
			<maxVx>13</maxVx>
			<runStartVx>10</runStartVx>
			<!-- AI属性 -->
			
			<nextAttackTime>0</nextAttackTime>
			<extraAIClassLabel></extraAIClassLabel>
			<!-- 技能 -->
			<bulletLauncherClass></bulletLauncherClass>
			<skillArr>crawlerBack</skillArr>
			<!-- 攻击数据 -->
			<hurtArr>
				<hurt>
					<imgLabel>normalAttack2</imgLabel><keyName>attack1</keyName>
					<hurtRatio>2</hurtRatio>
					<shakeValue>4</shakeValue>
					<attackType>direct</attackType>
					<hitImgUrl name="clawHit"/>
				</hurt>
			</hurtArr>
		</body>
		<skill>
			<name>crawlerBack</name>
			<cnName>绕袭</cnName><everNoClearB>1</everNoClearB><ignoreNoSkillB>1</ignoreNoSkillB>
			<conditionType>passive</conditionType>
			<condition>add</condition>
			<target>me</target>
			
			<addType>state</addType>
			<effectType>teleportBack</effectType>
			<value>4</value><!-- 第几帧触发 -->
			<mul>-80</mul><!-- 瞬移到敌人背后的距离 -->
			<secMul>30</secMul><!-- 瞬移到敌人背后的距离的随机值  -30~30 -->
			<valueString>normalAttack2</valueString><!-- 什么动作触发 -->
			<duration>99999999</duration>
			<pointEffectImg name="teleportNew"/>
			<otherEffectImg name="teleportLine"/>
			<description>在举起爪子的时候，瞬移到敌人背后攻击敌人。</description>
		</skill>
	</father>
</data>