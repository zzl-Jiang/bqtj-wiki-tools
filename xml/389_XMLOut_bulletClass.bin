			<attackDelay>0</attackDelay>
			<bulletAngle>179</bulletAngle>
			<bulletNum>1</bulletNum>				
			<shootNum>50</shootNum>					
			<shootGap>0.1</shootGap>
			<!--特殊属性------------------------------------------------------------ -->	
			<followD value="1"/>	<!-- 跟踪 -->
			<penetrationGap>1000</penetrationGap>
			<!--运动属性------------------------------------------------------------ -->	
