<?xml version="1.0" encoding="utf-8" ?>

<!-- id是唯一识别码，必须防止和其他关卡集合重复，不设置的话默认为文件名。 -->
<data id="levelExampleArms" cnName="创建新武器" author="沃龙先生">
	<!-- 关卡集介绍。 -->
	<info>演示了如何添加新武器，以及将工厂武器xml代码加入到当前关卡中的方法。</info>
	<father name="normal" cn="关卡">
		<gather>
			<level name="levelExampleArms1" cnName="表哥的头颅" descrip="">
				<!-- info参数【更多参数参考“开发文档_关卡.xls的info参数”】-->
				<info enemyLv="99" />
				<!-- 场景 -->
				<sceneLabel>WoTu</sceneLabel>
				<!-- 发兵集************************************************ -->
				<unitG>
					<!-- 设置全部单位id命令为patrolGlobal（巡逻全图） -->
					<allDefault aiOrder="patrolGlobal"></allDefault>
					<!-- 创建id为enemy1的发兵集。 camp="enemy"代表阵营设为敌方，要设为我方请用"we"，不设置的话默认为敌方。-->
					<unitOrder id="enemy1" camp="enemy">
						<!-- number（按照num数量发兵），pro就是按照（按照num数量进行概率发兵） -->
						<numberType>number</numberType>
						<unit cnName="肥胖僵尸" num="2" />
						<unit cnName="战斗僵尸" num="3" />
					</unitOrder>
					<unitOrder id="enemy2">
						<numberType>pro</numberType>
						<unit cnName="肥胖僵尸" num="3" />
						<unit cnName="战斗僵尸" num="4" />
					</unitOrder>
					<unitOrder id="enemy3">
						<numberType>pro</numberType>
						<unit cnName="肥胖僵尸" num="8" />
						<unit cnName="战斗僵尸" num="8" />
						<unit cnName="携弹僵尸" num="1" />
					</unitOrder>
					<unitOrder id="enemy4">
						<!-- unitType：单位类型，boss（首领），super（精英怪），normal（小怪，默认值） -->
						<!-- lifeMul：生命倍数，dpsMul：伤害倍数 -->
						<!-- skillArr：设置额外技能 ，格式="技能1英文名,技能2英文名..." -->
						<!-- 【更多参数参考“开发文档_关卡.xls的unit参数”】 -->
						<unit cnName="携弹僵尸" num="1" unitType="boss" lifeMul="2" dpsMul="3" skillArr="groupCrazy_enemy,groupLight_enemy" />
					</unitOrder>
				</unitG>
				
				<!-- 事件集，每个事件集内的event按照顺序运行，上个event执行结束后才会进行下一个。而事件集1和事件集2则同时运行。 -->
				<eventG>
					<group id="group1" cnName="事件集1">
						
						<event>
							<!-- 【限定p1的武器为新加的2把武器：表哥的头颅、青峰】 -->
							<order>body:p1; onlyNewArms:yearRabbit45,a1$93197984_6x</order>
						</event>
						<event>
							<condition doNumber="3">enemyNumber:less_1</condition>
							<order>createUnit:enemy1; r123</order>
						</event>
						<event>
							<condition doNumber="3">enemyNumber:less_1</condition>
							<order>createUnit:enemy2; r123</order>
						</event>
						<event>
							<condition doNumber="3">enemyNumber:less_1</condition>
							<order>createUnit:enemy3; r123</order>
						</event>
						<event>
							<condition>enemyNumber:less_1</condition>
							<order>createUnit:enemy4; r123</order>
						</event>
						<event><condition>enemyNumber:less_1</condition><order>level; showPointer:r_over</order></event>
					</group>
				</eventG>
			</level>
		</gather>
	</father>	
	 <father cn="来自武器工厂生成的xml">
		<armsEdit name="a1$93197984_6x">{'bulletNum':30,'baseLabel':'rifleHornet','shootAngle':55}</armsEdit>
	</father>
	
	
	
	
	<father type="rocket">
		<bullet color="darkgold" kind="water">
			<name>yearRabbit45</name>
			<cnName>表哥的头颅</cnName>
			<!--随机属性------------------------------------------------------------ -->
			<!--基本-->
			<capacity>15</capacity>
			<attackGap>0.4</attackGap>
			<reloadGap>2</reloadGap>
			<shakeAngle>7</shakeAngle>
			<bulletWidth>30</bulletWidth>
			<bulletShakeWidth>0,0</bulletShakeWidth>
			<bulletNum>1</bulletNum>				
			<gunNum>1</gunNum>
			
			<!--武器属性------------------------------------------------------------ -->
			<armsArmMul>1.05</armsArmMul>
			<armsWeight>5</armsWeight>
			<upValue>0</upValue>
			<shootShakeAngle>45</shootShakeAngle>
			<shootRecoil>4</shootRecoil>
			<screenShakeValue>8</screenShakeValue>
			<!--基本属性------------------------------------------------------------ -->
			<noShakeTime>0.5</noShakeTime>
			<bulletLife>6</bulletLife>
			<hitType>rect</hitType>
			<!--攻击时的属性------------------------------------------------------------ -->
			<dpsMul>1.8</dpsMul>
			<uiDpsMul>2</uiDpsMul>
			
			<!--运动属性------------------------------------------------------------ -->	
			<bulletSpeed>25</bulletSpeed>
			<speedD random="0.3"/>
			<!--特殊------------------------------------------------------------ -->
			<twoShootPro>0.4</twoShootPro>
			<penetrationGap>0</penetrationGap>
			<bounceD floor="1000" body="0"/>	<!-- 反弹 -->
			<critD mul="2" pro="0.3"/>
			
			
			<skillArr>Hit_blindness_ArmsSkill,Hit_SlowMove_ArmsSkill</skillArr>
			<godSkillArr>Hit_crazy_godArmsSkill,yearRabbitSkill</godSkillArr>
			<!--图像动画属性------------------------------------------------------------ -->
			<iconUrl>specialGun/yearRabbitIcon</iconUrl>
			<flipX>1</flipX>
			<bulletImgUrl raNum="1">WenJie/head</bulletImgUrl>
			<smokeImgUrl con="filter" raNum="30">bullet/fireballSmoke</smokeImgUrl>
			<hitImgUrl name="bigSpace"/>
			<hitFloorImgUrl>no</hitFloorImgUrl>
			<fireImgType></fireImgType>
			<shootSoundUrl>specialGun/yearRabbitSound</shootSoundUrl>
			<!--图像范围------------------------------------------------------------ -->
			<bodyImgRange>specialGun/yearRabbit</bodyImgRange>
			<bulletImgRange>specialGun/bullet</bulletImgRange>
			<description>2020中秋签到</description>
		</bullet>
	</father>
	
	
	<father name="normal" cn="子弹">
		<bullet>
			<name>PetZombieHelmet45</name>
			<cnName>橄榄僵尸-弹性世界</cnName>
			<!--基本属性------------------------------------------------------------ -->
			<shakeAngle>5</shakeAngle>
			<bulletLife>2</bulletLife>
			<bulletWidth>10</bulletWidth>
			<hitType>rect</hitType>
			<!--攻击时的属性------------------------------------------------------------ -->
			<attackGap>0.7</attackGap>
			<attackDelay>0.6</attackDelay>
			<bulletAngle>210</bulletAngle>
			<bulletAngleRange>40</bulletAngleRange>
			<bulletNum>30</bulletNum>				
			<shootNum>1</shootNum>					
							
			<shootAngle>50</shootAngle>					
			<!--特殊属性------------------------------------------------------------ -->	
			<bounceD floor="999"/>	<!-- 反弹 -->
			<penetrationNum>999</penetrationNum>
			<twoHitGap>0.2</twoHitGap>
			<skillArr>slowMove_enemy</skillArr>
			<!--运动属性------------------------------------------------------------ -->	
			<shootPoint>-64,-82</shootPoint>
			<bulletSpeed>20</bulletSpeed>
			<gravity>1.3</gravity>
			<!--图像动画属性------------------------------------------------------------ -->
			<flipX>1</flipX>
			<bulletImgUrl raNum="2">PetZombieHelmet/bullet</bulletImgUrl>
			<hitImgUrl soundUrl="PetZombieHelmet/hit2">bulletHitEffect/yellow_motion</hitImgUrl><!-- 子弹图像【必备】 -->
			<smokeImgUrl con="filter" raNum="30">bulletHitEffect/smoke_small</smokeImgUrl><!-- 子弹尾烟效果（默认为空） -->
		</bullet>
	</father>
</data>