						<unit cnName="童灵尸" num="4"/>
						<unit cnName="卫队尸" num="3"/>
						<unit cnName="关东尸" num="1.5"/>
					</unitOrder>
					<unitOrder id="enemy3">
						<numberType>number</numberType>
						<unit cnName="童灵尸" num="4"/>
						<unit cnName="卫队尸" num="5"/>
						<unit cnName="关东尸" num="4"/>
