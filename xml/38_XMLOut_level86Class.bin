			<level name="BingKuDeep_1">
				<!-- 发兵集************************************************ -->
				<info enemyLv="87"/><sceneLabel>BingKuDeep</sceneLabel>
				<!-- 发兵集************************************************ -->
				<unitG><allDefault aiOrder="patrolGlobal"></allDefault>
					<unitOrder id="enemy1">
