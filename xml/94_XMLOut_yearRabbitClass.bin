<?xml version="1.0" encoding="utf-8" ?>
<data>
	
	<father  type="rocket" cnName="火炮-特殊">
		<bullet index="44" cnName="卯兔" name="yearRabbit" kind="water" color="black" composeLv="95" chipB="1" chipNum="100" dropLevelArr="999">
			<name>yearRabbit</name>
			<cnName>卯兔</cnName>
			<!--随机属性------------------------------------------------------------ -->
			<!--基本-->
			<capacity>15</capacity>
			<attackGap>0.4</attackGap>
			<reloadGap>2</reloadGap>
			<shakeAngle>7</shakeAngle>
			<bulletWidth>30</bulletWidth>
			<bulletShakeWidth>0,0</bulletShakeWidth>
			<bulletNum>1</bulletNum>				
			<gunNum>1</gunNum>
			
			<!--武器属性------------------------------------------------------------ -->
			<armsArmMul>1.05</armsArmMul>
			<armsWeight>5</armsWeight>
			<upValue>0</upValue>
			<shootShakeAngle>45</shootShakeAngle>
			<shootRecoil>4</shootRecoil>
			<screenShakeValue>8</screenShakeValue>
			<!--基本属性------------------------------------------------------------ -->
			<noShakeTime>0.5</noShakeTime>
			<bulletLife>6</bulletLife>
			<hitType>rect</hitType>
			<!--攻击时的属性------------------------------------------------------------ -->
			<dpsMul>1.8</dpsMul>
			<uiDpsMul>2</uiDpsMul>
			
			<!--运动属性------------------------------------------------------------ -->	
			<bulletSpeed>26</bulletSpeed>
			<speedD min="5" max="26" random="0.3" a="-30"/>
			<!--特殊------------------------------------------------------------ -->
			<twoShootPro>0.4</twoShootPro>
			<penetrationGap>0</penetrationGap>
			<bounceD floor="1" body="0"/>	<!-- 反弹 -->
			<critD mul="2" pro="0.3"/>
			
			
			<skillArr>Hit_blindness_ArmsSkill,Hit_SlowMove_ArmsSkill</skillArr>
			<godSkillArr>Hit_crazy_godArmsSkill,yearRabbitSkill</godSkillArr>
			<!--图像动画属性------------------------------------------------------------ -->
			<iconUrl>specialGun/yearRabbitIcon</iconUrl>
			<flipX>1</flipX>
			<bulletImgUrl con="add" raNum="1" urlRandomValue="3">specialGun/yearRabbitBullet</bulletImgUrl>
			<hitImgUrl soundUrl="specialGun/christmasGunHit">specialGun/christmasGunBoom</hitImgUrl>
			<hitFloorImgUrl>no</hitFloorImgUrl>
			<fireImgType></fireImgType>
			<shootSoundUrl>specialGun/yearRabbitSound</shootSoundUrl>
			<!--图像范围------------------------------------------------------------ -->
			<bodyImgRange>specialGun/yearRabbit</bodyImgRange>
			<bulletImgRange>specialGun/bullet</bulletImgRange>
			<description>2020中秋签到</description>
		</bullet>
		
	</father>
	<father name="godArmsSkill" cnName="神级武器技能">
		<skill index="0" name="包裹"><!-- dps-被动 -->
			<name>yearRabbitSkill</name><noSkillDodgeB>1</noSkillDodgeB><ignoreImmunityB>1</ignoreImmunityB>
			<cnName>包裹</cnName><noRandomListB>1</noRandomListB>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>passive</conditionType>
			<condition>hit</condition>
			<target>target</target>
			<!--效果------------------------------------------------------------ -->
			<addType>state</addType>
			<effectType>yearRabbitSkill</effectType>
			<effectProArr>0.015</effectProArr>
			<mul>0.00001</mul>
			<duration>6</duration>
			<!--图像------------------------------------------------------------ -->
			<stateEffectImg partType="body" con="add">specialGun/yearRabbitBuff</stateEffectImg>
			<description>气泡有[effectType.0]的几率会把怪物包住，让它攻击伤害降低至0.001%，持续[duration]秒，无视技能免疫。99级主线任务、修罗模式效果减弱。</description>
		</skill>
	</father>
	
</data>