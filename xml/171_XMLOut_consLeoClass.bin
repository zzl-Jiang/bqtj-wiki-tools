<?xml version="1.0" encoding="utf-8" ?>
<data>
	<father type="wavegun" cnName="闪电球">
		<bullet name="狮子座" kind="electric" color="yagold" composeLv="99" dropLevelArr="999">
			<name>consLeo</name>
			<cnName>狮子座</cnName><noMagneticB>1</noMagneticB>
			<aiShootRange>2000</aiShootRange><!-- ai射程 -->
			<attackType>holy</attackType>
			<dpsMul>51</dpsMul>
			<extraMul>1.3</extraMul>
			<uiDpsMul>4.98</uiDpsMul>
			<!--基本-->
			<capacity>17</capacity> 
			<attackGap>0.45</attackGap>
			<reloadGap>1.3</reloadGap>
			<shakeAngle>0</shakeAngle>
			<bulletWidth>1100</bulletWidth>		
			<beatBack>2</beatBack>
			<targetShakeValue>10</targetShakeValue>
			<!--特殊------------------------------------------------------------ -->
			<bulletSkillArr>consLeo</bulletSkillArr>
			<noHitB>1</noHitB>
			<penetrationGap>1000</penetrationGap>
			<penetrationNum>999</penetrationNum>
			<skillArr>Hit_AddLifeMul_ArmsSkill,Hit_Spurting_ArmsSkill</skillArr>
			<godSkillArr>consLeoSkill</godSkillArr>
			<!--武器属性------------------------------------------------------------ -->
			<hurtRatio>15</hurtRatio>
			<gunNum>1</gunNum>
			<armsArmMul>0.5</armsArmMul>
			<armsWeight>5</armsWeight>
			<upValue>3</upValue>
			<shootShakeAngle>10</shootShakeAngle>
			<shootRecoil>7</shootRecoil>
			<screenShakeValue>10</screenShakeValue>
			<bulletLife>0.001</bulletLife>
			<hitType>longLine</hitType>
			<!--图像动画属性------------------------------------------------------------ -->
			<shootSoundUrl>newGun/consLeoSound</shootSoundUrl>
			<flipX>1</flipX>
			<bulletImgUrl name="consLeoLine"/>
			<hitImgUrl name="purpleSpurting"/>
			<!-- 子弹图像【必备】 -->
			<!--图像范围------------------------------------------------------------ -->
			<bodyImgRange>newGun/consLeo</bodyImgRange>
			<bulletImgRange>specialGun/bullet</bulletImgRange>
			<info>拥有光锥的射程，极源的攻击范围，隼武的无视地形，铄金的无限穿人，以及第一梯队的伤害输出和当前版本最高的面板战斗力，这就是第一把究极武器——狮子座！</info>
		</bullet>
	</father>
	<father name="godArmsSkill" cnName="神级武器技能">
		<skill><!-- dps-被动 -->
			<name>consLeoSkill</name><noRandomListB>1</noRandomListB>
			<cnName>声电场</cnName>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>passive</conditionType>
			<condition>no</condition>
			<target>me</target>
			<!--效果------------------------------------------------------------ -->
			<addType>instant</addType>
			<effectType>no</effectType>
			<otherEffectImg name="consVirgoLineChild"/>
			<description>狮子座的吼声划破天际，迸发出的声电电流将撕裂周围的敌人。</description>
		</skill>
	</father>
</data>