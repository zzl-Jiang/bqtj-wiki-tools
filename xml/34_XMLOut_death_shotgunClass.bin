	<father name="deathArms">
		<skill cnName="爆沙"><!-- dps -->
			<name>implodingDea</name><noRandomListB>1</noRandomListB>
			<cnName>爆沙</cnName>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>passive</conditionType>
			<condition>hit</condition>
			<target>me</target>
			<!--效果------------------------------------------------------------ -->
			<addType>instant</addType>
			<effectType>bullet</effectType>
			<effectProArr>0.2</effectProArr>
			<mul>1</mul>
			<extraValueType>nowArmsHurt</extraValueType><![CDATA[<extraValueType>nowArmsHurt</extraValueType>]]>
			<!-- 子弹所需 -->
			<obj>"name":"imploding_blackArmsSkill","site":"me","flipB":true</obj>
			<!--图像------------------------------------------------------------ -->
			<meEffectImg soundUrl="sound/imploding_enemy"></meEffectImg>
			<description>击中目标后有[effectProArr.0]概率向前方爆裂出4条火花，轰炸前方所有目标，每条火花伤害为：武器面板单发伤害*增伤Buff。</description>
		</skill>
	</father>
	
	
</data>