<?xml version="1.0" encoding="utf-8" ?>
<data>
	<father type="cutter" cnName="切割枪">
		<bullet name="yearTiger" color="orange">
			<name>yearTigerDea</name>
			<cnName>狂刃·寅虎</cnName><dpsMul>0.41</dpsMul>
			<whippB>0</whippB>
			<capacity>50</capacity><iconUrl>specialGun/yearTigerIcon</iconUrl>
			<attackGap>0.5</attackGap>
			<reloadGap>1.3</reloadGap>
			<shakeAngle>1</shakeAngle>
			<bulletWidth>30</bulletWidth>
			<bulletNum>1</bulletNum>				
			<!--特殊------------------------------------------------------------ -->
			<penetrationNum>4</penetrationNum>
			<penetrationGap>1000</penetrationGap>
			<followD value="2" delay="999" hitIsTargetB="1" />
			<speedD penDec="1"/>
			<!--武器属性------------------------------------------------------------ -->
			<bulletSpeed>25</bulletSpeed>
			<armsArmMul>0.5</armsArmMul>
			<upValue>15</upValue>
			<shootShakeAngle>40</shootShakeAngle>
			<shootRecoil>10</shootRecoil>
			<screenShakeValue>15</screenShakeValue>
			<!--基本属性------------------------------------------------------------ -->
			<noShakeTime>0.5</noShakeTime>
			<bulletLife>7</bulletLife>
			<hitType>rect</hitType>
			<!--图像动画属性------------------------------------------------------------ -->
			<shootSoundUrl>specialGun/yearTigerSound</shootSoundUrl>
			<flipX>1</flipX>
			<bulletImgUrl con="add" raNum="30">specialGun/yearTigerBullet</bulletImgUrl>
			<hitImgUrl name="oreWormHit"/>
			<!--图像范围------------------------------------------------------------ -->
			<bodyImgRange>specialGun/yearTiger</bodyImgRange>
			<bulletImgRange>specialGun/bullet</bulletImgRange>
			<info>寅虎子弹击中敌人后，子弹才会持续跟踪目标。</info>
		</bullet>
	</father>
	
	
	<father type="wavegun">
		<![CDATA[橙色枪，很牛逼的枪]]>
		<bullet name="狮子座" kind="electric" color="orange">
			<name>consLeoDea</name><iconUrl>newGun/consLeo_icon</iconUrl>
			<cnName>真·狮子座</cnName><noMagneticB>1</noMagneticB>
			<aiShootRange>2000</aiShootRange><!-- ai射程 -->
			<dpsMul>0.5</dpsMul>
			<!--基本-->
			<capacity>111</capacity> 
			<attackGap>0.45</attackGap>
			<reloadGap>1.3</reloadGap> 
			<bulletWidth>1100</bulletWidth>		
			<beatBack>2</beatBack>
			<targetShakeValue>10</targetShakeValue>
			<!--特殊------------------------------------------------------------ -->
			<bulletSkillArr>consLeo</bulletSkillArr>
			<noHitB>1</noHitB>
			<penetrationGap>1000</penetrationGap>
			<penetrationNum>999</penetrationNum>
			<!--武器属性------------------------------------------------------------ -->
			<armsArmMul>0.5</armsArmMul><upValue>3</upValue><shootShakeAngle>10</shootShakeAngle><shootRecoil>7</shootRecoil><screenShakeValue>10</screenShakeValue>
			<bulletLife>0.001</bulletLife>
			<hitType>longLine</hitType>
			<!--图像动画属性------------------------------------------------------------ -->
			<shootSoundUrl>hitSound/small3Laser3</shootSoundUrl>
			<flipX>1</flipX>
			<bulletImgUrl name="consLeoLine"/>
			<hitImgUrl name="purpleSpurting"/>
			<!-- 子弹图像【必备】 -->
			<!--图像范围------------------------------------------------------------ -->
			<bodyImgRange>newGun/consLeo</bodyImgRange>
			<bulletImgRange>specialGun/bullet</bulletImgRange>
			<info>狮子座的吼声划破天际，迸发出的声电电流将撕裂周围的敌人。不受磁力场影响。</info>
		</bullet>
		
		<bullet color="purple">
			<name>airCannonX</name><iconUrl>newGun/airCannonX_icon</iconUrl>
			<cnName>空气炮X</cnName>
			<aiShootRange>1200</aiShootRange><!-- ai射程 -->
			<dpsMul>0.65</dpsMul>
			<!--基本-->
			<capacity>400</capacity>
			<attackGap>0.5</attackGap>
			<reloadGap>1</reloadGap>
			<bulletWidth>25</bulletWidth><noHitB>1</noHitB>
			<bulletNum>1</bulletNum>				
			<!--武器属性------------------------------------------------------------ -->
			<armsArmMul>0.55</armsArmMul>
			<upValue>8</upValue>
			<shootShakeAngle>30</shootShakeAngle>
			<shootRecoil>9</shootRecoil>
			<screenShakeValue>8</screenShakeValue>
			<bulletLife>0.001</bulletLife>
			<shootNum>2</shootNum>
			<shootGap>0.1</shootGap>
			<hitType>rect</hitType>
			<!--运动属性------------------------------------------------------------ -->	
			<bulletSpeed>0</bulletSpeed>
			<bulletSkillArr>airCannonDieEvent</bulletSkillArr>
			<!--特殊------------------------------------------------------------ -->
			<boomD selfB="1" radius="160" haveBodyHitEffectB="1" />
			<!--图像动画属性------------------------------------------------------------ -->
			<shootSoundUrl>hitSound/wave</shootSoundUrl>
			<bulletImgUrl name="no"/>
			<hitImgUrl name="gun_hit"/><!-- elasticRecoveryGod-->
			<hitFloorImgUrl name="yearDragon_hit"/>
			<selfBoomImgUrl name="airCannonBoom"/>
			<!--图像范围------------------------------------------------------------ -->
			<bodyImgRange>newGun/airCannonX</bodyImgRange>
			<bulletImgRange>specialGun/bullet</bulletImgRange>
			<info>将半径190码范围内的敌人子弹变成我方子弹，并弹飞。</info>
		</bullet>
		
		
		<bullet color="blue">
			<name>airCannon</name><iconUrl>newGun/airCannon_icon</iconUrl>
			<cnName>空气炮</cnName>
			<aiShootRange>1200</aiShootRange><!-- ai射程 -->
			<dpsMul>0.45</dpsMul>
			<!--基本-->
			<capacity>1600</capacity>
			<attackGap>0.5</attackGap>
			<reloadGap>1</reloadGap>
			<bulletWidth>25</bulletWidth><noHitB>1</noHitB>
			<bulletNum>1</bulletNum>				
			<!--武器属性------------------------------------------------------------ -->
			<armsArmMul>0.55</armsArmMul>
			<upValue>8</upValue>
			<shootShakeAngle>30</shootShakeAngle>
			<shootRecoil>9</shootRecoil>
			<screenShakeValue>8</screenShakeValue>
			<bulletLife>0.001</bulletLife>
			<shootNum>2</shootNum>
			<shootGap>0.1</shootGap>
			<hitType>rect</hitType>
			<!--运动属性------------------------------------------------------------ -->	
			<bulletSpeed>0</bulletSpeed>
			<bulletSkillArr>airCannonDieEvent</bulletSkillArr>
			<!--特殊------------------------------------------------------------ -->
			<boomD selfB="1" radius="160" haveBodyHitEffectB="1" />
			<!--图像动画属性------------------------------------------------------------ -->
			<shootSoundUrl>hitSound/wave</shootSoundUrl>
			<bulletImgUrl name="no"/>
			<hitImgUrl name="gun_hit"/><!-- elasticRecoveryGod-->
			<hitFloorImgUrl name="yearDragon_hit"/>
			<selfBoomImgUrl name="airCannonBoom"/>
			<!--图像范围------------------------------------------------------------ -->
			<bodyImgRange>newGun/airCannon</bodyImgRange>
			<bulletImgRange>specialGun/bullet</bulletImgRange>
			<info>将半径190码范围内的敌人子弹变成我方子弹，并弹飞。</info>
		</bullet>
		
		<bullet color="blue">
			<name>stopCannon</name><iconUrl>newGun/stopCannon_icon</iconUrl>
			<cnName>截停炮</cnName>
			<aiShootRange>1200</aiShootRange><!-- ai射程 -->
			<dpsMul>0.5</dpsMul>
			<!--基本-->
			<capacity>800</capacity>
			<attackGap>0.5</attackGap>
			<reloadGap>1</reloadGap>
			<bulletWidth>25</bulletWidth><noHitB>1</noHitB>
			<bulletNum>1</bulletNum>				
			<!--武器属性------------------------------------------------------------ -->
			<armsArmMul>0.55</armsArmMul>
			<upValue>8</upValue>
			<shootShakeAngle>30</shootShakeAngle>
			<shootRecoil>9</shootRecoil>
			<screenShakeValue>8</screenShakeValue>
			<bulletLife>0.001</bulletLife>
			<shootNum>2</shootNum>
			<shootGap>0.12</shootGap>
			<hitType>rect</hitType>
			<!--运动属性------------------------------------------------------------ -->	
			<bulletSpeed>0</bulletSpeed>
			<bulletSkillArr>stopCannonDieEvent</bulletSkillArr>
			<!--特殊------------------------------------------------------------ -->
			<boomD selfB="1" radius="160" haveBodyHitEffectB="1" />
			<!--图像动画属性------------------------------------------------------------ -->
			<shootSoundUrl>hitSound/wave</shootSoundUrl>
			<bulletImgUrl name="no"/>
			<hitImgUrl name="gun_hit"/><!-- elasticRecoveryGod-->
			<hitFloorImgUrl name="yearDragon_hit"/>
			<selfBoomImgUrl name="stopCannonBoom"/>
			<!--图像范围------------------------------------------------------------ -->
			<bodyImgRange>newGun/stopCannon</bodyImgRange>
			<bulletImgRange>specialGun/bullet</bulletImgRange>
			<info>使半径190码范围内的敌人子弹停止运动。</info>
		</bullet>
