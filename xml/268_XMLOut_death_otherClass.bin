	<father  type="energy" cnName="能量枪">
		<bullet color="orange">
			<name>falconGunDea</name><dpsMul>0.5</dpsMul>
			<cnName>真·隼武</cnName><noMagneticB>1</noMagneticB>
			<aiShootRange>800</aiShootRange><iconUrl>specialGun/falconGunIcon2</iconUrl>
			
			<capacity>71</capacity>
			<attackGap>0.7</attackGap>
			<reloadGap>1</reloadGap>
			<bulletWidth>25</bulletWidth>
			<bulletNum>3</bulletNum>				
			<shootAngle>1</shootAngle>
			<!--武器属性------------------------------------------------------------ -->
			<armsArmMul>0.5</armsArmMul><upValue>10</upValue><shootShakeAngle>30</shootShakeAngle><shootRecoil>5</shootRecoil><screenShakeValue>9</screenShakeValue>
			<bulletLife>1.5</bulletLife>
			<hitType>rect</hitType>
			<!--运动属性------------------------------------------------------------ -->	
			<bulletSpeed>35</bulletSpeed>
			<bulletSkillArr>falconGun</bulletSkillArr>
			<bounceD floor="0" body="0" noDieB="1" />
			<!--特殊------------------------------------------------------------ -->
			<!--图像动画属性------------------------------------------------------------ -->
			<shootSoundUrl>specialGun/greedySnakeSound</shootSoundUrl>
			<bulletImgUrl name="falconArmsBullet"/>
			<hitImgUrl name="greenEnergyHit"/>
			<!--图像范围------------------------------------------------------------ -->
			<bodyImgRange>specialGun/falconGun</bodyImgRange>
			<bulletImgRange>specialGun/bullet</bulletImgRange>
			<info>可穿过任何障碍物，且不受磁力场影响。</info>
		</bullet>
		
		<bullet cnName="破灭" color="purple" hole="hole">
			<name>destroyDie</name>
			<cnName>破灭</cnName><dpsMul>0.36</dpsMul>
			<!--随机属性------------------------------------------------------------ -->
			<!--基本-->
			<capacity>500</capacity>
			<attackGap>0.2</attackGap>
			<reloadGap>1</reloadGap>
			<shakeAngle>1</shakeAngle>
			<bulletWidth>24</bulletWidth>
			<aiShootRange>610</aiShootRange>
			<!--武器属性------------------------------------------------------------ -->
			<armsArmMul>0.6</armsArmMul>
			<upValue>10</upValue>
			<shootShakeAngle>10</shootShakeAngle>
			<shootRecoil>1</shootRecoil>
			<screenShakeValue>3</screenShakeValue>
			<!--基本属性------------------------------------------------------------ -->
			<noShakeTime>0.5</noShakeTime>
			<bulletLife>2</bulletLife>
			<hitType>rect</hitType>
			<!--运动属性------------------------------------------------------------ -->	
			<bulletSpeed>30</bulletSpeed>
			<penetrationNum>1</penetrationNum>
			<bounceD body="7" floor="7" hurtNumAdd="-1" /><!-- 反弹不衰减 -->
			<speedD penDec="1"/>
			<!--图像动画属性------------------------------------------------------------ -->
			<iconUrl>newGun/destroyDie_icon</iconUrl>
			<flipX>1</flipX>
			<bulletImgUrl name="SilverShipBullet"/>
			<fireImgUrl name="SilverShipFire"/><hitImgUrl name="gun_hit"/>
			
			<shootSoundUrl>sound/laserShoot</shootSoundUrl>
			<!--图像范围------------------------------------------------------------ -->
			<bodyImgRange>newGun/destroyDie</bodyImgRange>
			<bulletImgRange>specialGun/bullet</bulletImgRange>
			<description></description>
		</bullet>
		
		
		<bullet cnName="幻灭" color="blue" hole="hole">
			<name>dreamDieDea</name>
			<cnName>幻灭</cnName><dpsMul>1</dpsMul>
			<!--随机属性------------------------------------------------------------ -->
			<!--基本-->
			<capacity>1666</capacity>
			<attackGap>0.12</attackGap>
			<reloadGap>1</reloadGap>
			<shakeAngle>1</shakeAngle>
			<bulletWidth>30</bulletWidth>
			<aiShootRange>610</aiShootRange>
			<!--武器属性------------------------------------------------------------ -->
			<armsArmMul>0.6</armsArmMul>
			<upValue>10</upValue>
			<shootShakeAngle>10</shootShakeAngle>
			<shootRecoil>1</shootRecoil>
			<screenShakeValue>3</screenShakeValue>
			<!--基本属性------------------------------------------------------------ -->
			<noShakeTime>0.5</noShakeTime>
			<bulletLife>0.65</bulletLife>
			<hitType>rect</hitType>
			<!--运动属性------------------------------------------------------------ -->	
			<bulletSpeed>40</bulletSpeed>
			<!--图像动画属性------------------------------------------------------------ -->
			<iconUrl>newGun/dreamDie_icon</iconUrl>
			<flipX>1</flipX>
			<bulletImgUrl name="SilverShipBullet"/>
			<fireImgUrl name="SilverShipFire"/><hitImgUrl name="gun_hit"/>
			
			<shootSoundUrl>sound/laserShoot</shootSoundUrl>
			<!--图像范围------------------------------------------------------------ -->
			<bodyImgRange>specialGun/dreamDie</bodyImgRange>
			<bulletImgRange>specialGun/bullet</bulletImgRange>
			<description></description>
		</bullet>
		
	</father>
	

	<father type="weather" cnName="气象枪">
		<bullet name="飓风·申猴" kind="wind" color="purple">
			<name>yearMonkeyDea</name>
			<cnName>飓风·申猴</cnName><dpsMul>0.13</dpsMul>
			<!--基本-->
			<capacity>125</capacity> <iconUrl>specialGun/yearMonkeyIcon</iconUrl>
			<attackGap>0.8</attackGap>
			<reloadGap>3</reloadGap>
			<shakeAngle>0</shakeAngle>
			<bulletWidth>45</bulletWidth>
			<aiShootRange>500</aiShootRange>
			<bulletNum>1</bulletNum>				
			<gunNum>1</gunNum>
			<!--特殊------------------------------------------------------------ -->
			<penetrationNum>999</penetrationNum>
			<twoHitGap>0.3</twoHitGap>
			<noMagneticB>1</noMagneticB>
			<!--武器属性------------------------------------------------------------ -->
			<gunNum>1</gunNum>
			<armsArmMul>0.5</armsArmMul>
			<upValue>3</upValue>
			<shootShakeAngle>15</shootShakeAngle>
			<shootRecoil>10</shootRecoil>
			<screenShakeValue>15</screenShakeValue>
			<!--基本属性------------------------------------------------------------ -->
			<bulletSpeed>25</bulletSpeed>
			<speedD min="3" a="-35"/>
			<noShakeTime>0.5</noShakeTime>
			<bulletLife>10</bulletLife>
			<hitType>rect</hitType>
			<!--图像动画属性------------------------------------------------------------ -->
			<shootSoundUrl>specialGun/yearMonkeySound</shootSoundUrl>
			<flipX>1</flipX>
			<bulletImgUrl name="smallWind" />
			<hitImgUrl name="silverScreenBulletHit"/><!-- 子弹图像【必备】 -->
			<hitFloorImgUrl name="yearDragon_hit"/>
			<fireImgUrl  raNum="1" con="add">specialGun/christmasGunBoom</fireImgUrl>
			<!--图像范围------------------------------------------------------------ -->
			<bodyImgRange>specialGun/yearMonkey</bodyImgRange>
			<bulletImgRange>specialGun/bullet</bulletImgRange>
			<info>射出持续存在10秒的飓风，对路经的敌人不断造成伤害。不受磁力场影响。</info>
		</bullet>
		
		<bullet cnName="冰锥" kind="water" color="blue">
			<name>iceConeDea</name>
			<cnName>赌·冰锥</cnName><dpsMul>0.91</dpsMul>
			<!--随机属性------------------------------------------------------------ -->
			<!--基本-->
			<capacity>333</capacity><skillArr>iceConeDea</skillArr>
			<attackGap>0.6</attackGap><iconUrl>specialGun/iceConeIcon</iconUrl>
			<reloadGap>1</reloadGap>
			<shakeAngle>0</shakeAngle>
			<bulletWidth>35</bulletWidth>
			<bulletNum>1</bulletNum>				
			<!--武器属性------------------------------------------------------------ -->
			<armsArmMul>0.9</armsArmMul>
			<upValue>5</upValue>
			<shootShakeAngle>30</shootShakeAngle>
			<shootRecoil>12</shootRecoil>
			<screenShakeValue>13</screenShakeValue>
			<!--基本属性------------------------------------------------------------ -->
			<bulletLife>2</bulletLife>
			<hitType>rect</hitType>
			<!--攻击时的属性------------------------------------------------------------ -->
			<bulletSpeed>40</bulletSpeed>
			<!--图像动画属性------------------------------------------------------------ -->
			<bulletImgUrl name="iceConeBullet"/>
			<hitImgUrl name="iceConeHit" />
			<fireImgUrl name="iceConeFire"/>
			<shootSoundUrl>sound/snowHit</shootSoundUrl>
			<!--图像范围------------------------------------------------------------ -->
			<bodyImgRange>specialGun/iceCone</bodyImgRange>
			<bulletImgRange>specialGun/bullet</bulletImgRange>
		</bullet>
	</father>

	
	<father name="deathArms">
		<skill><!-- dps-被动 -->
			<name>iceConeDea</name><noSkillDodgeB>1</noSkillDodgeB><ignoreImmunityB>1</ignoreImmunityB>
			<cnName>偶发冰冻</cnName><noRandomListB>1</noRandomListB><noBeClearB>1</noBeClearB>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>passive</conditionType>
			<condition>hit</condition>
			<target>target</target>
			<!--效果------------------------------------------------------------ -->
			<addType>instantAndState</addType>
			<effectType>dizziness</effectType>
			<effectProArr>0.003</effectProArr><!-- 0.003 -->
			<duration>20</duration>
			<!--图像------------------------------------------------------------ -->
			<stateEffectImg name="frozenState"/>
			<description>每次击中都有[effectProArr.0]将目标冰冻，让其无法攻击和动弹，持续[duration]秒，无视技能免疫、不会被清除。</description>
		</skill>
	</father>
	
	
</data>