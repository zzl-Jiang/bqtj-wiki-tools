<?xml version="1.0" encoding="utf-8" ?>
<data>
	<father type="wavegun" cnName="声波枪">
		<bullet name="酉鸡"  color="black" evoB="0" composeLv="97" chipNum="150" chipB="1" dropLevelArr="999">
			<name>yearChicken</name>
			<cnName>酉鸡</cnName>
			<dpsMul>1.5</dpsMul>
			<uiDpsMul>1.7</uiDpsMul>
			<extraMul>1.2</extraMul>
			<!--基本-->
			<capacity>6</capacity> 
			<attackGap>0.7</attackGap>
			<reloadGap>2</reloadGap>
			<shakeAngle>0</shakeAngle>
			<bulletWidth>600</bulletWidth>
			<bulletShakeWidth>50</bulletShakeWidth>
			<bulletNum>1</bulletNum>				
			<shootAngle>0</shootAngle>				
			<beatBack>10</beatBack>
			<targetShakeValue>10</targetShakeValue>
			<!--特殊------------------------------------------------------------ -->
			<twoShootPro>0.2</twoShootPro>
			<penetrationNum>20</penetrationNum>
			<penetrationGap>0</penetrationGap>
			<bounceD floor="0" body="0"/>	<!-- 反弹 -->
			<critD mul="2" pro="0.2"/>
			
			<skillArr>Hit_disabled_ArmsSkill</skillArr>
			<godSkillArr>yearChickenSkill</godSkillArr>
			<!--武器属性------------------------------------------------------------ -->
			<hurtRatio>15</hurtRatio>
			<gunNum>1</gunNum>
			<armsArmMul>0.5</armsArmMul>
			<armsWeight>5</armsWeight>
			<upValue>3</upValue>
			<shootShakeAngle>15</shootShakeAngle>
			<shootRecoil>10</shootRecoil>
			<screenShakeValue>15</screenShakeValue>
			<!--基本属性------------------------------------------------------------ -->
			<noShakeTime>0.5</noShakeTime>
			<bulletLife>0.001</bulletLife>
			<hitType>longLine</hitType>
			<!--攻击时的属性------------------------------------------------------------ -->
			
			<!--图像动画属性------------------------------------------------------------ -->
			<shootSoundUrl>sound/waveShoot</shootSoundUrl>
			<flipX>1</flipX>
			<bulletImgUrl raNum="30" con="filter" len="30" time="0.03" waveAn="15" imgDieType="die">specialGun/yearChickenBullet</bulletImgUrl>
			<hitImgUrl>bulletHitEffect/energyYellow</hitImgUrl><!-- 子弹图像【必备】 -->
			<!--图像范围------------------------------------------------------------ -->
			<bodyImgRange>specialGun/yearChicken</bodyImgRange>
			<bulletImgRange>specialGun/bullet</bulletImgRange>
		</bullet>
	</father>
	<father name="godArmsSkill" cnName="神级武器技能">
		<skill><!-- dps-被动 -->
			<name>yearChickenSkill</name><noRandomListB>1</noRandomListB>
			<cnName>周末快乐</cnName>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>passive</conditionType>
			<otherConditionArr>puWe,weekend</otherConditionArr>
			<condition>hit</condition>
			<target>target</target>
			<!--效果------------------------------------------------------------ -->
			<addType>instant</addType>
			<effectType>changeHurtNoCondition</effectType>
			<mul>2</mul>
			<!--图像------------------------------------------------------------ -->
			<description>周末期间双倍伤害。</description>
		</skill>
	</father>
</data>