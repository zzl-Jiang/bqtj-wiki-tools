  <!--██████████████分█界█线██████████████-->
  <!--█████████████████████████████████-->
  <father>
  <gather>
  <level name="心零找到制毒师" cnName="心零找到制毒师" descrip="心零在双塔村找到制毒师">
				<info enemyLv="25" modeDiy="death" firstLostB="1" noMoreB="1" noVehicleB="1" noTreasureB="1" noPropsB="1" mustSingleB="1" noDeviceB="1" noAIB="1"/>
				<sceneLabel>ShuangTa</sceneLabel>
				<unitG>
					<unitOrder id="制毒师" camp="we">
						<unit id="制毒师" cnName="制毒师" num="1" aiOrder="patrolRandom"/>
					</unitOrder>
					<unitOrder id="心零" camp="we">
            <unit id="心零" cnName="心零" lifeMul="0.7" dpsMul="5" skillArr="弹鼻屎,tauntLing_10,饰演重生石,shootSpeed2,无限携弹量,jumpNumAdd1"/>
          </unitOrder>
					<allDefault aiOrder="patrolGlobal"/>
				</unitG>
				<eventG>
					<group>
					<event>
              <order>sceneScale:1</order>
              <order>weAllHeroNoShoot</order>
              <order>weAllHeroNoEquip</order><order>weAllHeroNoSkill</order>
              <order>createUnit:心零; r1</order>
              <order>heroEverParasitic:心零</order>
			  <order>createUnit:制毒师; r2</order>
            </event>
			<event>
              <order>openInput</order>
			  </event>
			  <event>
              <condition>bodyGap:less_200; 心零:制毒师</condition>
			  <order>body:制毒师; ai:noAndStop</order><!--乱逛→停下-->
			  </event>
			  <event>
              <order>say;startList:见到制毒师对话</order>
			  </event>
			  <event>
              <condition>say:listOver; 见到制毒师对话</condition>
			  <order>level; showPointer:r_over</order>
			  </event>
			</group>
          <group id="判断失败">
            <event>
              <condition>bodyEvent:die; 心零</condition>
			  <order>say;startList:死了</order>
            </event>
            <event>
              <condition delay="1.5"/>
              <order>alert:yes; Vegetable</order>
            </event>
            <event>
              <order>level; fail</order>
            </event>
          </group>
				</eventG>
			</level>
			</gather>
			<level name="心零找到制毒师">
			<sayList name="见到制毒师对话">
		<say target="心零">
          <content>终于见到传说中的制毒师了！</content>
        </say>
		<say target="制毒师">
          <content>有何贵干？</content>
        </say>
		<say target="心零">
          <content>我想拜你为师！听说您研究过世界上所有毒物，我也想像你一样厉害！</content>
        </say>
		<say target="制毒师">
          <content>拜我为师？让我想想</content>
        </say>
		<say target="制毒师">
          <content>这样吧，你先去附近的幽灵谷收集点僵尸血液回来，我在这期间想想怎么教你。</content>
        </say>
		<say target="心零">
          <content>你这是找借口把我支开吧？</content>
        </say>
		<say target="制毒师">
          <content>不完全是。因为我真的要研究僵尸血液。</content>
        </say>
		<say target="心零">
          <content>呜呜呜，你就忍心看着这样的弱女子去僵尸那儿送死？</content>
        </say>
		<say target="制毒师">
          <content>你不弱。我早就在双塔村楼顶看到你在北斗城用超能石学习了新技能，应付个僵尸轻轻松松。</content>
        </say>
		<say target="制毒师">
          <content>这儿被小白他们打下来，作为基地。到时候收集完僵尸血液回这来找我就行了。</content>
        </say>
		<say target="心零">
          <content>都被你看穿了……好吧，我去看一看</content>
        </say>
      </sayList>
      <sayList name="死了">
        <say target="心零">
          <content>啊？重生次数用完了？</content>
        </say>
      </sayList>
    </level>
			</father>
