  <level name="南唐城" cnName="南唐城" descrip="心零继续找制毒师，逛到了南唐城">
				<info enemyLv="25" modeDiy="death" firstLostB="1" noMoreB="1" noVehicleB="1" noTreasureB="1" noPropsB="1" mustSingleB="1" noDeviceB="1" noAIB="1"/>
				<sceneLabel>NanTang</sceneLabel>
				<unitG>
					<unitOrder id="小樱" camp="we">
						<unit cnName="小樱" lifeMul="8" dpsMul="9" warningRange="1e+7" skillArr="shootSpeed2" dieGotoState="stru" />
					</unitOrder>
					<unitOrder id="心零" camp="we">
            <unit id="心零" cnName="心零" lifeMul="0.7" dpsMul="5" skillArr="弹鼻屎,tauntLing_10,饰演重生石,shootSpeed2,无限携弹量,jumpNumAdd1"/>
          </unitOrder>
					<allDefault aiOrder="patrolGlobal"/>
					<!-- 敌方 -->
					<unitOrder id="enemy1"><default lifeMul="25" skillArr="死后掉落超能石"/>
						<unit cnName="携弹僵尸" num="4" />
						<unit cnName="橄榄僵尸" num="4"/>
						<unit cnName="无头自爆僵尸" num="4"/>
						<unit cnName="僵尸突击兵" num="0.3"/>
						<unit cnName="僵尸狙击兵" num="0.3"/>
						<unit cnName="僵尸暴枪兵" num="0.3"/>
						<unit cnName="僵尸空军总管" num="0.5"/>
					</unitOrder>
					<unitOrder id="enemy3">
						<unit cnName="火炮僵尸王" num="1"  lifeMul="80" unitType="boss"/>
					</unitOrder>
				</unitG>
				<eventG>
					<group id="关卡进程">
						<event>
							<order>createUnit:小樱; r3</order>
							<order>sceneScale:1</order>
              <order>weAllHeroNoShoot</order>
              <order>weAllHeroNoEquip</order><order>weAllHeroNoSkill</order>
              <order>createUnit:心零; r_birth</order>
              <order>heroEverParasitic:心零</order><order>body:心零; onlyNewArms:akGreen,rocketDeath,shotgunTyran,pistolRed</order>
						</event>
						<event>
						<order>openInput</order>
						</event>
						<event>
							<condition doNumber="4" orderChooseType="randomOne">enemyNumber:less_1</condition>
							<order>createUnit:enemy1; r1</order>
							<order>createUnit:enemy1; r2</order>
						</event>
						<event><condition delay="0.01">enemyNumber:less_1</condition></event>
						<event>
							<condition doNumber="3" orderChooseType="randomOne">enemyNumber:less_1</condition>
							<order>createUnit:enemy1; r1</order>
							<order>createUnit:enemy1; r2</order>
						</event>
						<event><condition delay="0.01">enemyNumber:less_1</condition></event>
						<event>
							<condition doNumber="2" orderChooseType="randomOne">enemyNumber:less_3</condition>
							<order>createUnit:enemy1; r1</order>
							<order>createUnit:enemy1; r2</order>
						</event>
						<event>
							<condition orderChooseType="randomOne">enemyNumber:less_1</condition>
							<order>createUnit:enemy3; r1</order>
							<order>createUnit:enemy3; r2</order>
						</event>
					</group>
					<group id="对话和判断通关">
					<event>
					<condition>bodyGap:less_300; 心零:小樱</condition>
					<order>say;startList:和小樱对话</order>
					</event>
					<event>
					<condition>say:listOver;和小樱对话</condition>
					<order>body:小樱; onlyNewArms:mambaGreen</order>
					<order>say;startList:把枪给了小樱</order>
					</event>
					<event>
							<condition>bodyEvent:die;火炮僵尸王</condition>
							<order>say;startList:问制毒师去向</order>
							</event>
							<event>
							<condition>say:listOver;问制毒师去向</condition>
							<order>level; showPointer:r_over</order>
						</event>
					</group>
					<group>
						<!-- 小樱死亡 任务失败 -->
						<event>
							<condition delay="0.5">bodyEvent:die; 小樱</condition>
							<order>alert:yes; 小樱已倒下，任务失败！</order>
						</event>
						<event>
							<condition delay="0.3"></condition>
							<order>level; fail</order>
						</event>
					</group>
					<group id="被打死一次">
		  <event>
		  <condition>say:listOver; 把枪给了小樱</condition>
		  </event>
            <event>
              <condition>weNumber:greater_20</condition><!--P1和心零总计2个，如召唤了空单位即可多于20个-->
			  <order>say;startList:被打死一次</order>
            </event>
          </group>
          <group id="判断失败">
            <event>
              <condition>bodyEvent:die; 心零</condition>
			  <order>say;startList:死了</order>
            </event>
            <event>
              <condition delay="1.5"/>
              <order>alert:yes; Vegetable</order>
            </event>
            <event>
              <order>level; fail</order>
            </event>
          </group>
		  <group id="心零拾获超能石">
		  <event>
              <condition doNumber="-1">hitDrop:p1; skillStoneTask</condition><!--为什么【hitDrop:】的后面只能是p1？-->
			  <order>addNumber: 拾获超能石; 1</order>
			  <order>tip:1; 拾获超能石[拾获超能石]/30个</order>
			  </event>
          </group>
		  <group id="心零拾获超能石30个">
		  <event>
              <condition>number:greater_29; 拾获超能石</condition>
			  <order>body:心零; addSkillLock:coquettish_hero_14,trueshot_enemy,摧残</order>
			  </event>
          </group>
				</eventG>
  </level>
  </gather>
  <skill>
			<name>死后掉落超能石</name>
			<cnName>死后掉落超能石</cnName><ignoreNoSkillB>1</ignoreNoSkillB>
			<conditionType>passive</conditionType><condition>die</condition>
			<target>me</target>
			<addType>instant</addType><effectProArr>0.4</effectProArr>
			<effectType>theKunSkill</effectType><effectFather>vehicle</effectFather>
			<valueString>skillStoneTask</valueString><!--反客的超能石-->
			<description>死后有[effectProArr.0]的概率掉落1个超能石</description>
		</skill>
		<skill>
			<name>摧残</name>
			<cnName>摧残</cnName><ignoreImmunityB>1</ignoreImmunityB><noSkillDodgeB>1</noSkillDodgeB>
			<conditionType>passive</conditionType>
			<condition>hit</condition>
			<target>target</target>
			<addType>instant</addType>
			<effectType>changeHurt</effectType>
			<mul>0.1</mul>
			<secMul>2</secMul>
			<obj>"type":"accurate","exceptSkillB":true</obj>
			<meEffectImg></meEffectImg>
			<targetEffectImg></targetEffectImg>
			<description>提升打身体[secMul]的伤害值。提升爆头[mul]的伤害值，无视技能免疫和免疫</description>
		</skill>
			<level name="南唐城">
			<sayList name="和小樱对话">
		<say target="心零">
          <content>喔，这么可爱的小姐姐，在这里做什么呀</content>
        </say>
		<say target="小樱">
          <content>我在找超能矿石呢，有了超能石，我就能学习超能力，变得强大了！</content>
        </say>
		<say target="心零">
          <content>这儿有超能石啊，这么好，我也来找找看</content>
        </say>
		<say target="心零">
          <content>不过你的枪太烂了，怎么找得过僵尸呢？我刚好有多余的，给你一把用。</content>
        </say>
      </sayList>
	  <sayList name="把枪给了小樱">
	  <say target="心零">
          <content>送你的，不用还了</content>
        </say>
		<say target="小樱">
          <content>谢谢你！</content>
        </say>
      </sayList>
	  <sayList name="问制毒师去向">
		<say target="心零">
          <content>对了，你有没有见过制毒师？</content>
        </say>
		<say target="小樱">
          <content>见过呀，他是个热心肠的好人呢。前几天，他来这找我，说他现在有好多好多的神能石。</content>
        </say>
		<say target="小樱">
          <content>我只要找到足够的超能石，就可以跟他交换同等数量的神能石，他说整个霞光市只有我有这个特权哦。</content>
        </say>
		<say target="心零">
          <content>听着就像把你引到这里来打僵尸</content>
        </say>
		<say target="心零">
          <content>他去哪了呢？</content>
        </say>
		<say target="小樱">
          <content>记不清了，我只记得后来他接了个电话，然后就急匆匆往北边赶去了。</content>
        </say>
		<say target="心零">
          <content>电话，哦不，我在拜师的时候竟然没要他的电话，后悔莫及啊</content>
        </say>
		<say target="心零">
          <content>我得继续找他去，拜拜！</content>
        </say>
      </sayList>
			<sayList name="被打死一次">
		<say target="心零">
          <content>真疼啊，还好我买了很多重生石</content>
        </say>
		<say target="心零">
          <content>我就喜欢拿着黄金去买东西。</content>
        </say>
      </sayList>
      <sayList name="死了">
        <say target="心零">
          <content>啊？重生次数用完了？</content>
        </say>
      </sayList>
    </level>
  </father>
  <!--█████████████████████████████████-->
  <!--██████████████分█界█线██████████████-->
