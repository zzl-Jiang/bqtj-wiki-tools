  <father>
  <gather>
  <level name="心零向北到达清明岭" cnName="心零向北到达清明岭" descrip="随着小樱的指引，心零向北走到了清明岭">
				<info enemyLv="25" modeDiy="death" firstLostB="1" noMoreB="1" noVehicleB="1" noTreasureB="1" noPropsB="1" mustSingleB="1" noDeviceB="1" noAIB="1"/>
				<sceneLabel>QingMing</sceneLabel>
				<unitG>
					<unitOrder id="心零" camp="we">
            <unit id="心零" cnName="心零" lifeMul="0.7" dpsMul="5" skillArr="弹鼻屎,tauntLing_10,coquettish_hero_14,trueshot_enemy,摧残,饰演重生石,shootSpeed2,无限携弹量,jumpNumAdd1"/>
          </unitOrder>
					<allDefault aiOrder="patrolGlobal"/>
					<!-- 敌方 -->
					<unitOrder id="enemy1"><default lifeMul="14"/>
						<unit cnName="无头自爆僵尸" num="3" />
						<unit cnName="屠刀僵尸" num="3" />
						<unit cnName="橄榄僵尸" num="3" />
						<unit cnName="僵尸空降兵" num="1"/>
						<unit cnName="僵尸狙击兵" num="0.3"/>
						<unit cnName="僵尸暴枪兵" num="0.3"/>
						<unit cnName="僵尸空军总管" num="1"/>
					</unitOrder>
					<unitOrder id="亚瑟" camp="we">
						<unit cnName="亚瑟" warningRange="1e+7" lifeMul="50" unitType="boss" dieGotoState="stru"/>
					</unitOrder>
				</unitG>
				<eventG>
					<group id="关卡进程">
					<event>
							<order>createUnit:亚瑟; r3</order>
							<order>sceneScale:1</order>
              <order>weAllHeroNoShoot</order>
              <order>weAllHeroNoEquip</order><order>weAllHeroNoSkill</order>
              <order>createUnit:心零; r_birth</order>
              <order>heroEverParasitic:心零</order><order>body:心零; onlyNewArms:akGreen,rocketDeath,shotgunTyran,pistolRed</order>
						</event>
						<event>
						<order>openInput</order>
						</event>
						<event>
						<condition>bodyGap:less_300; 心零:亚瑟</condition>
						<order>say;startList:开局和亚瑟对话</order>
						</event>
						<event>
						<condition>say:listOver; 开局和亚瑟对话</condition>
						<order>say;startList:亚瑟出兵</order>
						</event>
						<event>
							<condition delay="0.5" />
							<order>body:亚瑟; changeCamp:enemy</order>
						</event>
						<event>
							<condition doNumber="14" />
							<order>createUnit:enemy1; r123</order>
						</event>
						<event>
							<condition>liveEnemyNumber:less_1</condition>
							<order>say;startList:打完亚瑟</order>
							</event>
							<event>
							<condition>say:listOver; 打完亚瑟</condition>
							<order>level; showPointer:r_over</order>
						</event>
					</group>
										<group id="被打死一次">
            <event>
              <condition>weNumber:greater_20</condition><!--P1和心零总计2个，如召唤了空单位即可多于20个-->
			  <order>say;startList:被打死一次</order>
            </event>
          </group>
          <group id="判断失败">
            <event>
              <condition>bodyEvent:die; 心零</condition>
			  <order>say;startList:死了</order>
            </event>
            <event>
              <condition delay="1.5"/>
              <order>alert:yes; Vegetable</order>
            </event>
            <event>
              <order>level; fail</order>
            </event>
          </group>
				</eventG>
			</level>
  </gather>
  <level name="心零向北到达清明岭">
			<sayList name="开局和亚瑟对话">
		<say target="心零">
          <content>哇哦，居然在这里碰到了天鹰军团的总司令：亚瑟</content>
        </say>
		<say target="心零">
          <content>的克隆体！</content>
        </say>
		<say target="亚瑟">
          <content>……</content>
        </say>
		<say target="心零">
          <content>咿？不说点什么吗？</content>
        </say>
		<say target="亚瑟">
          <content>你是干什么的，没事速速退去</content>
        </say>
		<say target="心零">
          <content>我要找制毒师，我有急事要找他，您知道制毒师在哪吗？</content>
        </say>
      </sayList>
	  <sayList name="亚瑟出兵">
	  <say target="亚瑟">
          <content>找制毒师？准没好事！全体听令进攻！</content>
        </say>
      </sayList>
	  <sayList name="打完亚瑟">
		<say target="心零">
          <content>太粗暴了吧，不由分说就开打..</content>
        </say>
		<say target="心零">
          <content>让我猜猜，你们打下双塔村的时候，跟你们作对这么久的制毒师直接倒戈加入了天鹰？</content>
        </say>
		<say target="亚瑟">
          <content>……</content>
        </say>
		<say target="心零">
          <content>看你这脸色，我好像猜对了</content>
        </say>
		<say target="心零">
          <content>所以你听说我要找制毒师才会攻击我，怕我对天鹰为非作歹？</content>
        </say>
		<say target="心零">
          <content>您放心吧，我只是想要学点技术。</content>
        </say>
		<say target="心零">
          <content>话说回来，您有没有制毒师的电话或者别的联系方式呢？</content>
        </say>
		<say target="亚瑟">
          <content>……</content>
        </say>
		<say target="心零">
          <content>算了，那您入土为安吧。</content>
        </say>
      </sayList>
			<sayList name="被打死一次">
		<say target="心零">
          <content>真疼啊，还好我买了很多重生石</content>
        </say>
		<say target="心零">
          <content>我就喜欢拿着黄金去买东西。</content>
        </say>
      </sayList>
      <sayList name="死了">
        <say target="心零">
          <content>啊？重生次数用完了？</content>
        </say>
      </sayList>
    </level>
  </father>
