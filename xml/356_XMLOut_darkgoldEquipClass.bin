<?xml version="1.0" encoding="utf-8" ?>
<data>
	<gather cnName="暗金" range="999999,999999,999999,999999"><!-- 开始等级，最大等级1，最大等级2，结束等级 -->	
		<father cnName="狂人" color="darkgold" name="madamor" imgSwf="madamor" evoB="1" suitPro="hurtAll:1.35">
			<image>
				<type>head</type><itemsLevel>95</itemsLevel>
				<cnName>狂人头盔</cnName>
				<otherObjJson>{'dpsAllBlack':0.16,'lifeAllBlack':0.45,'dodge':0.20}</otherObjJson>
			</image>
			<image>
				<type>coat</type><itemsLevel>95</itemsLevel>
				<cnName>狂人战衣</cnName>
				<otherObjJson>{'dpsAllBlack':0.16,'fightDedut':0.29,'bulletDedut':0.27}</otherObjJson>
			</image>
			<image>
				<type>pants</type><itemsLevel>95</itemsLevel>
				<cnName>狂人战裤</cnName>
				<otherObjJson>{'dpsAllBlack':0.16,'cdMul':0.27,'moveMul':0.27}</otherObjJson>
			</image>
			<image>
				<type>belt</type><itemsLevel>95</itemsLevel>
				<cnName>狂人腰带</cnName>
				<otherObjJson>{'dpsAllBlack':0.17,'lifeRateBlack':17329}</otherObjJson>
			</image>
		</father>
	</gather>
	
	<gather cnName="紫金" range="999999,999999,999999,999999"><!-- 开始等级，最大等级1，最大等级2，结束等级 -->	
		<father cnName="战神" color="purgold" name="madpur" imgSwf="madpur" evoB="1" suitPro="hurtAll:1.50,critPro3:0.03">
			<![CDATA[下面的属性要和狂人的一致，因为战神是由狂人进阶而来的]]>
			<image>
				<type>head</type><itemsLevel>99</itemsLevel>
				<cnName>战神的蔑视</cnName>
				<skillArr>madpurHurt</skillArr>
				<otherObjJson>{'dpsAllBlack':0.16,'lifeAllBlack':0.45,'dodge':0.20}</otherObjJson>
			</image>
			<image>
				<type>coat</type><itemsLevel>99</itemsLevel>
				<cnName>战神的戒严</cnName>
				<skillArr>madpurUnder</skillArr>
				<otherObjJson>{'dpsAllBlack':0.16,'fightDedut':0.29,'bulletDedut':0.27}</otherObjJson>
			</image>
			<image>
				<type>pants</type><itemsLevel>99</itemsLevel>
				<cnName>战神的讨伐</cnName>
				<skillArr>madpurPants</skillArr>
				<otherObjJson>{'dpsAllBlack':0.16,'cdMul':0.27,'moveMul':0.27}</otherObjJson>
			</image>
			<image>
				<type>belt</type><itemsLevel>99</itemsLevel>
				<cnName>战神的降临</cnName>
				<skillArr>madpurBelt</skillArr>
				<otherObjJson>{'dpsAllBlack':0.17,'lifeRateBlack':17329}</otherObjJson>
			</image>
		</father>
	</gather>
	<gather cnName="氩星" range="999999,999999,999999,999999"><!-- 开始等级，最大等级1，最大等级2，结束等级 -->	
		<father cnName="战神" color="yagold" name="madya" imgSwf="madya" evoB="1" suitPro="hurtAll:1.55,critPro3:0.03">
			
			<image>
				<type>head</type><itemsLevel>99</itemsLevel>
				<cnName>战神的藐视</cnName><!-- 无视敌人的锁血、上限、上帝之盾技能，新难度来个锁血-->
				<skillArr>yaMadHead</skillArr>
				<otherObjJson>{'dpsAllBlack':0.16,'lifeAllBlack':0.45,'dodge':0.20}</otherObjJson>
			</image>
			<image>
				<type>coat</type><itemsLevel>99</itemsLevel>
				<cnName>战神的封锁</cnName>
				<skillArr>yaMadCoat</skillArr>
				<otherObjJson>{'dpsAllBlack':0.16,'fightDedut':0.29,'bulletDedut':0.27}</otherObjJson>
			</image>
			
			<image>
				<type>pants</type><itemsLevel>99</itemsLevel>
				<cnName>战神的诛灭</cnName>
				<skillArr>yaMadPants</skillArr>
				<otherObjJson>{'dpsAllBlack':0.16,'cdMul':0.27,'moveMul':0.27}</otherObjJson>
			</image>
			
			<image>
				<type>belt</type><itemsLevel>99</itemsLevel>
				<cnName>战神的驾临</cnName>
				
				<otherObjJson>{'dpsAllBlack':0.17,'lifeRateBlack':17329}</otherObjJson>
			</image>
			
		</father>
	</gather>
	
	
	
	<![CDATA[技能]]>
	<father name="purgoldEquip">
		<skill>
			<name>madpurHurt</name>
			<cnName>蔑视</cnName><ignoreNoSkillB>1</ignoreNoSkillB><ignoreSilenceB>1</ignoreSilenceB><noSkillDodgeB>1</noSkillDodgeB><ignoreImmunityB>1</ignoreImmunityB>
			<conditionType>passive</conditionType><otherConditionArr>targetIsHero</otherConditionArr>
			<condition>hit</condition><target>target</target><addType>instant</addType>
			<effectType>changeHurtNoCondition</effectType><mul>1.2</mul>
			<description>对持枪敌人造成额外[mul-1]的伤害。</description>
		</skill>
				<skill>
					<name>madpurHurt2</name>
					<cnName>真视</cnName><showInLifeBarB>1</showInLifeBarB><wantDescripB>1</wantDescripB>
					<conditionType>passive</conditionType><noBeClearB>1</noBeClearB><everNoClearB>1</everNoClearB>
					<condition>add</condition>
					<target>me</target>
					<addType>state</addType>
					<effectType>findHideB2</effectType>
					<duration>999999</duration>
					<description>可看见隐身敌人。</description>
				</skill>
				<skill>
					<name>yaMadHead</name>
					<cnName>藐视</cnName>
					<conditionType>passive</conditionType>
					<condition>no</condition><target>me</target><addType>instant</addType>
					<effectType>no</effectType><mul>1.2</mul>
					<description>攻击时无视敌人的锁血、上限、上帝之盾技能。</description>
				</skill>
		<skill>
			<name>madpurUnder</name>
			<cnName>戒严</cnName><ignoreNoSkillB>1</ignoreNoSkillB><ignoreSilenceB>1</ignoreSilenceB><noSkillDodgeB>1</noSkillDodgeB><ignoreImmunityB>1</ignoreImmunityB>
			<conditionType>passive</conditionType><otherConditionArr>targetIsHero</otherConditionArr>
			<condition>underAllHit</condition><target>target</target><addType>instant</addType>
			<effectType>changeHurtAndMul</effectType><mul>0.75</mul>
			<description>受到持枪敌人的伤害减少[1-mul]。</description>
		</skill>
				<skill>
					<name>madpurUnder2</name>
					<cnName>惩戒</cnName><ignoreNoSkillB>1</ignoreNoSkillB><ignoreSilenceB>1</ignoreSilenceB><noSkillDodgeB>1</noSkillDodgeB><ignoreImmunityB>1</ignoreImmunityB>
					<conditionType>passive</conditionType><otherConditionArr>isMulHurt</otherConditionArr>
					<condition>underAllHit</condition><target>target</target><addType>instant</addType>
					<effectProArr>0.1</effectProArr>
					<effectType>madpurUnder2</effectType>
					<mul>0.3</mul>
					<description>受到百分比伤害时，有[effectProArr.0]的概率让敌人受到同样的百分比伤害（百分比不超过[mul]）。</description>
				</skill>
				<skill cnName="封锁">
					<name>yaMadCoat</name>
					<cnName>封锁</cnName><noSkillDodgeB>1</noSkillDodgeB><ignoreImmunityB>1</ignoreImmunityB><noBeClearB>1</noBeClearB>
					<!--触发条件与目标------------------------------------------------------------ -->
					<conditionType>passive</conditionType>
					<condition>summoned</condition>
					<otherConditionArr>targetArmsNoMeltFlamerPurgold,targetCn</otherConditionArr>
					<conditionString>战神</conditionString>
					<target>me,range,enemy</target>
					<!--效果------------------------------------------------------------ -->
					<addType>instantAndState</addType>
					<effectType>noAllSkill</effectType>
					<duration>5</duration>
					<range>999999</range>
					<!--图像------------------------------------------------------------ --> 
					<stateEffectImg partType="mouth" con="add">skillEffect/silenceMore</stateEffectImg>
					<pointEffectImg name="purpleLightning"/>
					<description>召唤战神时将封锁所有敌人[duration]秒。</description>
				</skill>
				
				
		<skill>
			<name>madpurPants</name>
			<cnName>讨伐</cnName><ignoreNoSkillB>1</ignoreNoSkillB><ignoreSilenceB>1</ignoreSilenceB><noSkillDodgeB>1</noSkillDodgeB><ignoreImmunityB>1</ignoreImmunityB>
			<conditionType>passive</conditionType><otherConditionArr>isDemon</otherConditionArr>
			<condition>hit</condition><target>target</target><addType>instant</addType>
			<effectType>changeHurtNoCondition</effectType><mul>1.2</mul>
			<description>修罗模式下伤害增加[mul-1]。</description>
		</skill>
				<skill>
					<name>madpurPants2</name>
					<cnName>远征</cnName><ignoreNoSkillB>1</ignoreNoSkillB><ignoreSilenceB>1</ignoreSilenceB><noSkillDodgeB>1</noSkillDodgeB><ignoreImmunityB>1</ignoreImmunityB>
					<conditionType>passive</conditionType><otherConditionArr>haveArmsSenB</otherConditionArr>
					<condition>hit</condition><target>target</target><addType>instant</addType>
					<effectType>changeHurtNoCondition</effectType><mul>1.20</mul>
					<description>对拥有武器敏感的敌人额外造成[mul-1]的伤害。</description>
				</skill>
				<skill>
					<name>yaMadPants</name>
					<cnName>诛灭</cnName><showInLifeBarB>1</showInLifeBarB><wantDescripB>1</wantDescripB>
					<conditionType>passive</conditionType><noBeClearB>1</noBeClearB><everNoClearB>1</everNoClearB>
					<condition>add</condition>
					<target>me</target>
					<addType>state</addType>
					<effectType>yaMadPants</effectType>
					<value>60</value>
					<mul>0.1</mul>
					<secMul>0.3</secMul>
					<duration>999999</duration>
					<description>每过[value]秒，角色就增加[mul]的伤害，最多增加[secMul]。时间停止期间不计时。</description>
				</skill>
				
				
				
		
		<skill>
			<name>madpurBelt</name>
			<cnName>降临</cnName><ignoreNoSkillB>1</ignoreNoSkillB><ignoreSilenceB>1</ignoreSilenceB><noSkillDodgeB>1</noSkillDodgeB><ignoreImmunityB>1</ignoreImmunityB>
			<conditionType>passive</conditionType>
			<condition>allDie</condition>
			<otherConditionArr>haveAllMadpur,noMainAndSpreadTask,noArena,noUnionPK,noDayTask6,noAntimatter_die</otherConditionArr>
			<target>me</target>
			<minTriggerT>300</minTriggerT>
			<!--效果------------------------------------------------------------ -->
			<addType>instant</addType>
			<summonedUnitsB>1</summonedUnitsB>
			<effectType>madpurBelt</effectType>
			<extraValueType>nowArmsDpsOrNormal</extraValueType>
			<duration>15</duration>
			<!-- 子弹所需 -->
			<obj>"cnName":"战神","num":1,"lifeMul":100000000,"dpsMul":20,"mulByFatherB":1,"maxNum":1,"skillArr":["crazy_pet_9","alloyShell_8","offBossAtten","madArmsAttack","desertedHalo_enemy","madCloseLightning","findHide","summonShortLife","rigidBody_enemy","MadbossUnder"]</obj>
			<!--图像------------------------------------------------------------ -->
			<meEffectImg noFollowB="1" soundUrl="sound/vehicleFit" con="add">generalEffect/vehicleFit</meEffectImg>
			<description>身穿全套战神装，在受到必亡伤害时将变身战神！持续[duration]秒，最短触发间隔[minTriggerT]秒。主线支线任务、竞技场无效。</description>
		</skill>
				<skill>
					<name>madpurBelt2</name>
					<cnName>降临II</cnName><ignoreNoSkillB>1</ignoreNoSkillB><ignoreSilenceB>1</ignoreSilenceB><noSkillDodgeB>1</noSkillDodgeB><ignoreImmunityB>1</ignoreImmunityB>
					<conditionType>passive</conditionType>
					<condition>allDie</condition>
					<otherConditionArr>haveAllMadpur,noMainAndSpreadTask,noArena,noUnionPK,noDayTask6,noAntimatter_die</otherConditionArr>
					<target>me</target>
					<minTriggerT>300</minTriggerT>
					<!--效果------------------------------------------------------------ -->
					<addType>instant</addType>
					<summonedUnitsB>1</summonedUnitsB>
					<effectType>madpurBelt</effectType>
					<extraValueType>nowArmsDpsOrNormal</extraValueType>
					<duration>20</duration>
					<!-- 子弹所需 -->
					<obj>"cnName":"战神","num":1,"lifeMul":1000000000,"dpsMul":25,"mulByFatherB":1,"maxNum":1,"skillArr":["noUnderMulHurt","spellImmunityMax","meltFlamerPurgold","crazy_pet_9","alloyShell_8","offBossAtten","madArmsAttack","desertedHalo_enemy","madCloseLightning","findHide","summonShortLife","rigidBody_enemy","MadbossUnder"]</obj>
					<!--图像------------------------------------------------------------ -->
					<meEffectImg noFollowB="1" soundUrl="sound/vehicleFit" con="add">generalEffect/vehicleFit</meEffectImg>
					<description>身穿全套战神装，在受到必亡伤害时将变身战神（新增技能：钢骨、化锁、技能免除）！持续[duration]秒，最短触发间隔[minTriggerT]秒。主线支线任务、竞技场无效。</description>
				</skill>
				
				
		
	</father>
</data>