			<highDispaArr>78级零件箱</highDispaArr>
			<lowDispaArr>强化石,副手箱</lowDispaArr>
		</gene>
		
		<gene name="PetZombieBattle" cnName="战斗僵尸" targetBodyName="ZombieBattle">
