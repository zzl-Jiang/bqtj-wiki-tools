		</gene>
		
		<![CDATA[顶级宠物]]>
		<gene name="PetIronChief" cnName="铁魁" targetBodyName="PetIronChief" grade="1"  type="boss" evolutionLabel="PetIronChiefSecond"  evolutionMustMul="1,1,1.4">
