		<gene name="PetZombieWolf" cnName="嗜血尸狼" targetBodyName="ZombieWolf" type="boss" evolutionLabel="PetFightWolf"  evolutionMustMul="2,1.6,1.6" growMust="1">
			<dpsMul>1.2</dpsMul><lifeMul>4.2</lifeMul>
			<talentSkillArr>summon_PetFightWolf,laser_PetFightWolf,treater_PetFightWolf</talentSkillArr>
