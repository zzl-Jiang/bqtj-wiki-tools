			<lowDispaArr>超能石,神能石</lowDispaArr>
		</gene>
		
		<gene name="PetZombieFootball" cnName="橄榄僵尸" targetBodyName="ZombieFootball" evolutionLabel="PetZombieHelmet"  evolutionMustMul="1,1,1">
			<dpsMul>0.5</dpsMul><lifeMul>6</lifeMul>
