<?xml version="1.0" encoding="utf-8" ?>
<data>
	<father>
		<gene name="PetZombieKing" cnName="僵尸王" targetBodyName="ZombieKing" type="boss" evolutionLabel="PetIronZombieKing" evolutionMustMul="1,0.8,0.8">
			<dpsMul>0.5</dpsMul><lifeMul>6</lifeMul>
			<talentSkillArr>crazy_pet,trueshot_pet,shelling_ZombieKing</talentSkillArr>
			<highDispaArr>神车卡片</highDispaArr>
			<lowDispaArr>转化石</lowDispaArr>
		</gene>
		
		<gene name="PetFightKing" cnName="狂战尸" targetBodyName="FightKing" type="boss" evolutionLabel="PetChaosKing"  evolutionMustMul="0.8,0.8,1">
			<dpsMul>1</dpsMul><lifeMul>4</lifeMul>
			<talentSkillArr>shake_FightKing,whirlwind_FightKing,shoot_FightKing</talentSkillArr>
			<highDispaArr>精石</highDispaArr>
			<lowDispaArr>血石</lowDispaArr>
		</gene>
		
		<gene name="PetZombieCleaver" cnName="屠刀僵尸" targetBodyName="ZombieCleaver">
