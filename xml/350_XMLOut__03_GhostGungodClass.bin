<?xml version="1.0" encoding="utf-8" ?>
<data>
	<father name="death" info="单位">
		<body index="0" name="末日枪神" shell="normal">
			<name>GhostGungod</name>
			<cnName>末日枪神</cnName>
			<raceType>human</raceType>
			<movieLink>Striker</movieLink>
			<swfName>bioShock</swfName>
			<showLevel>9999</showLevel>
			<!-- 基本系数 -->
			<headIconUrl>IconGather/GhostSoldier</headIconUrl>
			<!-- 碰撞体积 -->
			<hitRect>-12, -90, 24, 90</hitRect>
			<squatHitRect>-12,-50,24,50</squatHitRect>
			<hurtRectArr>-12,-35,24,35</hurtRectArr> 
			<hurtRectArr>-12, -70, 24, 70</hurtRectArr> 
			<hurtRectArr>-12, -40, 24, 40</hurtRectArr> 
			<!-- 运动 -->
			<maxVx>15</maxVx>
			<squatMaxVx>5</squatMaxVx>
			<!-- AI属性 -->
			<armsNumber>4</armsNumber><!-- 武器个数 -->
			<randomArmsRange>sniperBlue$gungod,rocketSpace,shotgunTyran,smileCrossbow</randomArmsRange>
			<!-- 技能 -->
			<skillArr></skillArr>
			<bossSkillArr>gunReloadSwap</bossSkillArr>
		</body>
		
				<skill name="换枪">
					<name>gunReloadSwap</name><noRandomListB>1</noRandomListB>
					<cnName>换枪</cnName><ignoreImmunityB>1</ignoreImmunityB><ignoreNoSkillB>1</ignoreNoSkillB>
					<!--触发条件与目标------------------------------------------------------------ -->
					<conditionType>passive</conditionType>
					<condition>heroShootReload</condition>
					<otherConditionArr>isAI</otherConditionArr>
					<target>me</target>
					<!--效果------------------------------------------------------------ -->
					<addType>instant</addType>
					<effectType>gunReloadSwap</effectType>
					<duration>3</duration><!-- 每把枪最短使用多长时间 -->
					<pointEffectImg name="swapArms"/>
					<description>一把枪的子弹打完后，立马换下一把枪。</description>
				</skill>
		
	</father>
	
	<father cn="来自武器工厂">
		<![CDATA[
		<armsEdit name="starTrails$gungod" info="末日枪神-星环">{'cnName':'星环','baseLabel':'starTrails','dpsMul':0.02,'extraMul':1,'reloadGap':2,'capacity':10,'bulletWidth':60,'penetrationGap':1000,'attackGap':0.5,'bulletLife':0.5,'bulletNum':3,'shootAngle':120,'speedD':{'vra':0.42},'aiShootRange':900,'followD':{'aiStopGap':110,'shootTween':0.4}}</armsEdit>
		]]>
		<armsEdit name="sniperBlue$gungod" info="末日枪神-狙击">{'baseLabel':'sniperBlue','capacity':6,'followD':{'shootDelayLockB':true},'attackGap':1.2,'attackDelay':1,'bulletWidth':1200,'bounceD':{'body':0},'skillArr':[],'penetrationNum':0,'penetrationGap':1000,'dpsMul':1,'twoShootPro':0,'godSkillArr':[]}</armsEdit>
		
	</father>
	<father type="crossbow" cnName="弩">
		<bullet kind="boom">
			<name>smileCrossbow</name><cnName>含笑弩</cnName>
			<dpsMul>1</dpsMul>
			<noHitB>1</noHitB>
			<!--基本-->
			<capacity>5</capacity>`
			<attackDelay>0.5</attackDelay><aiShootRange>1000</aiShootRange>
			<attackGap>2</attackGap>
			<reloadGap>1</reloadGap>
			<bulletWidth>20</bulletWidth>
			<bulletNum>1</bulletNum>				
			<shootAngle>3</shootAngle>
			<!--武器属性------------------------------------------------------------ -->
			<armsArmMul>0.5</armsArmMul><upValue>10</upValue><shootShakeAngle>30</shootShakeAngle><shootRecoil>7</shootRecoil><screenShakeValue>10</screenShakeValue>
			<!--基本属性------------------------------------------------------------ -->
			<bulletLife>0.6</bulletLife>
			<hitType>rect</hitType>
			<!--运动属性------------------------------------------------------------ -->	
			<bulletSpeed>70</bulletSpeed>
			
			<penetrationGap>1000</penetrationGap>
			<!--特殊------------------------------------------------------------ -->	
			<followD shootCY="-400"/>
			<boomD  selfB="1" radius="0" hurtMul="0" />
			<crossbowD focoB="1" minDelayMul="0.2"/>
			<bulletSkillArr>smileCrossbowSunSunDieEvent</bulletSkillArr>
			<!--图像动画属性------------------------------------------------------------ -->
			<shootSoundUrl>specialGun/arrowAttack</shootSoundUrl>
			<bulletImgUrl con="add">specialGun/beadBullet</bulletImgUrl>
			<selfBoomImgUrl soundUrl="boomSound/midBoom2" soundVolume="0.5" con="add">specialGun/beadBoom</selfBoomImgUrl><!-- 子弹图像【必备】 -->
			<smokeImgUrl con="filter" raNum="30">specialGun/electricLine</smokeImgUrl><!-- 子弹尾烟效果（默认为空） -->
			<fireImgType>no</fireImgType>
			<!--图像范围------------------------------------------------------------ -->
			<bodyImgRange>specialGun/beadCrossbow</bodyImgRange><bulletImgRange>specialGun/bullet</bulletImgRange>
			
			<description></description>
		</bullet>
				<bullet cnName="含笑弩-子弹">
					<name>smileCrossbowSun</name>
					<cnName>含笑弩-子弹</cnName><armsType>crossbow</armsType>
					<noMagneticB>1</noMagneticB>
					<noHitTime>0.2</noHitTime>
					<!--伤害属性------------------------------------------------------------ -->
					<hurtRatio>0.3</hurtRatio>
					<!--基本属性------------------------------------------------------------ -->
					<bulletNum>40</bulletNum>
					<shootAngle>90</shootAngle>
					<bulletAngle>90</bulletAngle>
					<bulletLife>5</bulletLife>
					<bulletWidth>25</bulletWidth>
					<hitType>rect</hitType>
					<!--攻击时的属性------------------------------------------------------------ -->
					<bulletSpeed>15</bulletSpeed>
					<speedD lockRaB="1"/>
					<penetrationGap>1000</penetrationGap>
					<!--图像动画属性------------------------------------------------------------ -->
					<flipX>1</flipX>
					<bulletImgUrl name="redThorn"/>
					<hitImgUrl name="gun_hit"/>
				</bullet>
		<![CDATA[
				<bullet>
					<name>fireworksGunSun</name>
					<cnName>烟花-子弹</cnName><armsType>crossbow</armsType>
					<noMagneticB>1</noMagneticB>
					<noHitTime>0.2</noHitTime>
					<!--伤害属性------------------------------------------------------------ -->
					<hurtRatio>0.3</hurtRatio>
					<!--基本属性------------------------------------------------------------ -->
					<bulletNum>20</bulletNum>
					<shakeAngle>6</shakeAngle>
					<shootAngle>174</shootAngle>
					<bulletAngle>90</bulletAngle>
					<bulletLife>5</bulletLife>
					<bulletWidth>25</bulletWidth>
					<hitType>rect</hitType>
					<!--攻击时的属性------------------------------------------------------------ -->
					<bulletSpeed>15</bulletSpeed>
					<speedD lockRaB="1"/>
					
					<penetrationGap>1000</penetrationGap>
					<!--图像动画属性------------------------------------------------------------ -->
					<flipX>1</flipX>
					<bulletImgUrl name="redThorn"/>
					<hitImgUrl name="gun_hit"/>
				</bullet>
			]]>	
				
		
	</father>
	<father type="rocket" cnName="火炮">
		<bullet info="末日枪神-苍穹">
			<name>rocketSpace</name>
			<cnName>苍穹</cnName>
			<dpsMul>1</dpsMul>
			<hurtRatio>1</hurtRatio>
			<aiShootRange>1200</aiShootRange>
			<hitType>rect</hitType>
			<!--基本-->
			<bulletNum>1</bulletNum>
			<capacity>6</capacity>
			<attackGap>1.7</attackGap>
			<shakeAngle>20</shakeAngle>
			<attackDelay>1.2</attackDelay>
			<reloadGap>1</reloadGap>
			<bulletWidth>20</bulletWidth>
			<!--武器属性------------------------------------------------------------ -->
			<armsArmMul>0.65</armsArmMul>
			<upValue>5</upValue>
			<shootShakeAngle>30</shootShakeAngle>
			<shootRecoil>12</shootRecoil>
			<screenShakeValue>16</screenShakeValue>
			<!--基本属性------------------------------------------------------------ -->
			<bulletLife>7</bulletLife>
			<bulletSpeed>15</bulletSpeed>
			<speedD max="35" min="3" a="-10"/>
			<!--特殊------------------------------------------------------------ -->
			<penetrationGap>1000</penetrationGap>
			<bulletSkillArr>pointerMissileRanRaLAST</bulletSkillArr>
			<followD value="2" delay="1" />
			<boomD selfB="1" bodyB="1" radius="100" />
			<noHitTime>0.1</noHitTime>
			<!--图像动画属性------------------------------------------------------------ -->
			<shootSoundUrl>specialGun/rocketHummer_sound</shootSoundUrl>
			<bulletImgUrl name="fightBackBullet_bullet"/>
			<hitImgUrl name="midSpaceQuietly"/><!-- 子弹图像【必备】 -->
			<smokeImgUrl name="rocketSmokeSm"/><!-- 子弹尾烟效果（默认为空） -->
			<fireImgUrl name="gunFireRocket"/>
			<!--图像范围------------------------------------------------------------ -->
			<bodyImgRange>specialGun/rocketSky</bodyImgRange>
			<bulletImgRange>specialGun/bullet</bulletImgRange>
		</bullet>
	</father>
	<father type="shotgun" cnName="散弹枪">
		<bullet info="末日枪神-暴龙">
			<name>shotgunTyran</name>
			<cnName>暴龙</cnName>
			<dpsMul>5</dpsMul>
			<aiShootRange>800</aiShootRange>
			<!--基本-->
			<bulletNum>45</bulletNum>
			<shootAngle>90</shootAngle>
			<capacity>6</capacity>
			<attackGap>1.3</attackGap>
			<attackDelay>0.8</attackDelay>
			<reloadGap>1</reloadGap>
			<shakeAngle>1</shakeAngle>
			<bulletWidth>15</bulletWidth>
			<extendGap>50</extendGap>				
							
			<beatBack>2</beatBack>
			<targetShakeValue>10</targetShakeValue>
			<penetrationGap>1000</penetrationGap>
			<!--武器属性------------------------------------------------------------ -->
			<hurtRatio>1</hurtRatio>
			<armsArmMul>0.6</armsArmMul>
			<armsWeight>5</armsWeight>
			<upValue>14</upValue>
			<shootShakeAngle>70</shootShakeAngle>
			<shootRecoil>10</shootRecoil>
			<screenShakeValue>15</screenShakeValue>
			<!--基本属性------------------------------------------------------------ -->
			<bulletLife>7</bulletLife>
			<bulletSpeed>13</bulletSpeed>
			<hitType>rect</hitType>
			<!--特殊------------------------------------------------------------ -->
			<!--图像动画属性------------------------------------------------------------ -->
			<iconUrl>specialGun/shotgunRedIcon</iconUrl>
			<shootSoundUrl>specialGun/shotgunRed_sound</shootSoundUrl>
			<bulletImgUrl name="redThorn"/>
			<fireImgUrl name="purgoldSkunkLink_point"/>
			<hitImgUrl name="gun_hit"/>
			<!--图像范围------------------------------------------------------------ -->
			<bodyImgRange>specialGun/shotgunRed</bodyImgRange>
			<bulletImgRange>specialGun/bullet</bulletImgRange>
		</bullet>
	</father>
</data>