			<bulletImgRange>newGun/m4RifleBullet</bulletImgRange>
		</bullet>
	</father>
	<father name="deathArms">
		<skill>
			<name>beatMoveDeath</name><noRandomListB>1</noRandomListB>
			<cnName>击退</cnName><ignoreImmunityB>1</ignoreImmunityB>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>passive</conditionType>
			<condition>hit</condition>
			<target>target</target>
			<!--效果------------------------------------------------------------ -->
			<addType>instant</addType>
			<effectType>toMoveFromHurtRa</effectType>
			<value>4</value>
			<description>子弹击中敌人后，将目标往后推动一段距离，无视技能免疫。</description>
		</skill>
		
		<skill name="惊跳">
			<name>jumpAutoDea</name>
			<cnName>惊跳</cnName><noSkillDodgeB>1</noSkillDodgeB>
			<haveEffectBuletHitNum>1</haveEffectBuletHitNum>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>passive</conditionType><condition>hit</condition><target>target</target>
			<!--效果------------------------------------------------------------ -->
			<addType>instantAndState</addType>
			<effectType>jumpAuto</effectType>
			<mul>5</mul>
			<value>7</value>
			<duration>0.2</duration>
			<description>每次射击都会让敌人不由自主的弹跳。</description>
		</skill>
		<skill name="尸爆">
			<name>corpseBoom</name>
			<cnName>尸爆</cnName>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>passive</conditionType>
			<condition>killTarget</condition>
			<target>target,range,enemy</target><!-- 目标	me：自己，target：目标（攻击的目标、击毙的目标），target,random,enemy：被攻击目标中心范围内的随机目标，me,range,enemy：距离自己300范围内的敌方目标， -->
			<!--效果------------------------------------------------------------ -->
			<addType>instant</addType>
			<effectType>hurtFromChildLockAndHurtTargetPointEffect</effectType>
			<valueString>poison</valueString>
			<extraValueType>hurtValueXarmsSpeed</extraValueType>
			<value>0</value>
			<mul>0.6</mul>
			<range>200</range>
			<!--图像------------------------------------------------------------ -->
			<pointEffectImg name="greemBoom"/>
			<description>击毙目标后，如果附近有敌人，则会引发尸爆，对[range]范围内的敌人造成伤害，伤害值=击中伤害*武器射速*60%。</description>
		</skill>
		
		<skill name="派生导弹">
			<name>hitMissileDea</name>
			<cnName>派生导弹</cnName>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>passive</conditionType>
			<condition>heroOneShoot</condition>
			<target>me</target>
			<!--效果------------------------------------------------------------ -->
			<addType>instant</addType>
			<effectType>bullet</effectType>
			<effectProArr>0.3</effectProArr>
			<extraValueType>nowArmsHurt</extraValueType>
			<!-- 子弹所需 -->
			<obj>"name":"hitMissileDea","site":"shootPoint","flipB":false</obj>
			<!--图像------------------------------------------------------------ -->
			<meEffectImg></meEffectImg>
			<targetEffectImg></targetEffectImg>
			<description>每次射击都有[effectProArr.0]的概率派生跟踪导弹。导弹伤害为当前武器面板单发伤害。</description>
		</skill>
				<bullet cnName="派生导弹">
					<name>hitMissileDea</name>
					<cnName>派生导弹</cnName>
					<!--伤害属性------------------------------------------------------------ -->
					<hurtRatio>1</hurtRatio>
					<!--基本属性------------------------------------------------------------ -->
					<shakeAngle>25</shakeAngle>
					<bulletLife>3</bulletLife>
					<bulletWidth>15</bulletWidth>
					<hitType>rect</hitType>
					<!--攻击时的属性------------------------------------------------------------ -->
					<attackGap>0</attackGap>
					<attackDelay>0</attackDelay>
					<bulletAngle>0</bulletAngle>
					<bulletNum>1</bulletNum>				
					<shootNum>1</shootNum>					
										
					<shootAngle>0</shootAngle>					
					<!--特殊属性------------------------------------------------------------ -->	
					<followD value="1" delay="0.2" />	<!-- 跟踪 -->
					<!--运动属性------------------------------------------------------------ -->	
					<shootPoint>0,0</shootPoint>
					<bulletSpeed>25</bulletSpeed>
					<speedD random="0.1"/>
					<gravity>0</gravity>
					<!--图像动画属性------------------------------------------------------------ -->
					<flipX>1</flipX>
					<bulletImgUrl raNum="30">bullet/missile_bullet</bulletImgUrl>
					<hitImgUrl  name="smallSpace"/>
					<smokeImgUrl name="smallMissleSmokeSm"/><!-- 子弹尾烟效果（默认为空） -->
				</bullet>
	</father>
	
	
	
	
</data>