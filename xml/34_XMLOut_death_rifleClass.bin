<?xml version="1.0" encoding="utf-8" ?>
<data>
	
	<father type="rifle" cnName="橙色 步枪">
		<bullet color="orange">
			<name>gatling</name>
			<cnName>加特林</cnName><dpsMul>1.11</dpsMul>
			<iconUrl>newGun/gatling_icon</iconUrl>
			<!--基本-->
			<capacity>1200</capacity><skillArr>beatMoveDeath</skillArr>
			<attackGap>0.066</attackGap>
			<reloadGap>2</reloadGap>
			<shakeAngle>5</shakeAngle>
			<bulletWidth>700</bulletWidth>
			<bulletNum>1</bulletNum>
			<bulletShakeWidth>50</bulletShakeWidth>		
			<beatBack>3</beatBack>
			<targetShakeValue>8</targetShakeValue>
			<!--武器属性------------------------------------------------------------ -->
			<armsArmMul>0.45</armsArmMul>
			<upValue>25</upValue>
			<shootShakeAngle>17</shootShakeAngle>
			<shootRecoil>2</shootRecoil>
			<screenShakeValue>8</screenShakeValue>
			<!--基本属性------------------------------------------------------------ -->
			<noShakeTime>0.5</noShakeTime>
			<bulletLife>0.001</bulletLife>
			<hitType>longLine</hitType>
			<bulletImgUrl>longLine</bulletImgUrl>
			<hitImgUrl>bulletHitEffect/yellow_motion</hitImgUrl>
			<!--图像范围------------------------------------------------------------ -->
			<shootSoundUrl>ak/barrel7_sound</shootSoundUrl>
			<bodyImgRange>newGun/gatling</bodyImgRange>
			<bulletImgRange>specialGun/bullet</bulletImgRange>
		</bullet>
	</father>
	
	<father type="rifle" cnName="步枪">
