		<bullet color="blue">
			<name>akYellow</name>
			<cnName>咆哮</cnName><dpsMul>1.15</dpsMul>
			<iconUrl>newGun/akYellow_icon</iconUrl>
			<!--基本-->
			<capacity>1666</capacity><skillArr>jumpAutoDea</skillArr>
