<?xml version="1.0" encoding="utf-8" ?>
<data>
	<![CDATA[玩家武器]]>
	<father cn="来自武器工厂">
		
	</father>
	<father type="crossbow" cnName="弩">
		<bullet color="blue">
			<cnName>痛·刺蝎</cnName>
			<name>scorpionDea</name><iconUrl>newGun/scorpionCrossbow_icon</iconUrl>
			<dpsMul>1.04</dpsMul>
			<!--基本-->
			<capacity>1000</capacity>
			<attackGap>0.2</attackGap>
			<reloadGap>1</reloadGap>
			<bulletWidth>35</bulletWidth>
			<bulletNum>1</bulletNum>				
			<shootAngle>3</shootAngle>
			<!--武器属性------------------------------------------------------------ -->
			<armsArmMul>0.5</armsArmMul><upValue>10</upValue><shootShakeAngle>30</shootShakeAngle><shootRecoil>7</shootRecoil><screenShakeValue>10</screenShakeValue>
			<!--基本属性------------------------------------------------------------ -->
			<bulletLife>2.5</bulletLife>
			<hitType>rect</hitType>
			<!--运动属性------------------------------------------------------------ -->	
			<bulletSpeed>45</bulletSpeed>
			<!--特殊------------------------------------------------------------ -->	
			<attackDelay>0.15</attackDelay>
			<crossbowD focoB="1" minDelayMul="0.4"/>
			<skillArr>beatBackDeath</skillArr>
			<!--图像动画属性------------------------------------------------------------ -->
			<shootSoundUrl>specialGun/arrowAttack</shootSoundUrl>
			<bulletImgUrl name="scorpionCrossbow_bullet" />
			<hitImgUrl soundUrl="specialGun/arrowImpact">bulletHitEffect/yellow_motion</hitImgUrl><!-- 子弹图像【必备】 -->
			<hitFloorImgUrl>bulletHitEffect/yellow_motion</hitFloorImgUrl><!-- 子弹图像【必备】 -->
			<smokeImgUrl raNum="30" con="filter">bulletHitEffect/smoke_small2</smokeImgUrl><!-- 子弹尾烟效果（默认为空） -->
			<fireImgUrl name="SilverShipFire"/>
			<!--图像范围------------------------------------------------------------ -->
			<bodyImgRange>specialGun/scorpionCrossbow</bodyImgRange><bulletImgRange>specialGun/bullet</bulletImgRange>
		</bullet>
	</father>
	<father name="deathArms">
		<skill>
			<name>beatBackDeath</name><noRandomListB>1</noRandomListB>
			<cnName>痛击</cnName><ignoreImmunityB>1</ignoreImmunityB>
			<!--触发条件与目标------------------------------------------------------------ -->
			<conditionType>passive</conditionType>
			<condition>hit</condition>
			<target>target</target>
			<!--效果------------------------------------------------------------ -->
			<addType>state</addType><overlyingB>1</overlyingB>
			<effectType>beatBack_arms</effectType>
			<value>20</value>
			<duration>0.1</duration>
			<stateEffectImg bodyColor="0xFF0000"></stateEffectImg>
			<description>击中同时推动目标一段距离，蓄力越久推动距离越远，无视技能免疫。</description>
		</skill>
	</father>
</data>